---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../../lib/supabase';

export const prerender = false;

const id = Astro.params.id;
if (!id) return Astro.redirect('/admin/clubs');

const admin = getSupabaseAdmin();

const { data: club } = await admin.from('clubs').select('*').eq('id', id).maybeSingle();
if (!club) return Astro.redirect('/admin/clubs');

const [
  { data: teams },
  { data: players },
  { data: matches },
  { data: members },
] = await Promise.all([
  admin.from('teams').select('id, name, sport, season, is_archived').eq('club_id', id).order('created_at', { ascending: true }),
  admin.from('players').select('id, first_name, last_name, jersey_number, position, status, team_id').eq('club_id', id).limit(20),
  admin.from('matches').select('id, date, opponent, our_score, opp_score, team_id').eq('club_id', id).order('date', { ascending: false }).limit(10),
  admin.from('club_members').select('id, role, user_id, created_at').eq('club_id', id),
]);

const userIds = (members ?? []).map((m: any) => m.user_id);
const { data: profiles } = userIds.length
  ? await admin.from('profiles').select('id, email, first_name, last_name').in('id', userIds)
  : { data: [] as any[] };
const profileById = new Map<string, any>((profiles ?? []).map((p: any) => [p.id, p]));

const url = new URL(Astro.request.url);
const saved = url.searchParams.get('saved');
const errorMsg = url.searchParams.get('error');

const tierLabel: Record<string, string> = { trial: 'Trial', tym: 'Tým', klub: 'Klub', liga: 'Liga' };
---

<AdminLayout title={`${club.name} · Admin`} active="clubs" pageTitle={club.name} pageSub={`Klub · /${club.slug} · ${club.sport ?? '—'} · ${tierLabel[club.subscription_tier] ?? club.subscription_tier}`}>

  {saved && <div class="mb-6 rounded-lg border border-verde/30 bg-verde/5 px-4 py-3 text-[14px] text-[#1B6E62]">✓ Změny uloženy.</div>}
  {errorMsg && <div class="mb-6 rounded-lg border border-signal/30 bg-signal/5 px-4 py-3 text-[14px] text-signal">{errorMsg}</div>}

  <div class="mb-6 flex flex-wrap items-center gap-2 text-[13px]">
    <a href="/admin/clubs" class="rounded-md border border-stone bg-pearl px-3 py-1.5 font-medium text-graphite hover:bg-mist">← Všechny kluby</a>
  </div>

  <div class="grid gap-6 lg:grid-cols-[1fr_320px]">
    <div class="space-y-6">

      <!-- Club info -->
      <div class="rounded-xl border border-stone bg-pearl p-6">
        <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Klubové info</p>
        <dl class="mt-4 grid gap-3 text-[13px] sm:grid-cols-2">
          <div><dt class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">Název</dt><dd class="mt-1 text-ink">{club.name}</dd></div>
          <div><dt class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">Slug</dt><dd class="mt-1 font-mono text-ink">{club.slug}</dd></div>
          <div><dt class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">Sport</dt><dd class="mt-1 text-ink">{club.sport ?? '—'}</dd></div>
          <div><dt class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">Owner</dt><dd class="mt-1 font-mono text-[11px] text-graphite">{club.owner_id}</dd></div>
          <div><dt class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">Vytvořeno</dt><dd class="mt-1 text-ink">{new Date(club.created_at).toLocaleDateString('cs-CZ')}</dd></div>
          <div><dt class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">Custom domain</dt><dd class="mt-1 text-ink">{club.custom_domain ?? '—'}</dd></div>
        </dl>
      </div>

      <!-- Teams -->
      <div class="rounded-xl border border-stone bg-pearl">
        <div class="flex items-center justify-between border-b border-stone px-5 py-4">
          <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Týmy</p>
          <span class="text-[12px] text-slate">{(teams ?? []).length}</span>
        </div>
        {(teams ?? []).length === 0 ? <div class="p-6 text-center text-[13px] text-slate">Žádné týmy.</div> : (
          <ul class="divide-y divide-stone">
            {(teams ?? []).map((t: any) => (
              <li class="flex items-center justify-between gap-3 px-5 py-3">
                <a href={`/admin/teams/${t.id}`} class="flex-1 min-w-0 hover:text-plum">
                  <p class="text-[14px] font-semibold text-ink">{t.name}{t.is_archived && <span class="ml-2 text-[10px] uppercase tracking-wider text-stone-2">archiv</span>}</p>
                  <p class="text-[11px] text-slate">{t.sport} · sezóna {t.season}</p>
                </a>
                <a href={`/admin/teams/${t.id}`} class="text-[11px] font-semibold text-plum hover:underline">Detail →</a>
              </li>
            ))}
          </ul>
        )}
      </div>

      <!-- Members -->
      <div class="rounded-xl border border-stone bg-pearl">
        <div class="border-b border-stone px-5 py-4">
          <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Členové</p>
        </div>
        {(members ?? []).length === 0 ? <div class="p-6 text-center text-[13px] text-slate">Žádní členové.</div> : (
          <ul class="divide-y divide-stone">
            {(members ?? []).map((m: any) => {
              const p = profileById.get(m.user_id);
              const name = p ? `${p.first_name ?? ''} ${p.last_name ?? ''}`.trim() || p.email : '—';
              return (
                <li class="flex items-center justify-between gap-3 px-5 py-3">
                  <div>
                    <p class="text-[14px] font-semibold text-ink">{name}</p>
                    <p class="text-[11px] text-slate">{p?.email ?? '—'}</p>
                  </div>
                  <span class="rounded-md bg-mist px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.08em] text-graphite">{m.role}</span>
                </li>
              );
            })}
          </ul>
        )}
      </div>

      <!-- Recent matches -->
      <div class="rounded-xl border border-stone bg-pearl">
        <div class="border-b border-stone px-5 py-4">
          <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Posledních {(matches ?? []).length} zápasů</p>
        </div>
        {(matches ?? []).length === 0 ? <div class="p-6 text-center text-[13px] text-slate">Žádné zápasy.</div> : (
          <ul class="divide-y divide-stone">
            {(matches ?? []).map((m: any) => (
              <li class="flex items-center justify-between gap-3 px-5 py-3 text-[13px]">
                <a href={`/admin/matches/${m.id}`} class="flex-1 min-w-0 hover:text-plum">
                  <p class="font-semibold text-ink">vs {m.opponent}</p>
                  <p class="text-[11px] text-slate">{new Date(m.date).toLocaleDateString('cs-CZ')}</p>
                </a>
                <span class="font-bold tabular-nums text-ink">{m.our_score}–{m.opp_score}</span>
                <a href={`/admin/matches/${m.id}`} class="text-[11px] font-semibold text-plum hover:underline">Detail →</a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>

    <!-- Side panel: super admin actions -->
    <aside class="space-y-4">
      <div class="rounded-xl border border-plum/30 bg-gradient-to-br from-plum/5 to-signal/5 p-5">
        <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-[#4F3878]">Admin akce</p>

        <!-- Change tier -->
        <form method="POST" action="/api/super/club/tier" class="mt-4">
          <input type="hidden" name="club_id" value={club.id} />
          <label class="block text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Tier</label>
          <select name="tier" class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2 text-[13px] text-ink">
            <option value="trial" selected={club.subscription_tier === 'trial'}>Trial</option>
            <option value="tym"   selected={club.subscription_tier === 'tym'}>Tým</option>
            <option value="klub"  selected={club.subscription_tier === 'klub'}>Klub</option>
            <option value="liga"  selected={club.subscription_tier === 'liga'}>Liga</option>
          </select>
          <button type="submit" class="mt-3 w-full rounded-md bg-plum px-3 py-2 text-[12px] font-semibold text-white hover:bg-[#3F2B68]">Změnit tier</button>
        </form>

        <p class="mt-5 text-[11px] text-slate">Pozor: změna tieru se aplikuje okamžitě bez Stripe orchestrace. Pro účet s aktivním předplatným použijte Stripe portál místo přímé změny.</p>
      </div>

      <div class="rounded-xl border border-stone bg-pearl p-5">
        <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-slate">Stripe</p>
        <dl class="mt-3 space-y-2 text-[12px]">
          <div><dt class="text-stone-2">Customer ID</dt><dd class="font-mono text-graphite">{club.stripe_customer_id ?? '—'}</dd></div>
          <div><dt class="text-stone-2">Subscription ID</dt><dd class="font-mono text-graphite">{club.stripe_subscription_id ?? '—'}</dd></div>
          <div><dt class="text-stone-2">Status</dt><dd class="text-ink">{club.subscription_status}</dd></div>
          <div><dt class="text-stone-2">Period end</dt><dd class="text-ink">{club.current_period_end ? new Date(club.current_period_end).toLocaleDateString('cs-CZ') : '—'}</dd></div>
        </dl>
      </div>
    </aside>
  </div>
</AdminLayout>
