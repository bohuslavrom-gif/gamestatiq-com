---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../../lib/supabase';

export const prerender = false;

const id = Astro.params.id;
if (!id) return Astro.redirect('/admin/leagues');

const admin = getSupabaseAdmin();

const { data: league } = await admin.from('leagues').select('*').eq('id', id).maybeSingle();
if (!league) return Astro.redirect('/admin/leagues');

const [{ data: ltRaw }, { data: lmRaw }] = await Promise.all([
  admin
    .from('league_teams')
    .select('team_id, invited_at, approved_at, teams(id, name, sport, clubs(name))')
    .eq('league_id', id)
    .order('invited_at', { ascending: false }),
  admin
    .from('league_members')
    .select('id, role, user_id, created_at')
    .eq('league_id', id),
]);

const lts = (ltRaw ?? []) as any[];
const lms = (lmRaw ?? []) as any[];

// Iter 7c: list of all non-archived teams across all clubs (for force-add picker)
// Filter out teams already in this league
const inLeagueIds = new Set(lts.map((r) => r.team_id));
const { data: allTeamsRaw } = await admin
  .from('teams')
  .select('id, name, sport, club_id, clubs(name)')
  .eq('is_archived', false)
  .order('created_at', { ascending: true });
const availableTeams = ((allTeamsRaw ?? []) as any[]).filter((t) => !inLeagueIds.has(t.id));

const userIds = lms.map((m) => m.user_id);
const { data: profiles } = userIds.length
  ? await admin.from('profiles').select('id, email, first_name, last_name').in('id', userIds)
  : { data: [] as any[] };
const profileById = new Map<string, any>((profiles ?? []).map((p: any) => [p.id, p]));

const approved = lts.filter((r) => r.approved_at);
const pending  = lts.filter((r) => !r.approved_at);

const url = new URL(Astro.request.url);
const saved = url.searchParams.get('saved');
const errorMsg = url.searchParams.get('error');

const tierLabel: Record<string, string> = { klub: 'Klub', liga: 'Liga' };
---

<AdminLayout title={`${league.name} · Admin`} active="leagues" pageTitle={league.name} pageSub={`Liga · ${league.sport} · ${tierLabel[league.subscription_tier] ?? league.subscription_tier}`}>

  {saved && <div class="mb-6 rounded-lg border border-verde/30 bg-verde/5 px-4 py-3 text-[14px] text-[#1B6E62]">✓ Změny uloženy.</div>}
  {errorMsg && <div class="mb-6 rounded-lg border border-signal/30 bg-signal/5 px-4 py-3 text-[14px] text-signal">{errorMsg}</div>}

  <div class="mb-6 flex flex-wrap items-center gap-2 text-[13px]">
    <a href="/admin/leagues" class="rounded-md border border-stone bg-pearl px-3 py-1.5 font-medium text-graphite hover:bg-mist">← Všechny ligy</a>
    <a href={`/liga/${league.slug}`} target="_blank" rel="noopener" class="rounded-md border border-stone bg-pearl px-3 py-1.5 font-medium text-graphite hover:bg-mist">Public stránka ↗</a>
  </div>

  <div class="grid gap-6 lg:grid-cols-[1fr_320px]">
    <div class="space-y-6">

      <!-- League info -->
      <div class="rounded-xl border border-stone bg-pearl p-6">
        <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Liga info</p>
        <dl class="mt-4 grid gap-3 text-[13px] sm:grid-cols-2">
          <div><dt class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">Název</dt><dd class="mt-1 text-ink">{league.name}</dd></div>
          <div><dt class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">Slug</dt><dd class="mt-1 font-mono text-ink">/{league.slug}</dd></div>
          <div><dt class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">Sport</dt><dd class="mt-1 text-ink">{league.sport}</dd></div>
          <div><dt class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">Owner</dt><dd class="mt-1 font-mono text-[11px] text-graphite">{league.owner_user_id ?? '—'}</dd></div>
          <div><dt class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">Vytvořeno</dt><dd class="mt-1 text-ink">{new Date(league.created_at).toLocaleDateString('cs-CZ')}</dd></div>
          <div><dt class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">Trial do</dt><dd class="mt-1 text-ink">{league.trial_ends_at ? new Date(league.trial_ends_at).toLocaleDateString('cs-CZ') : '—'}</dd></div>
        </dl>
        {league.description && <p class="mt-4 rounded-md bg-mist/40 px-3 py-2 text-[13px] text-graphite">{league.description}</p>}
      </div>

      <!-- Force-add team (cross-sport allowed for super admin) -->
      <div class="rounded-xl border border-plum/30 bg-gradient-to-br from-plum/5 to-signal/5 p-5">
        <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-[#4F3878]">Force-add tým do ligy</p>
        <p class="mt-1 text-[12px] text-graphite">Vybírá z všech non-archivovaných týmů napříč kluby. Bypass invite + auto-approve.</p>
        {availableTeams.length === 0 ? (
          <p class="mt-3 text-[12px] text-slate">Žádné další týmy k přidání.</p>
        ) : (
          <form method="POST" action="/api/super/league/add-team" class="mt-4 flex flex-wrap items-end gap-2">
            <input type="hidden" name="league_id" value={league.id} />
            <label class="block flex-1 min-w-[260px]">
              <span class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">Tým</span>
              <select name="team_id" required class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2 text-[13px] text-ink focus:border-plum focus:outline-none focus:ring-2 focus:ring-plum/20">
                <option value="">— vyberte tým —</option>
                {availableTeams.map((t: any) => (
                  <option value={t.id}>{(t.clubs?.name ?? '?')} · {t.name} <span>({t.sport})</span></option>
                ))}
              </select>
            </label>
            <button type="submit" class="rounded-md bg-plum px-3 py-2 text-[12px] font-semibold text-white hover:bg-[#3F2B68]">Přidat + Schválit</button>
          </form>
        )}
      </div>

      <!-- League teams (approved + pending) -->
      <div class="rounded-xl border border-stone bg-pearl">
        <div class="flex items-center justify-between border-b border-stone px-5 py-4">
          <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Týmy v lize</p>
          <span class="text-[12px] text-slate">{approved.length} schválených · {pending.length} čekajících</span>
        </div>
        {lts.length === 0 ? <div class="p-6 text-center text-[13px] text-slate">Žádné týmy.</div> : (
          <ul class="divide-y divide-stone">
            {lts.map((row: any) => {
              const t = row.teams;
              const c = t?.clubs;
              const isApproved = !!row.approved_at;
              return (
                <li class="flex items-center gap-3 px-5 py-3">
                  <div class="min-w-0 flex-1">
                    <p class="truncate text-[14px] font-semibold text-ink">{t?.name ?? '—'}</p>
                    <p class="truncate text-[11px] text-slate">{c?.name ?? '—'} · {t?.sport ?? '—'}</p>
                  </div>
                  {isApproved ? (
                    <span class="rounded-md bg-verde/15 px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.08em] text-[#1B6E62]">Schválený</span>
                  ) : (
                    <form method="POST" action="/api/super/league/approve-team" class="inline">
                      <input type="hidden" name="league_id" value={league.id} />
                      <input type="hidden" name="team_id" value={row.team_id} />
                      <button type="submit" class="rounded-md bg-verde px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.08em] text-white hover:bg-[#22887C]">Force-approve</button>
                    </form>
                  )}
                </li>
              );
            })}
          </ul>
        )}
      </div>

      <!-- League members -->
      <div class="rounded-xl border border-stone bg-pearl">
        <div class="border-b border-stone px-5 py-4">
          <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Členové ligy</p>
        </div>
        {lms.length === 0 ? <div class="p-6 text-center text-[13px] text-slate">Žádní členové.</div> : (
          <ul class="divide-y divide-stone">
            {lms.map((m) => {
              const p = profileById.get(m.user_id);
              const name = p ? `${p.first_name ?? ''} ${p.last_name ?? ''}`.trim() || p.email : '—';
              return (
                <li class="flex items-center justify-between gap-3 px-5 py-3">
                  <div>
                    <p class="text-[14px] font-semibold text-ink">{name}</p>
                    <p class="text-[11px] text-slate">{p?.email ?? '—'}</p>
                  </div>
                  <span class="rounded-md bg-mist px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.08em] text-graphite">{m.role}</span>
                </li>
              );
            })}
          </ul>
        )}
      </div>
    </div>

    <!-- Side panel: admin actions -->
    <aside class="space-y-4">
      <div class="rounded-xl border border-plum/30 bg-gradient-to-br from-plum/5 to-signal/5 p-5">
        <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-[#4F3878]">Admin akce</p>

        <form method="POST" action="/api/super/league/tier" class="mt-4">
          <input type="hidden" name="league_id" value={league.id} />
          <label class="block text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Tier</label>
          <select name="tier" class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2 text-[13px] text-ink">
            <option value="klub" selected={league.subscription_tier === 'klub'}>Klub</option>
            <option value="liga" selected={league.subscription_tier === 'liga'}>Liga</option>
          </select>
          <button type="submit" class="mt-3 w-full rounded-md bg-plum px-3 py-2 text-[12px] font-semibold text-white hover:bg-[#3F2B68]">Změnit tier</button>
        </form>

        <form method="POST" action="/api/super/league/status" class="mt-5">
          <input type="hidden" name="league_id" value={league.id} />
          <label class="block text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Status</label>
          <select name="status" class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2 text-[13px] text-ink">
            {['trialing','active','past_due','canceled','incomplete'].map((s) => (
              <option value={s} selected={league.subscription_status === s}>{s}</option>
            ))}
          </select>
          <button type="submit" class="mt-3 w-full rounded-md bg-plum px-3 py-2 text-[12px] font-semibold text-white hover:bg-[#3F2B68]">Změnit status</button>
        </form>
      </div>

      <div class="rounded-xl border border-stone bg-pearl p-5">
        <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-slate">IDs</p>
        <dl class="mt-3 space-y-2 text-[11px]">
          <div><dt class="text-stone-2">Liga</dt><dd class="font-mono text-graphite">{league.id}</dd></div>
          <div><dt class="text-stone-2">Stripe customer</dt><dd class="font-mono text-graphite">{league.stripe_customer_id ?? '—'}</dd></div>
          <div><dt class="text-stone-2">Stripe sub</dt><dd class="font-mono text-graphite">{league.stripe_subscription_id ?? '—'}</dd></div>
        </dl>
      </div>
    </aside>
  </div>
</AdminLayout>
