---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../../lib/supabase';
import { isSuperAdmin } from '../../../lib/admin';

export const prerender = false;

const id = Astro.params.id;
if (!id) return Astro.redirect('/admin/users');

const admin = getSupabaseAdmin();

// Auth user (canonical record)
const { data: authData } = await admin.auth.admin.getUserById(id);
const authUser = authData?.user ?? null;
if (!authUser) return Astro.redirect('/admin/users');

// Profile
const { data: profile } = await admin.from('profiles').select('*').eq('id', id).maybeSingle();

// Memberships + all clubs/leagues (for assign dropdowns)
const [{ data: cms }, { data: lms }, { data: allClubsRaw }, { data: allLeaguesRaw }] = await Promise.all([
  admin.from('club_members').select('id, role, created_at, club_id, clubs(name)').eq('user_id', id),
  admin.from('league_members').select('id, role, created_at, league_id, leagues(name)').eq('user_id', id),
  admin.from('clubs').select('id, name').order('name', { ascending: true }),
  admin.from('leagues').select('id, name').order('name', { ascending: true }),
]);
const clubMems = (cms ?? []) as any[];
const leagueMems = (lms ?? []) as any[];
const allClubs = (allClubsRaw ?? []) as Array<{ id: string; name: string }>;
const allLeagues = (allLeaguesRaw ?? []) as Array<{ id: string; name: string }>;

// Iter 32: filter dropdown options to non-members only
const memberClubIds = new Set(clubMems.map((m: any) => m.club_id));
const memberLeagueIds = new Set(leagueMems.map((m: any) => m.league_id));
const availableClubs = allClubs.filter((c) => !memberClubIds.has(c.id));
const availableLeagues = allLeagues.filter((l) => !memberLeagueIds.has(l.id));

const CLUB_ROLES = [
  { value: 'admin',  label: 'Admin',  desc: 'Plný přístup, fakturace, mazání zápasů' },
  { value: 'coach',  label: 'Trenér', desc: 'Editace soupisky, playbook, zápasy' },
  { value: 'stats',  label: 'Statistik', desc: 'Editace zápasů (oprava statistik)' },
  { value: 'viewer', label: 'Pozorovatel', desc: 'Jen prohlížení' },
];
const LEAGUE_ROLES = [
  { value: 'admin',  label: 'Admin',  desc: 'Plný přístup, schvalování týmů, fakturace' },
  { value: 'staff',  label: 'Staff',  desc: 'Editace rekordů a stats, ne fakturace' },
  { value: 'viewer', label: 'Pozorovatel', desc: 'Jen prohlížení' },
];

// Owned clubs (if owner_id matches)
const { data: ownedClubsRaw } = await admin.from('clubs').select('id, name').eq('owner_id', id);
const ownedClubs = (ownedClubsRaw ?? []) as any[];

// Owned leagues
const { data: ownedLeaguesRaw } = await admin.from('leagues').select('id, name').eq('owner_user_id', id);
const ownedLeagues = (ownedLeaguesRaw ?? []) as any[];

const url = new URL(Astro.request.url);
const saved = url.searchParams.get('saved');
const errorMsg = url.searchParams.get('error');

const SAVED_MSG: Record<string, string> = {
  created:  '✓ Uživatel vytvořen.',
  updated:  '✓ Profil aktualizován.',
  password: '✓ Heslo změněno.',
  membership_added:          '✓ Členství v klubu přidáno.',
  membership_updated:        '✓ Role v klubu upravena.',
  membership_removed:        '✓ Členství v klubu odebráno.',
  league_membership_added:   '✓ Členství v lize přidáno.',
  league_membership_updated: '✓ Role v lize upravena.',
  league_membership_removed: '✓ Členství v lize odebráno.',
};

const isAdminUser = isSuperAdmin({ email: profile?.email ?? authUser.email });
const isSelf = id === Astro.locals.user?.id;

const fullName = [profile?.first_name, profile?.last_name].filter(Boolean).join(' ') || profile?.email || authUser.email;
const initials = ((profile?.first_name?.[0] ?? '') + (profile?.last_name?.[0] ?? '')).toUpperCase() || (authUser.email?.[0] ?? '?').toUpperCase();
---

<AdminLayout title={`${fullName} · Admin`} active="users" pageTitle={fullName} pageSub={authUser.email ?? '—'}>

  {saved && SAVED_MSG[saved] && <div class="mb-6 rounded-lg border border-verde/30 bg-verde/5 px-4 py-3 text-[14px] text-[#1B6E62]">{SAVED_MSG[saved]}</div>}
  {errorMsg && <div class="mb-6 rounded-lg border border-signal/30 bg-signal/5 px-4 py-3 text-[14px] text-signal">{errorMsg}</div>}

  <div class="mb-6 flex flex-wrap items-center gap-2 text-[13px]">
    <a href="/admin/users" class="rounded-md border border-stone bg-pearl px-3 py-1.5 font-medium text-graphite hover:bg-mist">← Všichni uživatelé</a>
  </div>

  <div class="grid gap-6 lg:grid-cols-[1fr_320px]">
    <div class="space-y-6">

      <!-- Header card -->
      <div class="rounded-xl border border-stone bg-pearl p-6">
        <div class="flex flex-wrap items-center gap-4">
          <span class={`inline-flex h-14 w-14 items-center justify-center rounded-full text-[16px] font-bold ${isAdminUser ? 'bg-plum text-white' : 'bg-ink/5 text-ink'}`}>{initials}</span>
          <div class="min-w-0 flex-1">
            <p class="text-[20px] font-bold tracking-tight-2 text-ink">{fullName}</p>
            <p class="text-[13px] text-graphite">{authUser.email}</p>
            <div class="mt-2 flex flex-wrap gap-2 text-[10px] font-semibold uppercase tracking-wider">
              {isAdminUser && <span class="rounded-md bg-plum/15 px-2 py-0.5 text-[#4F3878]">Super admin</span>}
              {isSelf && <span class="rounded-md bg-signal/15 px-2 py-0.5 text-signal">Vy</span>}
              {authUser.email_confirmed_at ? (
                <span class="rounded-md bg-verde/15 px-2 py-0.5 text-[#1B6E62]">E-mail ověřen</span>
              ) : (
                <span class="rounded-md bg-spark/15 px-2 py-0.5 text-[#A0531B]">E-mail neověřen</span>
              )}
            </div>
          </div>
        </div>
      </div>

      <!-- Edit profile -->
      <div class="rounded-xl border border-stone bg-pearl p-6">
        <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Profil</p>
        <form method="POST" action="/api/super/user/update" class="mt-4 space-y-4">
          <input type="hidden" name="user_id" value={id} />
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block">
              <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Jméno</span>
              <input type="text" name="first_name" value={profile?.first_name ?? ''} class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[14px]" />
            </label>
            <label class="block">
              <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Příjmení</span>
              <input type="text" name="last_name" value={profile?.last_name ?? ''} class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[14px]" />
            </label>
          </div>
          <label class="block">
            <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">E-mail</span>
            <input type="email" name="email" value={authUser.email ?? ''} class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[14px]" />
            <p class="mt-1 text-[11px] text-slate">Pozor: změna e-mailu se aplikuje na auth.users i profiles. Uživatel se příště loginuje s novým e-mailem.</p>
          </label>
          <button type="submit" class="rounded-md bg-plum px-4 py-2 text-[13px] font-semibold text-white hover:bg-[#3F2B68]">Uložit profil</button>
        </form>
      </div>

      <!-- Reset password -->
      <div class="rounded-xl border border-spark/30 bg-spark/5 p-6">
        <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Reset hesla</p>
        <p class="mt-1 text-[12px] text-graphite">Nastavte uživateli nové heslo a předejte mu ho bezpečným kanálem. Doporuč okamžitou změnu po prvním přihlášení.</p>
        <form method="POST" action="/api/super/user/reset-password" class="mt-4 flex flex-wrap items-end gap-2">
          <input type="hidden" name="user_id" value={id} />
          <label class="block flex-1 min-w-[260px]">
            <span class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">Nové heslo (min 8 znaků)</span>
            <input type="text" name="password" required minlength="8" autocomplete="off" class="mt-1.5 block w-full rounded-md border border-stone bg-pearl px-3 py-2 text-[13px] font-mono" placeholder="new password" />
          </label>
          <button type="submit" class="rounded-md bg-spark px-3 py-2 text-[12px] font-semibold text-white hover:bg-[#D88B47]" onclick="return confirm('Nastavit nové heslo? Uživatel bude muset použít toto nové heslo.')">Změnit heslo</button>
        </form>
      </div>

      <!-- Iter 32: Klubové členství s editací -->
      <div class="rounded-xl border border-stone bg-pearl">
        <div class="border-b border-stone px-5 py-4">
          <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Klubové členství</p>
          <p class="text-[12px] text-slate">{clubMems.length} {clubMems.length === 1 ? 'členství' : 'členství'} · Master admin může přiřadit do dalšího klubu</p>
        </div>

        {clubMems.length === 0 ? (
          <div class="p-6 text-center text-[13px] text-slate">Žádné členství v klubech.</div>
        ) : (
          <ul class="divide-y divide-stone">
            {clubMems.map((m: any) => (
              <li class="flex flex-wrap items-center gap-3 px-5 py-3">
                <a href={`/admin/clubs/${m.club_id}`} class="flex-1 min-w-0 text-[14px] font-semibold text-ink hover:text-plum">{m.clubs?.name ?? '—'}</a>
                <form method="POST" action="/api/super/user/club-membership" class="inline-flex items-center gap-2">
                  <input type="hidden" name="user_id" value={id} />
                  <input type="hidden" name="membership_id" value={m.id} />
                  <input type="hidden" name="action" value="update" />
                  <select name="role" class="rounded-md border border-stone bg-pearl px-2 py-1 text-[12px] text-ink">
                    {CLUB_ROLES.map((r) => (
                      <option value={r.value} selected={m.role === r.value}>{r.label}</option>
                    ))}
                  </select>
                  <button type="submit" class="rounded-md border border-stone bg-pearl px-2.5 py-1 text-[11px] font-medium text-graphite hover:bg-mist">Uložit</button>
                </form>
                <form method="POST" action="/api/super/user/club-membership" class="inline" onsubmit={`return confirm('Odebrat z klubu ${m.clubs?.name ?? ''}?');`}>
                  <input type="hidden" name="user_id" value={id} />
                  <input type="hidden" name="membership_id" value={m.id} />
                  <input type="hidden" name="action" value="remove" />
                  <button type="submit" class="rounded-md border border-stone bg-pearl px-2.5 py-1 text-[11px] font-medium text-graphite hover:border-signal/40 hover:text-signal">×</button>
                </form>
              </li>
            ))}
          </ul>
        )}

        {availableClubs.length > 0 && (
          <div class="border-t border-stone bg-mist/40 px-5 py-4">
            <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">+ Přiřadit do klubu</p>
            <form method="POST" action="/api/super/user/club-membership" class="mt-2 flex flex-wrap items-end gap-2">
              <input type="hidden" name="user_id" value={id} />
              <input type="hidden" name="action" value="add" />
              <label class="block flex-1 min-w-[200px]">
                <span class="text-[11px] text-slate">Klub</span>
                <select name="club_id" required class="mt-1 block w-full rounded-md border border-stone bg-pearl px-3 py-2 text-[13px] text-ink">
                  <option value="">— vyberte klub —</option>
                  {availableClubs.map((c) => (
                    <option value={c.id}>{c.name}</option>
                  ))}
                </select>
              </label>
              <label class="block">
                <span class="text-[11px] text-slate">Role</span>
                <select name="role" required class="mt-1 block rounded-md border border-stone bg-pearl px-3 py-2 text-[13px] text-ink">
                  {CLUB_ROLES.map((r) => (
                    <option value={r.value}>{r.label}</option>
                  ))}
                </select>
              </label>
              <button type="submit" class="rounded-md bg-plum px-3 py-2 text-[12px] font-semibold text-white hover:bg-[#3F2B68]">Přidat</button>
            </form>
            <div class="mt-3 grid gap-x-4 gap-y-1 text-[10px] text-stone-2 sm:grid-cols-2">
              {CLUB_ROLES.map((r) => (
                <div><span class="font-semibold text-graphite">{r.label}:</span> {r.desc}</div>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Iter 32: Liga členství s editací -->
      <div class="rounded-xl border border-stone bg-pearl">
        <div class="border-b border-stone px-5 py-4">
          <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Liga členství</p>
          <p class="text-[12px] text-slate">{leagueMems.length} {leagueMems.length === 1 ? 'členství' : 'členství'} · Master admin může přiřadit do další ligy</p>
        </div>

        {leagueMems.length === 0 ? (
          <div class="p-6 text-center text-[13px] text-slate">Žádné členství v lize.</div>
        ) : (
          <ul class="divide-y divide-stone">
            {leagueMems.map((m: any) => (
              <li class="flex flex-wrap items-center gap-3 px-5 py-3">
                <a href={`/admin/leagues/${m.league_id}`} class="flex-1 min-w-0 text-[14px] font-semibold text-ink hover:text-plum">{m.leagues?.name ?? '—'}</a>
                <form method="POST" action="/api/super/user/league-membership" class="inline-flex items-center gap-2">
                  <input type="hidden" name="user_id" value={id} />
                  <input type="hidden" name="membership_id" value={m.id} />
                  <input type="hidden" name="action" value="update" />
                  <select name="role" class="rounded-md border border-stone bg-pearl px-2 py-1 text-[12px] text-ink">
                    {LEAGUE_ROLES.map((r) => (
                      <option value={r.value} selected={m.role === r.value}>{r.label}</option>
                    ))}
                  </select>
                  <button type="submit" class="rounded-md border border-stone bg-pearl px-2.5 py-1 text-[11px] font-medium text-graphite hover:bg-mist">Uložit</button>
                </form>
                <form method="POST" action="/api/super/user/league-membership" class="inline" onsubmit={`return confirm('Odebrat z ligy ${m.leagues?.name ?? ''}?');`}>
                  <input type="hidden" name="user_id" value={id} />
                  <input type="hidden" name="membership_id" value={m.id} />
                  <input type="hidden" name="action" value="remove" />
                  <button type="submit" class="rounded-md border border-stone bg-pearl px-2.5 py-1 text-[11px] font-medium text-graphite hover:border-signal/40 hover:text-signal">×</button>
                </form>
              </li>
            ))}
          </ul>
        )}

        {availableLeagues.length > 0 && (
          <div class="border-t border-stone bg-mist/40 px-5 py-4">
            <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">+ Přiřadit do ligy</p>
            <form method="POST" action="/api/super/user/league-membership" class="mt-2 flex flex-wrap items-end gap-2">
              <input type="hidden" name="user_id" value={id} />
              <input type="hidden" name="action" value="add" />
              <label class="block flex-1 min-w-[200px]">
                <span class="text-[11px] text-slate">Liga</span>
                <select name="league_id" required class="mt-1 block w-full rounded-md border border-stone bg-pearl px-3 py-2 text-[13px] text-ink">
                  <option value="">— vyberte ligu —</option>
                  {availableLeagues.map((l) => (
                    <option value={l.id}>{l.name}</option>
                  ))}
                </select>
              </label>
              <label class="block">
                <span class="text-[11px] text-slate">Role</span>
                <select name="role" required class="mt-1 block rounded-md border border-stone bg-pearl px-3 py-2 text-[13px] text-ink">
                  {LEAGUE_ROLES.map((r) => (
                    <option value={r.value}>{r.label}</option>
                  ))}
                </select>
              </label>
              <button type="submit" class="rounded-md bg-plum px-3 py-2 text-[12px] font-semibold text-white hover:bg-[#3F2B68]">Přidat</button>
            </form>
            <div class="mt-3 grid gap-x-4 gap-y-1 text-[10px] text-stone-2 sm:grid-cols-2">
              {LEAGUE_ROLES.map((r) => (
                <div><span class="font-semibold text-graphite">{r.label}:</span> {r.desc}</div>
              ))}
            </div>
          </div>
        )}
      </div>

      {(ownedClubs.length > 0 || ownedLeagues.length > 0) && (
        <div class="rounded-xl border border-stone bg-pearl">
          <div class="border-b border-stone px-5 py-4">
            <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Vlastněné entity</p>
            <p class="text-[12px] text-slate">Záznamy, kde je uživatel owner (mazání uživatele tyto entity osiří — pozor)</p>
          </div>
          <ul class="divide-y divide-stone">
            {ownedClubs.map((c: any) => (
              <li class="flex items-center justify-between gap-3 px-5 py-3">
                <a href={`/admin/clubs/${c.id}`} class="text-[14px] font-semibold text-ink hover:text-plum">{c.name}</a>
                <span class="text-[11px] uppercase tracking-wider text-stone-2">Klub</span>
              </li>
            ))}
            {ownedLeagues.map((l: any) => (
              <li class="flex items-center justify-between gap-3 px-5 py-3">
                <a href={`/admin/leagues/${l.id}`} class="text-[14px] font-semibold text-ink hover:text-plum">{l.name}</a>
                <span class="text-[11px] uppercase tracking-wider text-stone-2">Liga</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

    <!-- Side panel -->
    <aside class="space-y-4">
      <div class="rounded-xl border border-stone bg-pearl p-5">
        <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-slate">Auth info</p>
        <dl class="mt-3 space-y-2 text-[11px]">
          <div><dt class="text-stone-2">User ID</dt><dd class="break-all font-mono text-graphite">{authUser.id}</dd></div>
          <div><dt class="text-stone-2">Vytvořen</dt><dd class="text-ink">{authUser.created_at ? new Date(authUser.created_at).toLocaleString('cs-CZ') : '—'}</dd></div>
          <div><dt class="text-stone-2">Poslední přihlášení</dt><dd class="text-ink">{authUser.last_sign_in_at ? new Date(authUser.last_sign_in_at).toLocaleString('cs-CZ') : '—'}</dd></div>
          <div><dt class="text-stone-2">E-mail ověřen</dt><dd class="text-ink">{authUser.email_confirmed_at ? new Date(authUser.email_confirmed_at).toLocaleDateString('cs-CZ') : 'Ne'}</dd></div>
        </dl>
      </div>

      <!-- Danger zone -->
      {!isSelf && !isAdminUser && (
        <div class="rounded-xl border border-signal/30 bg-signal/5 p-5">
          <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-signal">Danger zone</p>
          <p class="mt-2 text-[12px] text-graphite">
            Smazání uživatele zruší auth.users, profile, club_members a league_members. Vlastněné kluby/ligy osiří.
          </p>
          <form method="POST" action="/api/super/user/delete" class="mt-3" onsubmit="return confirm('Opravdu smazat tohoto uživatele? Akce je nevratná. Vlastněné kluby a ligy přejdou na vás (super admina).')">
            <input type="hidden" name="user_id" value={id} />
            <button type="submit" class="w-full rounded-md border border-signal/40 bg-signal/5 px-3 py-2 text-[12px] font-semibold text-signal hover:bg-signal hover:text-white">Smazat uživatele</button>
          </form>
        </div>
      )}
      {isSelf && (
        <div class="rounded-xl border border-stone bg-mist p-5 text-[12px] text-slate">
          Sám sebe nemůžete smazat. Pro odebrání super-admin práv odeberte e-mail ze <code class="rounded bg-pearl px-1 py-0.5 text-[11px]">SUPER_ADMIN_EMAILS</code> env var.
        </div>
      )}
      {!isSelf && isAdminUser && (
        <div class="rounded-xl border border-stone bg-mist p-5 text-[12px] text-slate">
          Super-admin uživatele nelze smazat z UI. Nejdřív odeberte e-mail ze <code class="rounded bg-pearl px-1 py-0.5 text-[11px]">SUPER_ADMIN_EMAILS</code> env var, pak ho můžete smazat.
        </div>
      )}
    </aside>
  </div>
</AdminLayout>
