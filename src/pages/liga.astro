---
import BaseLayout from '../layouts/BaseLayout.astro';

// ─── Mock data ───────────────────────────────────────────────────────

type Club = {
  rank: number;
  name: string;
  city: string;
  abbr: string;
  played: number;
  w: number;
  d: number;
  l: number;
  scored: number;
  conceded: number;
  points: number;
  form: ('V' | 'P' | 'R')[]; // posledních 5
  trend: 'up' | 'down' | 'flat';
};

const clubs: Club[] = [
  { rank: 1, name: 'Praha Lions',     city: 'Praha',         abbr: 'PRA', played: 8, w: 8, d: 0, l: 0, scored: 340, conceded: 142, points: 24, form: ['V','V','V','V','V'], trend: 'up' },
  { rank: 2, name: 'Brno Wolves',     city: 'Brno',          abbr: 'BRN', played: 8, w: 6, d: 0, l: 2, scored: 287, conceded: 198, points: 18, form: ['V','V','P','V','V'], trend: 'up' },
  { rank: 3, name: 'Ostrava Eagles',  city: 'Ostrava',       abbr: 'OST', played: 8, w: 5, d: 1, l: 2, scored: 256, conceded: 220, points: 16, form: ['V','V','R','P','V'], trend: 'flat' },
  { rank: 4, name: 'Plzeň Bears',     city: 'Plzeň',         abbr: 'PLZ', played: 8, w: 4, d: 2, l: 2, scored: 234, conceded: 231, points: 14, form: ['R','V','V','R','P'], trend: 'flat' },
  { rank: 5, name: 'Liberec Sharks',  city: 'Liberec',       abbr: 'LBC', played: 8, w: 3, d: 1, l: 4, scored: 198, conceded: 245, points: 10, form: ['P','V','P','R','V'], trend: 'up' },
  { rank: 6, name: 'Olomouc Hawks',   city: 'Olomouc',       abbr: 'OLO', played: 8, w: 2, d: 1, l: 5, scored: 176, conceded: 268, points: 7,  form: ['P','P','V','R','P'], trend: 'down' },
  { rank: 7, name: 'Hradec Tigers',   city: 'Hradec Králové',abbr: 'HRA', played: 8, w: 1, d: 1, l: 6, scored: 152, conceded: 289, points: 4,  form: ['P','P','R','P','V'], trend: 'down' },
  { rank: 8, name: 'Vary Phoenix',    city: 'Karlovy Vary',  abbr: 'KVA', played: 8, w: 0, d: 0, l: 8, scored: 98,  conceded: 348, points: 0,  form: ['P','P','P','P','P'], trend: 'down' },
];

const teamHighlights = [
  { label: 'Top útok', value: '42.5', unit: 'b / zápas', team: 'Praha Lions', sub: '340 bodů v 8 zápasech', accent: 'signal' },
  { label: 'Top obrana', value: '17.8', unit: 'b / zápas', team: 'Praha Lions', sub: 'Jen 142 obdržených', accent: 'verde' },
  { label: 'Nejdelší série', value: '8', unit: 'výher v řadě', team: 'Praha Lions', sub: 'Od úvodního zápasu', accent: 'spark' },
  { label: 'Rising tým', value: '+4', unit: 'pozice', team: 'Liberec Sharks', sub: 'Posun od poloviny sezóny', accent: 'plum' },
];

const topScorers = [
  { rank: 1, name: 'Tomáš Vacek',    club: 'Praha Lions',     value: 96, unit: 'b' },
  { rank: 2, name: 'Lukáš Macho',    club: 'Brno Wolves',     value: 82, unit: 'b' },
  { rank: 3, name: 'Petr Červenka',  club: 'Ostrava Eagles',  value: 71, unit: 'b' },
  { rank: 4, name: 'Josef Drmla',    club: 'Praha Lions',     value: 64, unit: 'b' },
  { rank: 5, name: 'Nikolas Kopecký',club: 'Plzeň Bears',     value: 58, unit: 'b' },
];

const topAssists = [
  { rank: 1, name: 'Adam Beck',      club: 'Praha Lions',     value: 41, unit: 'asistencí' },
  { rank: 2, name: 'David Krása',    club: 'Brno Wolves',     value: 34, unit: 'asistencí' },
  { rank: 3, name: 'Filip Šťastný',  club: 'Liberec Sharks',  value: 29, unit: 'asistencí' },
  { rank: 4, name: 'Martin Pokorný', club: 'Ostrava Eagles',  value: 26, unit: 'asistencí' },
  { rank: 5, name: 'Jan Novotný',    club: 'Plzeň Bears',     value: 22, unit: 'asistencí' },
];

const topDefenders = [
  { rank: 1, name: 'Patrik Souček',  club: 'Praha Lions',     value: 47, unit: 'zákroků' },
  { rank: 2, name: 'Václav Horák',   club: 'Brno Wolves',     value: 39, unit: 'zákroků' },
  { rank: 3, name: 'Marek Dvořák',   club: 'Ostrava Eagles',  value: 36, unit: 'zákroků' },
  { rank: 4, name: 'Roman Veselý',   club: 'Liberec Sharks',  value: 31, unit: 'zákroků' },
  { rank: 5, name: 'Tomáš Šimek',    club: 'Hradec Tigers',   value: 28, unit: 'zákroků' },
];

const accentMap: Record<string, string> = {
  signal: 'bg-signal/10 text-signal',
  verde:  'bg-verde/15 text-[#1B6E62]',
  spark:  'bg-spark/15 text-[#A0531B]',
  plum:   'bg-plum/15 text-[#4F3878]',
};
---

<BaseLayout
  title="Liga 2026 — Demo ligový hub | GameStatiq"
  description="Ukázka, jak vypadá veřejná stránka ligy nebo svazu na GameStatiq. Tabulka, sezónní statistiky a cross-club leaderboardy napříč kluby."
>
  <!-- Page header -->
  <section class="border-b border-stone bg-ink text-white">
    <div class="container-pm py-14 lg:py-20">
      <div class="flex flex-wrap items-center gap-3">
        <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.12em] text-white/80">
          <span class="h-1.5 w-1.5 rounded-full bg-signal"></span>
          Demo · poháněno GameStatiq
        </span>
        <span class="text-[11px] uppercase tracking-[0.12em] text-white/40">Sezóna 2026</span>
      </div>
      <h1 class="h-display mt-5 text-white">Liga 2026</h1>
      <p class="lead mt-5 max-w-2xl text-white/75">
        Ukázka, jak může vypadat veřejná stránka ligy nebo národního svazu na GameStatiq.
        Master view nad daty napříč všemi kluby — tabulka, sezónní highlighty
        a cross-club leaderboardy v jednom místě.
      </p>
      <div class="mt-7 grid max-w-2xl grid-cols-2 gap-6 border-t border-white/10 pt-6 sm:grid-cols-4">
        <div>
          <p class="text-2xl font-bold tabular-nums tracking-tight-2 text-white">8</p>
          <p class="mt-1 text-[11px] font-medium uppercase tracking-[0.08em] text-white/50">Klubů</p>
        </div>
        <div>
          <p class="text-2xl font-bold tabular-nums tracking-tight-2 text-white">32</p>
          <p class="mt-1 text-[11px] font-medium uppercase tracking-[0.08em] text-white/50">Zápasů</p>
        </div>
        <div>
          <p class="text-2xl font-bold tabular-nums tracking-tight-2 text-white">1 741</p>
          <p class="mt-1 text-[11px] font-medium uppercase tracking-[0.08em] text-white/50">Bodů v sezóně</p>
        </div>
        <div>
          <p class="text-2xl font-bold tabular-nums tracking-tight-2 text-white">192</p>
          <p class="mt-1 text-[11px] font-medium uppercase tracking-[0.08em] text-white/50">Hráčů ve statistikách</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Standings table -->
  <section class="bg-pearl py-16 lg:py-20">
    <div class="container-pm">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="eyebrow">Tabulka</p>
          <h2 class="h-section mt-3">Pořadí klubů</h2>
          <p class="lead mt-3 max-w-xl">
            Live tabulka aktualizovaná po každém odehraném zápase. Žádný Excel,
            žádné ruční přepisování ze sešitu — data tečou ze Scorer appky rovnou sem.
          </p>
        </div>
        <span class="rounded-md border border-stone bg-mist px-3 py-1.5 text-[11px] font-semibold uppercase tracking-[0.12em] text-slate">
          Aktualizováno po posledním zápase
        </span>
      </div>

      <div class="mt-10 overflow-x-auto rounded-xl border border-stone bg-pearl">
        <table class="w-full min-w-[720px] text-left text-[14px]">
          <thead class="border-b border-stone bg-mist text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">
            <tr>
              <th class="px-4 py-3 lg:px-6">#</th>
              <th class="py-3">Klub</th>
              <th class="px-3 py-3 text-center tabular-nums">Z</th>
              <th class="px-3 py-3 text-center tabular-nums">V</th>
              <th class="px-3 py-3 text-center tabular-nums">R</th>
              <th class="px-3 py-3 text-center tabular-nums">P</th>
              <th class="px-3 py-3 text-center tabular-nums">+ / −</th>
              <th class="px-3 py-3 text-center tabular-nums">Skóre</th>
              <th class="px-3 py-3 text-center">Forma</th>
              <th class="px-4 py-3 text-right tabular-nums lg:px-6">Body</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-stone">
            {clubs.map((c) => (
              <tr class={`group transition-colors hover:bg-mist/60 ${c.rank === 1 ? 'bg-signal/[0.03]' : ''}`}>
                <td class="px-4 py-3.5 lg:px-6">
                  <span class={`inline-flex h-6 min-w-[1.5rem] items-center justify-center rounded font-mono text-[12px] font-bold ${c.rank === 1 ? 'bg-signal text-white' : c.rank <= 3 ? 'bg-mist text-ink' : 'text-graphite'}`}>
                    {c.rank}
                  </span>
                </td>
                <td class="py-3.5">
                  <div class="flex items-center gap-3">
                    <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-ink text-[10px] font-bold tracking-[0.04em] text-white">
                      {c.abbr}
                    </span>
                    <div>
                      <p class="text-[15px] font-semibold tracking-tight-2 text-ink">{c.name}</p>
                      <p class="text-[11px] text-slate">{c.city}</p>
                    </div>
                  </div>
                </td>
                <td class="px-3 py-3.5 text-center tabular-nums text-graphite">{c.played}</td>
                <td class="px-3 py-3.5 text-center font-semibold tabular-nums text-verde">{c.w}</td>
                <td class="px-3 py-3.5 text-center tabular-nums text-graphite">{c.d}</td>
                <td class="px-3 py-3.5 text-center tabular-nums text-slate">{c.l}</td>
                <td class="px-3 py-3.5 text-center tabular-nums text-graphite">
                  <span class="text-ink">{c.scored}</span>
                  <span class="text-stone-2"> / </span>
                  <span class="text-slate">{c.conceded}</span>
                </td>
                <td class="px-3 py-3.5 text-center tabular-nums">
                  <span class={c.scored - c.conceded > 0 ? 'font-semibold text-verde' : c.scored - c.conceded < 0 ? 'text-slate' : 'text-graphite'}>
                    {c.scored - c.conceded > 0 ? '+' : ''}{c.scored - c.conceded}
                  </span>
                </td>
                <td class="px-3 py-3.5">
                  <div class="flex items-center justify-center gap-1">
                    {c.form.map((f) => (
                      <span
                        class={`inline-flex h-5 w-5 items-center justify-center rounded text-[10px] font-bold ${
                          f === 'V' ? 'bg-verde/20 text-[#1B6E62]' :
                          f === 'R' ? 'bg-spark/20 text-[#A0531B]' :
                          'bg-stone text-slate'
                        }`}
                      >
                        {f}
                      </span>
                    ))}
                  </div>
                </td>
                <td class="px-4 py-3.5 text-right tabular-nums lg:px-6">
                  <span class="text-[17px] font-bold tracking-tight-2 text-ink">{c.points}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="mt-4 text-[12px] text-slate">
        Z = zápasy, V = výhry, R = remízy, P = prohry. Forma = posledních 5 zápasů (nejnovější vpravo).
      </p>
    </div>
  </section>

  <!-- Team highlights -->
  <section class="border-t border-stone bg-mist py-16 lg:py-20">
    <div class="container-pm">
      <div class="max-w-2xl">
        <p class="eyebrow">Týmové statistiky</p>
        <h2 class="h-section mt-3">Highlighty sezóny.</h2>
        <p class="lead mt-3">
          Agregované metriky napříč ligou — najdou je sami fanoušci i sportovní redakce,
          která vám tím nepřímo dělá PR.
        </p>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {teamHighlights.map((h) => (
          <div class="rounded-xl border border-stone bg-pearl p-6">
            <span class={`inline-flex items-center rounded-md px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.1em] ${accentMap[h.accent]}`}>
              {h.label}
            </span>
            <div class="mt-4 flex items-baseline gap-1.5">
              <span class="text-3xl font-bold tabular-nums tracking-tight-3 text-ink">{h.value}</span>
              <span class="text-[12px] font-medium text-slate">{h.unit}</span>
            </div>
            <p class="mt-4 text-[15px] font-semibold tracking-tight-2 text-ink">{h.team}</p>
            <p class="mt-1 text-[13px] text-graphite">{h.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cross-club leaderboards -->
  <section class="border-t border-stone bg-pearl py-16 lg:py-20">
    <div class="container-pm">
      <div class="max-w-2xl">
        <p class="eyebrow">Cross-club leaderboardy</p>
        <h2 class="h-section mt-3">Hráči, kteří hýbou ligou.</h2>
        <p class="lead mt-3">
          Per-hráč statistiky se sčítají napříč všemi kluby. Hráč si vybuduje jméno
          v lize, ne jen v klubu — a federace má v ruce vyprávění na celou sezónu.
        </p>
      </div>

      <div class="mt-10 grid gap-5 lg:grid-cols-3">
        <!-- Top scorers -->
        <div class="rounded-xl border border-stone bg-pearl">
          <div class="flex items-center justify-between border-b border-stone px-6 py-4">
            <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Top skóreři</p>
            <span class="rounded-md bg-signal/10 px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.1em] text-signal">Body</span>
          </div>
          <ol class="divide-y divide-stone">
            {topScorers.map((p) => (
              <li class="flex items-center gap-4 px-6 py-3.5">
                <span class={`inline-flex h-7 w-7 items-center justify-center rounded-full text-[12px] font-bold tabular-nums ${p.rank === 1 ? 'bg-signal text-white' : 'bg-mist text-graphite'}`}>
                  {p.rank}
                </span>
                <div class="min-w-0 flex-1">
                  <p class="truncate text-[14px] font-semibold text-ink">{p.name}</p>
                  <p class="truncate text-[12px] text-slate">{p.club}</p>
                </div>
                <p class="text-[15px] font-bold tabular-nums tracking-tight-2 text-ink">
                  {p.value}<span class="ml-0.5 text-[11px] font-medium text-slate">{p.unit}</span>
                </p>
              </li>
            ))}
          </ol>
        </div>

        <!-- Top assists -->
        <div class="rounded-xl border border-stone bg-pearl">
          <div class="flex items-center justify-between border-b border-stone px-6 py-4">
            <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Top playmakeři</p>
            <span class="rounded-md bg-sky/15 px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.1em] text-[#1B5E83]">Asistence</span>
          </div>
          <ol class="divide-y divide-stone">
            {topAssists.map((p) => (
              <li class="flex items-center gap-4 px-6 py-3.5">
                <span class={`inline-flex h-7 w-7 items-center justify-center rounded-full text-[12px] font-bold tabular-nums ${p.rank === 1 ? 'bg-sky/30 text-[#1B5E83]' : 'bg-mist text-graphite'}`}>
                  {p.rank}
                </span>
                <div class="min-w-0 flex-1">
                  <p class="truncate text-[14px] font-semibold text-ink">{p.name}</p>
                  <p class="truncate text-[12px] text-slate">{p.club}</p>
                </div>
                <p class="text-[15px] font-bold tabular-nums tracking-tight-2 text-ink">
                  {p.value}
                </p>
              </li>
            ))}
          </ol>
        </div>

        <!-- Top defenders -->
        <div class="rounded-xl border border-stone bg-pearl">
          <div class="flex items-center justify-between border-b border-stone px-6 py-4">
            <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Top obránci</p>
            <span class="rounded-md bg-verde/15 px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.1em] text-[#1B6E62]">Zákroky</span>
          </div>
          <ol class="divide-y divide-stone">
            {topDefenders.map((p) => (
              <li class="flex items-center gap-4 px-6 py-3.5">
                <span class={`inline-flex h-7 w-7 items-center justify-center rounded-full text-[12px] font-bold tabular-nums ${p.rank === 1 ? 'bg-verde/30 text-[#1B6E62]' : 'bg-mist text-graphite'}`}>
                  {p.rank}
                </span>
                <div class="min-w-0 flex-1">
                  <p class="truncate text-[14px] font-semibold text-ink">{p.name}</p>
                  <p class="truncate text-[12px] text-slate">{p.club}</p>
                </div>
                <p class="text-[15px] font-bold tabular-nums tracking-tight-2 text-ink">
                  {p.value}
                </p>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-ink py-16 lg:py-20 text-white">
    <div class="container-pm">
      <div class="rounded-2xl border border-white/10 bg-gradient-to-br from-white/[0.04] to-white/[0.01] p-8 lg:p-12">
        <div class="grid items-center gap-8 lg:grid-cols-[1.4fr_1fr]">
          <div>
            <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-signal">Pro svazy a ligy</p>
            <h2 class="h-section mt-3 text-white">Tohle by mohla být stránka vašeho svazu.</h2>
            <p class="mt-4 max-w-xl text-[17px] leading-relaxed text-white/75">
              Custom doména (např. <span class="text-white">liga.vase-asociace.cz</span>),
              váš logo, vaše barvy. Data tečou ze všech klubů automaticky — nemusíte
              po nikom honit Excely.
            </p>
          </div>
          <div class="flex flex-col gap-3 lg:items-end">
            <a
              href="/#contact"
              class="inline-flex items-center justify-center gap-2 rounded-lg bg-signal px-6 py-3.5 text-[15px] font-semibold text-white transition-all hover:bg-[#C8313D] active:scale-[0.98]"
            >
              Vyžádat demo pro svaz
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <p class="text-[12px] text-white/40 lg:text-right">
              30min hovor · žádný závazek
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
