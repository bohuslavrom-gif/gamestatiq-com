---
// Iter 46: public liga match detail = sjednocený look s /klub/{slug} head-to-head.
// Používá fetchClubMatchHeadToHead z home perspektivy + diverging bars + player tables.
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import { getSupabaseAdmin } from '../../../../../lib/supabase';
import { fetchClubMatchHeadToHead } from '../../../../../lib/club-public';
import { getLangFromUrl, useTranslations, localizedPath } from '../../../../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

export const prerender = false;

const slug = Astro.params.slug;
const matchId = Astro.params.matchId;
if (!slug || !matchId) return Astro.redirect('/');

const admin = getSupabaseAdmin();

const { data: league } = await admin
  .from('leagues')
  .select('id, name, slug, sport, primary_color, secondary_color, logo_url')
  .eq('slug', slug)
  .maybeSingle();
if (!league) return Astro.redirect('/');

// Najdi match a ověř že home_team patří do ligy (allowlist)
const { data: matchRow } = await admin
  .from('matches')
  .select('id, team_id, opp_team_id, teams!matches_team_id_fkey(id, name, primary_color, logo_url, club_id, clubs(name, logo_url))')
  .eq('id', matchId)
  .maybeSingle();
if (!matchRow) return Astro.redirect(localizedPath(`/liga/${slug}?tab=matches`, lang));

// Allowlist: home tým nebo opp tým musí být v lize
const { data: ltRaw } = await admin
  .from('league_teams')
  .select('team_id')
  .eq('league_id', league.id)
  .not('approved_at', 'is', null);
const allowedTeams = new Set(((ltRaw ?? []) as { team_id: string }[]).map((r) => r.team_id));
const m = matchRow as any;
const homeInLeague = allowedTeams.has(m.team_id);
const oppInLeague = m.opp_team_id && allowedTeams.has(m.opp_team_id);
if (!homeInLeague && !oppInLeague) return Astro.redirect(localizedPath(`/liga/${slug}?tab=matches`, lang));

// Perspective: pokud je home v lize → home perspective; jinak opp perspective
const perspectiveTeamId = homeInLeague ? m.team_id : m.opp_team_id;
const homeTeam = m.teams ?? {};
const homeClub = homeTeam.clubs ?? {};

// Pokud zobrazujeme z opp perspektivy, potřebujeme opp tým metadata pro fetchClubMatchHeadToHead
let perspectiveTeamName = '—';
let perspectiveClubName = '—';
let perspectiveLogoUrl: string | null = null;
let perspectivePrimaryColor = '#0F1B2D';
if (homeInLeague) {
  perspectiveTeamName = homeTeam.name ?? '—';
  perspectiveClubName = homeClub.name ?? '—';
  perspectiveLogoUrl = homeTeam.logo_url ?? homeClub.logo_url ?? null;
  perspectivePrimaryColor = homeTeam.primary_color ?? '#0F1B2D';
} else if (m.opp_team_id) {
  const { data: oppRow } = await admin
    .from('teams')
    .select('id, name, primary_color, logo_url, club_id, clubs(name, logo_url)')
    .eq('id', m.opp_team_id)
    .maybeSingle();
  if (oppRow) {
    const o = oppRow as any;
    perspectiveTeamName = o.name ?? '—';
    perspectiveClubName = o.clubs?.name ?? '—';
    perspectiveLogoUrl = o.logo_url ?? o.clubs?.logo_url ?? null;
    perspectivePrimaryColor = o.primary_color ?? '#0F1B2D';
  }
}

const headToHead = await fetchClubMatchHeadToHead(
  matchId,
  perspectiveTeamId,
  perspectiveTeamName,
  perspectiveClubName,
  perspectiveLogoUrl,
  perspectivePrimaryColor,
);
if (!headToHead) return Astro.redirect(localizedPath(`/liga/${slug}?tab=matches`, lang));

const primary = league.primary_color || '#0F1B2D';
const secondary = league.secondary_color || '#E63946';
const accent = perspectivePrimaryColor || secondary;

// Iter 62: pokud opp barva koliduje s naší barvou nebo je default, vyber kontrastní z palety
const BRAND_FALLBACKS = ['#E63946', '#2A9D8F', '#7B5BA6', '#F4A261', '#7AB5D9'];
function hashColor(str: string): string {
  let h = 0;
  for (let i = 0; i < str.length; i++) h = (h * 31 + str.charCodeAt(i)) | 0;
  return BRAND_FALLBACKS[Math.abs(h) % BRAND_FALLBACKS.length];
}
function isDefaultDark(c: string | null | undefined): boolean {
  if (!c) return true;
  const v = c.toLowerCase();
  return v === '#0f1b2d' || v === '#1a1a1a' || v === '#000' || v === '#000000';
}
function resolveOppColor(rawOpp: string, ourColor: string, oppName: string): string {
  if (isDefaultDark(rawOpp) || rawOpp.toLowerCase() === ourColor.toLowerCase()) {
    // Pick from brand palette by team name hash, vyhněte se akcentu
    let c = hashColor(oppName);
    if (c.toLowerCase() === ourColor.toLowerCase()) c = BRAND_FALLBACKS[(BRAND_FALLBACKS.indexOf(c) + 1) % BRAND_FALLBACKS.length];
    return c;
  }
  return rawOpp;
}

const finalOppColor = resolveOppColor(headToHead.oppColor, accent, headToHead.opponent);


const dateLocale = lang === 'cs' ? 'cs-CZ' : lang === 'de' ? 'de-DE' : 'en-US';
const dateStr = new Date(headToHead.date).toLocaleDateString(dateLocale, { day: 'numeric', month: 'long', year: 'numeric' });

function initials(name: string): string {
  return (name ?? '').replace(/[^A-Za-zÀ-ɏ]/g, '').slice(0, 3).toUpperCase() || '—';
}

const sportText = (t as any)(`pliga.sport.${league.sport}`) ?? league.sport;

const resultLabelMap: Record<string, string> = {
  W: t('pmatch.result.W'),
  L: t('pmatch.result.L'),
  T: t('pmatch.result.T'),
};

const pageTitle = `${headToHead.ourClubName} ${headToHead.ourTeamName} vs ${headToHead.opponent} · ${dateStr} · ${league.name}`;
const pageDesc = `${headToHead.ourClubName} ${headToHead.ourTeamName} vs ${headToHead.opponent} (${dateStr}) · ${headToHead.ourScore}–${headToHead.oppScore}`;
---

<BaseLayout title={pageTitle} description={pageDesc}>

  <!-- Liga gradient header (small, breadcrumb only) -->
  <section class="border-b border-stone" style={`background: linear-gradient(135deg, ${primary} 0%, ${secondary} 100%)`}>
    <div class="mx-auto max-w-6xl px-5 py-5 lg:px-8 lg:py-6">
      <div class="flex flex-wrap items-center gap-2 text-[12px] text-white/90">
        <a href={localizedPath(`/liga/${league.slug}`, lang)} class="hover:text-white">← {league.name}</a>
        <span class="text-white/40">/</span>
        <a href={localizedPath(`/liga/${league.slug}?tab=matches`, lang)} class="hover:text-white">{t('pmatch.breadcrumb.matches')}</a>
        <span class="text-white/40">/</span>
        <span class="text-white/65">{dateStr}</span>
      </div>
    </div>
  </section>

  <main class="mx-auto max-w-6xl px-5 py-6 lg:px-8 lg:py-8">

    <!-- ═════════════ SCORE BANNER (same look as /klub/{slug}) ═════════════ -->
    <div class="mb-4 overflow-hidden rounded-xl border border-stone bg-gradient-to-br from-pearl via-mist to-stone/40 text-ink shadow-lg shadow-ink/10">
      <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-4 px-6 py-7 sm:px-8">
        <div class="flex items-center gap-3 sm:gap-4">
          {headToHead.ourLogoUrl ? (
            <img src={headToHead.ourLogoUrl} alt="" class="h-12 w-12 rounded-lg bg-white object-contain p-1 shadow-sm sm:h-16 sm:w-16" />
          ) : (
            <span class="flex h-12 w-12 items-center justify-center rounded-lg bg-ink/10 font-bold text-ink shadow-sm sm:h-16 sm:w-16">{initials(headToHead.ourClubName)}</span>
          )}
          <div class="min-w-0">
            <div class="truncate font-['Bebas_Neue'] text-[24px] leading-none tracking-[0.04em] sm:text-[32px]">{(headToHead.ourTeamName ?? '').toUpperCase()}</div>
          </div>
        </div>
        <div class="flex items-baseline gap-2">
          <span class="font-['Bebas_Neue'] text-[60px] leading-none tabular-nums tracking-tight text-ink sm:text-[88px]" style={headToHead.result === 'W' ? `color:${accent}` : ''}>{headToHead.ourScore}</span>
          <span class="text-[24px] text-slate sm:text-[36px]">:</span>
          <span class="font-['Bebas_Neue'] text-[60px] leading-none tabular-nums tracking-tight text-slate sm:text-[88px]" style={headToHead.result === 'L' ? `color:${finalOppColor}` : ''}>{headToHead.oppScore}</span>
        </div>
        <div class="flex items-center justify-end gap-3 sm:gap-4">
          <div class="min-w-0 text-right">
            <div class="truncate font-['Bebas_Neue'] text-[24px] leading-none tracking-[0.04em] sm:text-[32px]">{(headToHead.opponent ?? '').toUpperCase()}</div>
          </div>
          {headToHead.oppLogoUrl ? (
            <img src={headToHead.oppLogoUrl} alt="" class="h-12 w-12 flex-shrink-0 rounded-lg bg-white object-contain p-1 shadow-sm sm:h-16 sm:w-16" />
          ) : (
            <span class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg font-bold text-white shadow-sm sm:h-16 sm:w-16" style={`background:${finalOppColor === '#1A1A1A' ? '#475569' : finalOppColor}`}>{initials(headToHead.opponent)}</span>
          )}
        </div>
      </div>
      <div class="border-t border-stone/60 bg-mist/40 px-6 py-3 text-center sm:px-8">
        <span class="text-[11px] text-slate">{dateStr}</span>
      </div>
    </div>

    <!-- ═════════════ DIVERGING METRICS ═════════════ -->
    <div class="mt-4 rounded-xl border border-black/10 bg-white px-5 py-5 sm:px-7 sm:py-6">
      <div class="mb-4 flex items-baseline justify-between">
        <h3 class="m-0 font-['Bebas_Neue'] text-[22px] tracking-[0.04em]">Head-to-head</h3>
        <span class="text-[11px] uppercase tracking-[0.06em] text-[#888780]">srovnání týmů</span>
      </div>
      <div class="space-y-3.5">
        {headToHead.metrics.map((mtr) => {
          const total = mtr.format === 'percent' ? 100 : Math.max(1, mtr.our + mtr.opp);
          const ourBar = mtr.format === 'percent' ? Math.min(100, mtr.our) : Math.round((mtr.our / total) * 100);
          const oppBar = mtr.format === 'percent' ? Math.min(100, mtr.opp) : Math.round((mtr.opp / total) * 100);
          const ourBetter = mtr.higherIsBetter === false ? mtr.our < mtr.opp : (mtr.our > mtr.opp && mtr.higherIsBetter !== false);
          const oppBetter = mtr.higherIsBetter === false ? mtr.opp < mtr.our : (mtr.opp > mtr.our && mtr.higherIsBetter !== false);
          const ourShown = mtr.ourDisplay ?? String(mtr.our);
          const oppShown = mtr.oppDisplay ?? String(mtr.opp);
          const ourYardSuffix = mtr.format === 'yards' && !mtr.ourDisplay;
          const oppYardSuffix = mtr.format === 'yards' && !mtr.oppDisplay;
          return (
            <div>
              <div class="grid grid-cols-[110px_1fr_110px] items-center gap-2 sm:grid-cols-[140px_1fr_140px] sm:gap-4">
                <div class={`text-right tabular-nums ${ourBetter ? 'font-bold' : ''}`} style={`color:${accent};opacity:${ourBetter ? 1 : 0.5}`}>
                  <span class="text-[16px] sm:text-[18px]">{ourShown}</span>
                  {ourYardSuffix && <span class="ml-1 text-[10px] opacity-70">yd</span>}
                </div>
                <div class="flex h-6 items-center overflow-hidden rounded-full bg-[#F1EFE8]">
                  <div class="flex h-full w-1/2 justify-end">
                    <div class="h-full transition-all" style={`width:${ourBar}%;background:${accent};opacity:${ourBetter ? 1 : 0.45}`}></div>
                  </div>
                  <div class="flex h-full w-1/2 justify-start">
                    <div class="h-full transition-all" style={`width:${oppBar}%;background:${finalOppColor};opacity:${oppBetter ? 1 : 0.45}`}></div>
                  </div>
                </div>
                <div class={`text-left tabular-nums ${oppBetter ? 'font-bold' : ''}`} style={`color:${finalOppColor};opacity:${oppBetter ? 1 : 0.5}`}>
                  <span class="text-[16px] sm:text-[18px]">{oppShown}</span>
                  {oppYardSuffix && <span class="ml-1 text-[10px] opacity-70">yd</span>}
                </div>
              </div>
              <div class="mt-1 text-center text-[10px] font-semibold uppercase tracking-[0.08em] text-[#888780]">{mtr.label}</div>
            </div>
          );
        })}
      </div>
      <p class="mt-5 text-center text-[10px] text-[#888780]">
        <span class="inline-block h-2 w-2 rounded-full align-middle" style={`background:${accent}`}></span>
        <span class="mx-1.5 align-middle">{headToHead.ourTeamName}</span>
        <span class="text-[#bbb8ad]">·</span>
        <span class="inline-block h-2 w-2 rounded-full align-middle ml-1.5" style={`background:${finalOppColor}`}></span>
        <span class="ml-1.5 align-middle">{headToHead.opponent}</span>
      </p>
    </div>

    <!-- ═════════════ PLAYER TABLES (sortable) ═════════════ -->
    {(headToHead.qbStats.length > 0 || headToHead.wrStats.length > 0 || headToHead.defenseLeaders.length > 0 || headToHead.oppQbStats.length > 0 || headToHead.oppWrStats.length > 0 || headToHead.oppDefenseLeaders.length > 0) && (
      <div class="mt-6 space-y-6">
        {(headToHead.qbStats.length > 0 || headToHead.oppQbStats.length > 0) && (
          <div class="space-y-4">
            <h3 class="text-[12px] font-semibold uppercase tracking-[0.1em] text-slate">{t('pliga.pos.qb')}</h3>
        {headToHead.qbStats.length > 0 && (
          <div class="overflow-hidden rounded-xl border border-stone bg-pearl">
            <div class="flex items-center gap-2.5 border-b border-stone px-5 py-3">
              {perspectiveLogoUrl ? <img src={perspectiveLogoUrl} alt="" loading="lazy" class="h-5 w-5 rounded object-contain" /> : <span class="inline-block h-5 w-5 rounded" style={`background-color:${accent}`}></span>}
              <p class="text-[14px] font-semibold text-ink">{headToHead.ourTeamName} ({headToHead.qbStats.length})</p>
            </div>
            <div class="overflow-x-auto">
              <table class="sortable-table w-full min-w-[640px] text-left text-[13px]" data-accent={accent} data-default-sort="5" data-default-dir="desc">
                <thead class="border-b border-stone bg-mist text-[10px] font-semibold uppercase tracking-[0.08em] text-slate">
                  <tr>
                    <th class="px-5 py-3 w-10">#</th>
                    <th class="py-3" data-sort="text" data-sort-col="1">{t('pliga.players.col.player')}</th>
                    <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="2">ATT</th>
                    <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="3">COMP</th>
                    <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="4">YDS</th>
                    <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="5">TD</th>
                    <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="6">INT</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-stone">
                  {headToHead.qbStats.map((p, i) => (
                    <tr>
                      <td class="px-5 py-2.5 rank-cell"><span class={`inline-flex h-6 w-6 items-center justify-center rounded-full text-[11px] font-bold tabular-nums ${i === 0 ? 'text-white' : 'bg-mist text-graphite'}`} style={i === 0 ? `background-color:${accent}` : ''}>{i + 1}</span></td>
                      <td class="py-2.5" data-sort-value={p.name}>
                        <div class="flex items-center gap-2.5">
                          <div class="relative h-7 w-7 shrink-0">
                            {p.photoUrl
                              ? <img src={p.photoUrl} alt="" loading="lazy" class="h-7 w-7 rounded-full object-cover" />
                              : <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-ink/5 text-[10px] font-semibold text-ink">{p.name.split(' ').map((w: string) => w[0] ?? '').join('').slice(0, 2)}</span>}
                            {perspectiveLogoUrl && (
                              <img src={perspectiveLogoUrl} alt="" loading="lazy" class="absolute -right-1 -bottom-1 h-3.5 w-3.5 rounded-full border border-pearl bg-pearl object-contain" />
                            )}
                          </div>
                          <div><p class="text-[13px] font-semibold text-ink">{p.name}</p><p class="text-[10px] text-slate">#{p.jersey ?? '—'}</p></div>
                        </div>
                      </td>
                      <td class="px-3 py-2.5 text-center tabular-nums text-graphite" data-sort-value={p.att}>{p.att}</td>
                      <td class="px-3 py-2.5 text-center font-semibold tabular-nums text-ink" data-sort-value={p.comp}>{p.comp}</td>
                      <td class="px-3 py-2.5 text-center tabular-nums text-graphite" data-sort-value={p.yds}>{p.yds}</td>
                      <td class="px-3 py-2.5 text-center font-bold tabular-nums text-ink" data-sort-value={p.td}>{p.td}</td>
                      <td class="px-3 py-2.5 text-center tabular-nums text-graphite" data-sort-value={p.int}>{p.int}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}
        {headToHead.oppQbStats.length > 0 && (
          <div class="overflow-hidden rounded-xl border border-stone bg-pearl">
            <div class="flex items-center gap-2.5 border-b border-stone px-5 py-3">
              {headToHead.oppLogoUrl ? <img src={headToHead.oppLogoUrl} alt="" loading="lazy" class="h-5 w-5 rounded object-contain" /> : <span class="inline-block h-5 w-5 rounded" style={`background-color:${finalOppColor}`}></span>}
              <p class="text-[14px] font-semibold text-ink">{headToHead.opponent} ({headToHead.oppQbStats.length})</p>
            </div>
            <div class="overflow-x-auto">
              <table class="sortable-table w-full min-w-[640px] text-left text-[13px]" data-accent={finalOppColor} data-default-sort="5" data-default-dir="desc">
                <thead class="border-b border-stone bg-mist text-[10px] font-semibold uppercase tracking-[0.08em] text-slate">
                  <tr>
                    <th class="px-5 py-3 w-10">#</th>
                    <th class="py-3" data-sort="text" data-sort-col="1">{t('pliga.players.col.player')}</th>
                    <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="2">ATT</th>
                    <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="3">COMP</th>
                    <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="4">YDS</th>
                    <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="5">TD</th>
                    <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="6">INT</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-stone">
                  {headToHead.oppQbStats.map((p, i) => (
                    <tr>
                      <td class="px-5 py-2.5 rank-cell"><span class={`inline-flex h-6 w-6 items-center justify-center rounded-full text-[11px] font-bold tabular-nums ${i === 0 ? 'text-white' : 'bg-mist text-graphite'}`} style={i === 0 ? `background-color:${finalOppColor}` : ''}>{i + 1}</span></td>
                      <td class="py-2.5" data-sort-value={p.name}>
                        <div class="flex items-center gap-2.5">
                          <div class="relative h-7 w-7 shrink-0">
                            {p.photoUrl
                              ? <img src={p.photoUrl} alt="" loading="lazy" class="h-7 w-7 rounded-full object-cover" />
                              : <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-ink/5 text-[10px] font-semibold text-ink">{p.name.split(' ').map((w: string) => w[0] ?? '').join('').slice(0, 2)}</span>}
                            {headToHead.oppLogoUrl && (
                              <img src={headToHead.oppLogoUrl} alt="" loading="lazy" class="absolute -right-1 -bottom-1 h-3.5 w-3.5 rounded-full border border-pearl bg-pearl object-contain" />
                            )}
                          </div>
                          <div><p class="text-[13px] font-semibold text-ink">{p.name}</p><p class="text-[10px] text-slate">#{p.jersey ?? '—'}</p></div>
                        </div>
                      </td>
                      <td class="px-3 py-2.5 text-center tabular-nums text-graphite" data-sort-value={p.att}>{p.att}</td>
                      <td class="px-3 py-2.5 text-center font-semibold tabular-nums text-ink" data-sort-value={p.comp}>{p.comp}</td>
                      <td class="px-3 py-2.5 text-center tabular-nums text-graphite" data-sort-value={p.yds}>{p.yds}</td>
                      <td class="px-3 py-2.5 text-center font-bold tabular-nums text-ink" data-sort-value={p.td}>{p.td}</td>
                      <td class="px-3 py-2.5 text-center tabular-nums text-graphite" data-sort-value={p.int}>{p.int}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}
          </div>
        )}

        {(headToHead.wrStats.length > 0 || headToHead.oppWrStats.length > 0) && (
          <div class="space-y-4">
            <h3 class="text-[12px] font-semibold uppercase tracking-[0.1em] text-slate">{t('pliga.pos.wr')}</h3>
        {headToHead.wrStats.length > 0 && (
          <div class="overflow-hidden rounded-xl border border-stone bg-pearl">
            <div class="flex items-center gap-2.5 border-b border-stone px-5 py-3">
              {perspectiveLogoUrl ? <img src={perspectiveLogoUrl} alt="" loading="lazy" class="h-5 w-5 rounded object-contain" /> : <span class="inline-block h-5 w-5 rounded" style={`background-color:${accent}`}></span>}
              <p class="text-[14px] font-semibold text-ink">{headToHead.ourTeamName} ({headToHead.wrStats.length})</p>
            </div>
            <div class="overflow-x-auto">
              <table class="sortable-table w-full min-w-[640px] text-left text-[13px]" data-accent={accent} data-default-sort="5" data-default-dir="desc">
                <thead class="border-b border-stone bg-mist text-[10px] font-semibold uppercase tracking-[0.08em] text-slate">
                  <tr>
                    <th class="px-5 py-3 w-10">#</th>
                    <th class="py-3" data-sort="text" data-sort-col="1">{t('pliga.players.col.player')}</th>
                    <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="2">TARG</th>
                    <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="3">REC</th>
                    <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="4">YDS</th>
                    <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="5">TD</th>
                    <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="6">PTS</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-stone">
                  {headToHead.wrStats.map((p, i) => (
                    <tr>
