---
import AuthLayout from '../layouts/AuthLayout.astro';

export const prerender = false;

const url = new URL(Astro.request.url);
const error = url.searchParams.get('error');
const info = url.searchParams.get('info');
const next = url.searchParams.get('next') ?? '/app';
---

<AuthLayout title="Přihlášení · GameStatiq">
  <div class="w-full max-w-md">
    <div class="rounded-2xl border border-stone bg-pearl p-8 shadow-[0_20px_50px_-25px_rgba(15,27,45,0.2)]">
      <h1 class="text-[24px] font-bold tracking-tight-2 text-ink">Vítejte zpět</h1>
      <p class="mt-1.5 text-[14px] text-slate">Přihlaste se do svého klubového portálu</p>

      {info && (
        <div class="mt-5 rounded-lg border border-sky/30 bg-sky/5 px-3 py-2.5 text-[13px] text-[#1B5E83]">
          {info}
        </div>
      )}
      {error && (
        <div class="mt-5 rounded-lg border border-signal/30 bg-signal/5 px-3 py-2.5 text-[13px] text-signal">
          {error}
        </div>
      )}

      <form method="POST" action="/api/auth/login" class="mt-6 space-y-4">
        <input type="hidden" name="next" value={next} />
        <label class="block">
          <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">E-mail</span>
          <input type="email" name="email" required autocomplete="email" placeholder="vy@klub.cz" class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[14px] text-ink focus:border-signal focus:outline-none focus:ring-2 focus:ring-signal/20" />
        </label>
        <label class="block">
          <div class="flex items-center justify-between">
            <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Heslo</span>
            <a href="#" class="text-[11px] font-medium text-signal hover:underline">Zapomněli jste?</a>
          </div>
          <input type="password" name="password" required autocomplete="current-password" placeholder="••••••••" class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[14px] text-ink focus:border-signal focus:outline-none focus:ring-2 focus:ring-signal/20" />
        </label>
        <button type="submit" class="block w-full rounded-lg bg-signal px-4 py-2.5 text-[14px] font-semibold text-white transition-colors hover:bg-[#C8313D]">
          Přihlásit se
        </button>
      </form>

      <p class="mt-6 text-center text-[13px] text-graphite">
        Nemáte ještě účet? <a href="/signup" class="font-semibold text-signal hover:underline">Vytvořit účet</a>
      </p>
    </div>

    <p class="mt-6 text-center text-[12px] text-slate">
      Přihlášením souhlasíte s <a href="/podminky" class="hover:text-ink">podmínkami</a> a <a href="/soukromi" class="hover:text-ink">ochranou údajů</a>.
    </p>
  </div>
</AuthLayout>
