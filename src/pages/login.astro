---
import AuthLayout from '../layouts/AuthLayout.astro';
---

<AuthLayout title="Přihlášení · GameStatiq">
  <div class="w-full max-w-md">
    <div class="rounded-2xl border border-stone bg-pearl p-8 shadow-[0_20px_50px_-25px_rgba(15,27,45,0.2)]">
      <h1 class="text-[24px] font-bold tracking-tight-2 text-ink">Vítejte zpět</h1>
      <p class="mt-1.5 text-[14px] text-slate">Přihlaste se do svého klubového portálu</p>

      <!-- OAuth -->
      <div class="mt-6 space-y-2.5">
        <button class="flex w-full items-center justify-center gap-2.5 rounded-lg border border-stone bg-pearl px-4 py-2.5 text-[14px] font-medium text-ink transition-colors hover:bg-mist">
          <svg class="h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09Z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.99.66-2.25 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23Z"/>
            <path fill="#FBBC05" d="M5.84 14.09a6.97 6.97 0 0 1 0-4.18V7.07H2.18a11.02 11.02 0 0 0 0 9.86l3.66-2.84Z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38Z"/>
          </svg>
          Pokračovat přes Google
        </button>
        <button class="flex w-full items-center justify-center gap-2.5 rounded-lg border border-stone bg-pearl px-4 py-2.5 text-[14px] font-medium text-ink transition-colors hover:bg-mist">
          <svg class="h-4 w-4" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
            <path d="M17.5 12.5c0-2.7 2.2-4 2.3-4-1.3-1.8-3.2-2.1-3.9-2.1-1.7-.2-3.3 1-4.1 1-.9 0-2.2-1-3.6-1-1.9 0-3.6 1.1-4.5 2.8-2 3.4-.5 8.5 1.4 11.3.9 1.4 2 2.9 3.5 2.8 1.4 0 1.9-.9 3.6-.9 1.7 0 2.2.9 3.6.9 1.5 0 2.5-1.4 3.4-2.7.7-1 1.3-2.1 1.7-3.4-3.5-1.4-3.4-4.7-3.4-4.7Zm-2.7-8.7c.8-.9 1.3-2.2 1.2-3.4-1.1.1-2.5.7-3.3 1.6-.7.8-1.4 2.1-1.2 3.3 1.2.1 2.5-.6 3.3-1.5Z"/>
          </svg>
          Pokračovat přes Apple
        </button>
      </div>

      <div class="my-6 flex items-center gap-3">
        <span class="h-px flex-1 bg-stone"></span>
        <span class="text-[11px] uppercase tracking-[0.1em] text-slate">nebo e-mailem</span>
        <span class="h-px flex-1 bg-stone"></span>
      </div>

      <form class="space-y-4">
        <label class="block">
          <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">E-mail</span>
          <input
            type="email"
            placeholder="vy@klub.cz"
            class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[14px] text-ink focus:border-signal focus:outline-none focus:ring-2 focus:ring-signal/20"
          />
        </label>
        <label class="block">
          <div class="flex items-center justify-between">
            <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Heslo</span>
            <a href="#" class="text-[11px] font-medium text-signal hover:underline">Zapomněli jste?</a>
          </div>
          <input
            type="password"
            placeholder="••••••••"
            class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[14px] text-ink focus:border-signal focus:outline-none focus:ring-2 focus:ring-signal/20"
          />
        </label>
        <button type="submit" class="block w-full rounded-lg bg-signal px-4 py-2.5 text-[14px] font-semibold text-white transition-colors hover:bg-[#C8313D]">
          Přihlásit se
        </button>
      </form>

      <p class="mt-6 text-center text-[13px] text-graphite">
        Nemáte ještě účet? <a href="/signup" class="font-semibold text-signal hover:underline">Vytvořit účet</a>
      </p>
    </div>

    <p class="mt-6 text-center text-[12px] text-slate">
      Přihlášením souhlasíte s <a href="/podminky" class="hover:text-ink">podmínkami</a> a <a href="/soukromi" class="hover:text-ink">ochranou údajů</a>.
    </p>
  </div>
</AuthLayout>
