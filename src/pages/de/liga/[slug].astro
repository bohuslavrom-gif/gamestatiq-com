---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TeamStatsSection from '../../../components/TeamStatsSection.astro';
import RecordCard from '../../../components/RecordCard.astro';
import { getSupabaseAdmin } from '../../../lib/supabase';
import { getLangFromUrl, useTranslations, localizedPath } from '../../../i18n/utils';
import {
  fetchLeagueStandings,
  fetchLeagueTeamStats,
  fetchLeagueAllPlayers,
  fetchLeagueRecentMatches,
  fetchLeagueMatches,
  fetchLeagueRecords,
  fetchLeagueManualRecords,
  RECORD_CATEGORY_LABELS,
  type TeamStatsRow,
  type ManualRecord,
  type RecordType,
  type LeagueMatchListRow,
} from '../../../lib/league-stats';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

export const prerender = false;

const slug = Astro.params.slug;
if (!slug) return Astro.redirect('/');

const admin = getSupabaseAdmin();

const { data: league } = await admin
  .from('leagues')
  .select('id, name, slug, sport, description, logo_url, primary_color, secondary_color')
  .eq('slug', slug)
  .maybeSingle();
if (!league) return Astro.redirect('/');

const [standings, teamStats, players, recent, allMatches, records, manualRecords] = await Promise.all([
  fetchLeagueStandings(league.id),
  fetchLeagueTeamStats(league.id),
  fetchLeagueAllPlayers(league.id),
  fetchLeagueRecentMatches(league.id, 5),
  fetchLeagueMatches(league.id),
  fetchLeagueRecords(league.id),
  fetchLeagueManualRecords(league.id),
]);

// Build team filter options from matches (dedup by teamId)
const teamFilterMap = new Map<string, { id: string; label: string }>();
for (const m of allMatches) {
  if (!teamFilterMap.has(m.teamId)) {
    teamFilterMap.set(m.teamId, { id: m.teamId, label: `${m.clubName} ${m.teamName}` });
  }
}
const teamFilterOptions = Array.from(teamFilterMap.values()).sort((a, b) => a.label.localeCompare(b.label, 'cs'));

// Split manual records by type
const seasonRecords: ManualRecord[] = manualRecords.filter((r) => r.recordType === 'season');
const careerRecords: ManualRecord[] = manualRecords.filter((r) => r.recordType === 'career');

// Group by category for display
function groupByCategory(list: ManualRecord[]): Map<string, ManualRecord[]> {
  const map = new Map<string, ManualRecord[]>();
  for (const r of list) {
    const arr = map.get(r.category) ?? [];
    arr.push(r);
    map.set(r.category, arr);
  }
  return map;
}
const seasonByCategory = groupByCategory(seasonRecords);
const careerByCategory = groupByCategory(careerRecords);

const totalMatches = standings.reduce((s, r) => s + r.played, 0);
const totalTeams = standings.length;

const sportKey = `pliga.sport.${league.sport}` as const;
const sportText = (t as any)(sportKey) ?? league.sport;

const url = new URL(Astro.request.url);
const tab = url.searchParams.get('tab') ?? 'team';
const playerPos = url.searchParams.get('pos') ?? 'qb';
const recordsSubRaw = url.searchParams.get('sub') ?? 'season';
const recordsSub: RecordType = recordsSubRaw === 'career' ? 'career' : 'season';
const matchesTeamFilter = url.searchParams.get('team') ?? '';
const filteredMatches: LeagueMatchListRow[] = matchesTeamFilter
  ? allMatches.filter((m) => m.teamId === matchesTeamFilter)
  : allMatches;

const primary = league.primary_color || '#0F1B2D';
const secondary = league.secondary_color || '#E63946';

const tabs = [
  { key: 'team',    label: t('pliga.tabs.team') },
  { key: 'players', label: t('pliga.tabs.players') },
  { key: 'matches', label: t('pliga.tabs.matches') },
  { key: 'records', label: t('pliga.tabs.records') },
];

const lastResultColor: Record<string, string> = {
  W: 'bg-verde/15 text-[#1B6E62]',
  L: 'bg-signal/15 text-signal',
  T: 'bg-stone text-slate',
};

const pageTitle = `${league.name} · ${sportText} · GameStatiq`;
const pageDesc = league.description ?? `${league.name} — ${t('pliga.footer.tagline')}`;

// Pre-sorted slices for each section
const scoringOffense = [...teamStats].sort((a, b) => b.pointsForAvg - a.pointsForAvg);
const scoringDefense = [...teamStats].sort((a, b) => a.pointsAgainstAvg - b.pointsAgainstAvg);
const passOffense    = [...teamStats].sort((a, b) => b.passEfficiency - a.passEfficiency);
const passDefense    = [...teamStats].sort((a, b) => a.oppPassYdsAvg - b.oppPassYdsAvg);
const interceptions  = [...teamStats].sort((a, b) => b.defInts - a.defInts);
const sacks          = [...teamStats].sort((a, b) => b.defSacks - a.defSacks);
const penalties      = [...teamStats].sort((a, b) => a.penCount - b.penCount);

const posTabs = [
  { key: 'qb', label: t('pliga.pos.qb'), count: players.qb.length },
  { key: 'wr', label: t('pliga.pos.wr'), count: players.wr.length },
  { key: 'db', label: t('pliga.pos.db'), count: players.db.length },
];

const recordsSubTabs: { key: RecordType; label: string; count: number }[] = [
  { key: 'season', label: t('pliga.records.subtabs.season'), count: seasonRecords.length },
  { key: 'career', label: t('pliga.records.subtabs.career'), count: careerRecords.length },
];
---

<BaseLayout title={pageTitle} description={pageDesc}>

  <!-- Hero -->
  <section class="border-b border-stone" style={`background: linear-gradient(135deg, ${primary} 0%, ${secondary} 100%)`}>
    <div class="mx-auto max-w-7xl px-5 py-10 lg:px-8 lg:py-14">
      <div class="flex flex-wrap items-center gap-6">
        {league.logo_url ? (
          <img src={league.logo_url} alt={league.name} class="h-20 w-20 rounded-2xl bg-white/95 object-contain p-2 shadow-xl" />
        ) : (
          <span class="inline-flex h-20 w-20 items-center justify-center rounded-2xl bg-white/15 text-2xl font-bold text-white backdrop-blur-sm">
            {league.name.replace(/[^A-Za-zÀ-ž]/g, '').slice(0, 3).toUpperCase() || '—'}
          </span>
        )}
        <div class="min-w-0 flex-1">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-white/80">{sportText} {t('pliga.sport.suffix')}</p>
          <h1 class="mt-2 text-[28px] font-bold tracking-tight-2 text-white lg:text-[40px]">{league.name}</h1>
          {league.description && <p class="mt-2 max-w-2xl text-[14px] text-white/85">{league.description}</p>}
        </div>
      </div>

      <div class="mt-6 grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-white/10 p-4 backdrop-blur-sm">
          <p class="text-[10px] font-semibold uppercase tracking-[0.12em] text-white/70">{t('pliga.kpi.teams')}</p>
          <p class="mt-1 text-3xl font-bold tabular-nums text-white">{totalTeams}</p>
        </div>
        <div class="rounded-xl bg-white/10 p-4 backdrop-blur-sm">
          <p class="text-[10px] font-semibold uppercase tracking-[0.12em] text-white/70">{t('pliga.kpi.matches')}</p>
          <p class="mt-1 text-3xl font-bold tabular-nums text-white">{totalMatches}</p>
        </div>
        <div class="rounded-xl bg-white/10 p-4 backdrop-blur-sm">
          <p class="text-[10px] font-semibold uppercase tracking-[0.12em] text-white/70">{t('pliga.kpi.season')}</p>
          <p class="mt-1 text-3xl font-bold tabular-nums text-white">2026</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Main content -->
  <section class="mx-auto max-w-7xl px-5 py-10 lg:px-8 lg:py-12">

    <!-- Top-level tabs -->
    <div class="mb-8 flex flex-wrap gap-1 rounded-lg border border-stone bg-pearl p-1">
      {tabs.map((tabItem) => {
        const isActive = tab === tabItem.key;
        return (
          <a href={`?tab=${tabItem.key}`} class={`rounded-md px-5 py-2.5 text-[14px] font-semibold transition-colors ${isActive ? 'bg-ink text-white' : 'text-graphite hover:bg-mist'}`}>{tabItem.label}</a>
        );
      })}
    </div>

    {totalTeams === 0 && (
      <div class="rounded-xl border border-stone bg-pearl p-12 text-center">
        <p class="text-[15px] font-semibold text-ink">{t('pliga.empty.title')}</p>
        <p class="mt-1 text-[13px] text-slate">{t('pliga.empty.lead')}</p>
      </div>
    )}

    {totalTeams > 0 && tab === 'team' && (
      <div class="space-y-10">

        <!-- Standings (mini at top) -->
        <div>
          <h2 class="mb-4 text-[20px] font-bold tracking-tight-2 text-ink">{t('pliga.standings.title')}</h2>
          <div class="overflow-hidden rounded-xl border border-stone bg-pearl">
            <div class="overflow-x-auto">
              <table class="w-full min-w-[600px] text-left text-[13px]">
                <thead class="border-b border-stone bg-mist text-[10px] font-semibold uppercase tracking-[0.08em] text-slate">
                  <tr>
                    <th class="px-5 py-3 w-12 text-center">#</th>
                    <th class="py-3">{t('pliga.standings.col.team')}</th>
                    <th class="px-3 py-3 text-center tabular-nums">{t('pliga.standings.col.played')}</th>
                    <th class="px-3 py-3 text-center tabular-nums">{t('pliga.standings.col.wlt')}</th>
                    <th class="px-3 py-3 text-center tabular-nums">{t('pliga.standings.col.score')}</th>
                    <th class="px-3 py-3 text-center tabular-nums">{t('pliga.standings.col.winpct')}</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-stone">
                  {standings.map((row, i) => (
                    <tr>
                      <td class="px-5 py-2.5 text-center"><span class={`inline-flex h-6 w-6 items-center justify-center rounded-full text-[11px] font-bold tabular-nums ${i === 0 ? 'text-white' : 'bg-mist text-graphite'}`} style={i === 0 ? `background-color:${secondary}` : ''}>{i + 1}</span></td>
                      <td class="py-2.5"><p class="text-[13px] font-semibold text-ink">{row.teamName}</p><p class="text-[10px] text-slate">{row.clubName}</p></td>
                      <td class="px-3 py-2.5 text-center tabular-nums text-graphite">{row.played}</td>
                      <td class="px-3 py-2.5 text-center tabular-nums text-graphite">{row.wins}-{row.losses}{row.ties ? `-${row.ties}` : ''}</td>
                      <td class="px-3 py-2.5 text-center tabular-nums text-graphite">{row.ptsFor}-{row.ptsAgainst}</td>
                      <td class="px-3 py-2.5 text-center font-bold tabular-nums" style={`color:${secondary}`}>{row.winPct}%</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <TeamStatsSection
          title={t('pliga.section.scoring_off')}
          subtitle={t('pliga.section.scoring_off.sub')}
          accentColor={secondary}
          rows={scoringOffense}
          columns={[
            { key: 'games', label: t('pliga.col.games') },
            { key: 'offTd', label: t('pliga.col.td'), bold: true },
            { key: 'xp1Ok', label: t('pliga.col.xp1') },
            { key: 'xp2Ok', label: t('pliga.col.xp2') },
            { key: 'pointsFor', label: t('pliga.col.points'), bold: true },
            { key: 'pointsForAvg', label: t('pliga.col.points_avg'), accent: true },
          ]}
        />

        <TeamStatsSection
          title={t('pliga.section.scoring_def')}
          subtitle={t('pliga.section.scoring_def.sub')}
          accentColor={secondary}
          rows={scoringDefense}
          columns={[
            { key: 'games', label: t('pliga.col.games') },
            { key: 'pointsAgainst', label: t('pliga.col.pts_against'), bold: true },
            { key: 'pointsAgainstAvg', label: t('pliga.col.pts_against_avg'), accent: true },
          ]}
        />

        <TeamStatsSection
          title={t('pliga.section.pass_off')}
          subtitle={t('pliga.section.pass_off.sub')}
          accentColor={secondary}
          rows={passOffense}
          columns={[
            { key: 'games', label: t('pliga.col.games') },
            { key: 'qbComp', label: t('pliga.col.comp') },
            { key: 'qbAtt', label: t('pliga.col.att') },
            { key: 'qbInt', label: t('pliga.col.int_thrown') },
            { key: 'qbYds', label: t('pliga.col.yds') },
            { key: 'qbTd', label: t('pliga.col.td'), bold: true },
            { key: 'passEfficiency', label: t('pliga.col.eff'), accent: true },
          ]}
        />

        <TeamStatsSection
          title={t('pliga.section.pass_def')}
          subtitle={t('pliga.section.pass_def.sub')}
          accentColor={secondary}
          rows={passDefense}
          columns={[
            { key: 'games', label: t('pliga.col.games') },
            { key: 'oppPassYds', label: t('pliga.col.yds_against'), bold: true },
            { key: 'oppPassYdsAvg', label: t('pliga.col.yds_against_avg'), accent: true },
            { key: 'defInts', label: t('pliga.col.int_caught') },
            { key: 'defSacks', label: t('pliga.col.sacks') },
          ]}
        />

        <TeamStatsSection
          title={t('pliga.section.interceptions')}
          subtitle={t('pliga.section.interceptions.sub')}
          accentColor={secondary}
          rows={interceptions}
          columns={[
            { key: 'games', label: t('pliga.col.games') },
            { key: 'defInts', label: t('pliga.col.int_caught'), bold: true, accent: true },
          ]}
        />

        <TeamStatsSection
          title={t('pliga.section.sacks')}
          subtitle={t('pliga.section.sacks.sub')}
          accentColor={secondary}
          rows={sacks}
          columns={[
            { key: 'games', label: t('pliga.col.games') },
            { key: 'defSacks', label: t('pliga.col.sacks'), bold: true, accent: true },
          ]}
        />

        <TeamStatsSection
          title={t('pliga.section.penalties')}
          subtitle={t('pliga.section.penalties.sub')}
          accentColor={secondary}
          rows={penalties}
          columns={[
            { key: 'games', label: t('pliga.col.games') },
            { key: 'penCount', label: t('pliga.col.fouls'), bold: true, accent: true },
            { key: 'penYds', label: t('pliga.col.fouls_yds') },
          ]}
        />

      </div>
    )}

    {totalTeams > 0 && tab === 'players' && (
      <div>
        <div class="mb-6 flex flex-wrap gap-1 rounded-lg border border-stone bg-pearl p-1">
          {posTabs.map((posItem) => {
            const isActive = playerPos === posItem.key;
            return (
              <a href={`?tab=players&pos=${posItem.key}`} class={`rounded-md px-4 py-2 text-[13px] font-medium transition-colors ${isActive ? 'bg-ink text-white' : 'text-graphite hover:bg-mist'}`}>
                {posItem.label}<span class="ml-1 text-[10px] opacity-70">({posItem.count})</span>
              </a>
            );
          })}
        </div>

        {playerPos === 'qb' && (
          <div class="overflow-hidden rounded-xl border border-stone bg-pearl">
            <div class="border-b border-stone px-5 py-4">
              <p class="text-[15px] font-semibold text-ink">{t('pliga.players.qb.title')}</p>
              <p class="text-[12px] text-slate">{players.qb.length} {t('pliga.players.count.plural')} · {t('pliga.players.qb.sub')}</p>
            </div>
            {players.qb.length === 0 ? (
              <div class="p-12 text-center text-[13px] text-slate">{t('pliga.players.empty.qb')}</div>
            ) : (
              <div class="overflow-x-auto">
                <table class="sortable-table w-full min-w-[800px] text-left text-[13px]" data-accent={secondary} data-default-sort="7" data-default-dir="desc">
                  <thead class="border-b border-stone bg-mist text-[10px] font-semibold uppercase tracking-[0.08em] text-slate">
                    <tr>
                      <th class="px-5 py-3 w-10">#</th>
                      <th class="py-3" data-sort="text" data-sort-col="1">{t('pliga.players.col.player')}</th>
                      <th class="py-3" data-sort="text" data-sort-col="2">{t('pliga.players.col.team')}</th>
                      <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="3">ATT</th>
                      <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="4">COMP</th>
                      <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="5">%</th>
                      <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="6">YDS</th>
                      <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="7">TD</th>
                      <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="8">INT</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-stone">
                    {players.qb.map((p, i) => {
                      const pct = p.qbAtt > 0 ? Math.round((p.qbComp / p.qbAtt) * 100) : 0;
                      return (
                        <tr>
                          <td class="px-5 py-2.5 rank-cell"><span class={`inline-flex h-6 w-6 items-center justify-center rounded-full text-[11px] font-bold tabular-nums ${i === 0 ? 'text-white' : 'bg-mist text-graphite'}`} style={i === 0 ? `background-color:${secondary}` : ''}>{i + 1}</span></td>
                          <td class="py-2.5" data-sort-value={p.name}><div class="flex items-center gap-2.5">{p.photoUrl ? <img src={p.photoUrl} alt="" loading="lazy" class="h-7 w-7 rounded-full object-cover" /> : <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-ink/5 text-[10px] font-semibold text-ink">{p.name.split(' ').map((w: string) => w[0] ?? '').join('').slice(0, 2)}</span>}<div><p class="text-[13px] font-semibold text-ink">{p.name}</p><p class="text-[10px] text-slate">#{p.jersey ?? '—'}</p></div></div></td>
                          <td class="py-2.5 text-[12px] text-graphite" data-sort-value={`${p.clubName} ${p.teamName}`}>{p.clubName}<br/><span class="text-[10px] text-stone-2">{p.teamName}</span></td>
                          <td class="px-3 py-2.5 text-center tabular-nums text-graphite" data-sort-value={p.qbAtt}>{p.qbAtt}</td>
                          <td class="px-3 py-2.5 text-center font-semibold tabular-nums text-ink" data-sort-value={p.qbComp}>{p.qbComp}</td>
                          <td class="px-3 py-2.5 text-center tabular-nums" style={`color:${secondary}`} data-sort-value={pct}>{pct}%</td>
                          <td class="px-3 py-2.5 text-center tabular-nums text-graphite" data-sort-value={p.qbYds}>{p.qbYds}</td>
                          <td class="px-3 py-2.5 text-center font-bold tabular-nums text-ink" data-sort-value={p.qbTd}>{p.qbTd}</td>
                          <td class="px-3 py-2.5 text-center tabular-nums text-graphite" data-sort-value={p.qbInt}>{p.qbInt}</td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        )}

        {playerPos === 'wr' && (
          <div class="overflow-hidden rounded-xl border border-stone bg-pearl">
            <div class="border-b border-stone px-5 py-4">
              <p class="text-[15px] font-semibold text-ink">{t('pliga.players.wr.title')}</p>
              <p class="text-[12px] text-slate">{players.wr.length} {t('pliga.players.count.plural')} · {t('pliga.players.wr.sub')}</p>
            </div>
            {players.wr.length === 0 ? (
              <div class="p-12 text-center text-[13px] text-slate">{t('pliga.players.empty.wr')}</div>
            ) : (
              <div class="overflow-x-auto">
                <table class="sortable-table w-full min-w-[820px] text-left text-[13px]" data-accent={secondary} data-default-sort="7" data-default-dir="desc">
                  <thead class="border-b border-stone bg-mist text-[10px] font-semibold uppercase tracking-[0.08em] text-slate">
                    <tr>
                      <th class="px-5 py-3 w-10">#</th>
                      <th class="py-3" data-sort="text" data-sort-col="1">{t('pliga.players.col.player')}</th>
                      <th class="py-3" data-sort="text" data-sort-col="2">{t('pliga.players.col.team')}</th>
                      <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="3">TARG</th>
                      <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="4">REC</th>
                      <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="5">%</th>
                      <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="6">YDS</th>
                      <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="7">TD</th>
                      <th class="px-3 py-3 text-center tabular-nums" data-sort="numeric" data-sort-col="8">PTS</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-stone">
                    {players.wr.map((p, i) => {
                      const pct = p.wrTargets > 0 ? Math.round((p.wrRec / p.wrTargets) * 100) : 0;
                      return (
                        <tr>
                          <td class="px-5 py-2.5 rank-cell"><span class={`inline-flex h-6 w-6 items-center justify-center rounded-full text-[11px] font-bold tabular-nums ${i === 0 ? 'text-white' : 'bg-mist text-graphite'}`} style={i === 0 ? `background-color:${secondary}` : ''}>{i + 1}</span></td>
                          <td class="py-2.5" data-sort-value={p.name}><div class="flex items-center gap-2.5">{p.photoUrl ? <img src={p.photoUrl} alt="" loading="lazy" class="h-7 w-7 rounded-full object-cover" /> : <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-ink/5 text-[10px] font-semibold text-ink">{p.name.split(' ').map((w: string) => w[0] ?? '').join('').slice(0, 2)}</span>}<div><p class="text-[13px] font-semibold text-ink">{p.name}</p><p class="text-[10px] text-slate">#{p.jersey ?? '—'}</p></div></div></td>
                          <td class="py-2.5 text-[12px] text-graphite" data-sort-value={`${p.clubName} ${p.teamName}`}>{p.clubName}<br/><span class="text-[10px] text-stone-2">{p.teamName}</span></td>
                          <td class="px-3 py-2.5 text-center tabular-nums text-graphite" data-sort-value={p.wrTargets}>{p.wrTargets}</td>
                          <td class="px-3 py-2.5 text-center font-semibold tabular-nums text-ink" data-sort-value={p.wrRec}>{p.wrRec}</td>
                          <td class="px-3 py-2.5 text-center tabular-nums" style={`color:${secondary}`} data-sort-value={pct}>{pct}%</td>
                          <td class="px-3 py-2.5 text-center tabular-nums text-graphite" data-sort-value={p.wrYds}>{p.wrYds}</td>
                          <td class="px-3 py-2.5 text-center font-bold tabular-nums text-ink" data-sort-value={p.wrTd}>{p.wrTd}</td>
