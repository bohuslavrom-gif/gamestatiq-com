---
import AppLayout from '../../layouts/AppLayout.astro';
import ScorerInstall from '../../components/ScorerInstall.astro';
import { fetchPlayerEnrichmentByName, enrich } from '../../lib/players';
import { getSupabaseAdmin } from '../../lib/supabase';
import { fetchSupabaseStats } from '../../lib/supabase-stats';

export const prerender = false;

const currentTeam = Astro.locals.team ?? null;
const currentTeamId = currentTeam?.id ?? null;

// Resolve club info (for header) — defensive
let clubName = '—';
let clubSlug: string | null = null;
let isClubAdmin = false;
if (currentTeam?.club_id) {
  const admin = getSupabaseAdmin();
  const { data: c } = await admin
    .from('clubs')
    .select('name, slug')
    .eq('id', currentTeam.club_id)
    .maybeSingle();
  clubName = (c as { name: string; slug: string } | null)?.name ?? '—';
  clubSlug = (c as { name: string; slug: string } | null)?.slug ?? null;
  // Iter 5b: detect club admin (for league invitation approvals)
  const { data: cm } = await admin
    .from('club_members')
    .select('role')
    .eq('user_id', Astro.locals.user!.id)
    .eq('club_id', currentTeam.club_id)
    .maybeSingle();
  isClubAdmin = (cm as { role: string } | null)?.role === 'admin';
}

// Iter 5b: pending league invitations for ANY team in this club (club admin sees them all)
type PendingLeagueInvite = {
  league_id: string;
  team_id: string;
  invited_at: string;
  teams: { name: string };
  leagues: { name: string; sport: string };
};
let pendingLeagueInvites: PendingLeagueInvite[] = [];
if (isClubAdmin && currentTeam?.club_id) {
  // Fetch all teams in this club, then look for pending league_teams rows referring to any of them
  const { data: clubTeams } = await getSupabaseAdmin()
    .from('teams').select('id').eq('club_id', currentTeam.club_id);
  const teamIds = ((clubTeams ?? []) as { id: string }[]).map((t) => t.id);
  if (teamIds.length) {
    const { data: invites } = await getSupabaseAdmin()
      .from('league_teams')
      .select('league_id, team_id, invited_at, teams(name), leagues(name, sport)')
      .in('team_id', teamIds)
      .is('approved_at', null)
      .order('invited_at', { ascending: false });
    pendingLeagueInvites = (invites ?? []) as unknown as PendingLeagueInvite[];
  }
}

// Iter 16: GAS sunset — all stats from Supabase
const [supabaseStats, enrichmentMap] = await Promise.all([
  fetchSupabaseStats(currentTeamId),
  fetchPlayerEnrichmentByName(currentTeamId),
]);

function photoOf(name: string, fallback?: string): string | undefined {
  const e = enrich(enrichmentMap, name);
  if (e?.photoUrl) return e.photoUrl;
  return fallback;
}

// Compute season record + points from Supabase matches
let wins = 0, losses = 0, ties = 0, ptsFor = 0, ptsAgainst = 0;
for (const m of supabaseStats.matches) {
  ptsFor += m.ourScore ?? 0;
  ptsAgainst += m.oppScore ?? 0;
  if (m.result === 'W') wins++;
  else if (m.result === 'L') losses++;
  else if (m.result === 'T') ties++;
}
const matches = supabaseStats.matches.length;
const forAvg = matches > 0 ? +(ptsFor / matches).toFixed(1) : 0;
const againstAvg = matches > 0 ? +(ptsAgainst / matches).toFixed(1) : 0;
const winsLosses = matches > 0 ? `${wins}-${losses}${ties ? '-' + ties : ''}` : '—';
const hasStats = matches > 0;

const totalRoster = new Set([
  ...supabaseStats.qbStats.map((p) => p.name),
  ...supabaseStats.wrStats.map((p) => p.name),
  ...supabaseStats.defenseLeaders.map((p) => p.name),
]).size;

const kpis = [
  { label: 'Bilance', value: winsLosses, unit: 'V-P', accent: 'verde' },
  { label: 'Bodů skórovaných', value: hasStats ? String(ptsFor) : '—', unit: hasStats ? `${forAvg.toFixed(1)} / zápas` : '', accent: 'signal' },
  { label: 'Bodů obdržených', value: hasStats ? String(ptsAgainst) : '—', unit: hasStats ? `${againstAvg.toFixed(1)} / zápas` : '', accent: 'sky' },
  { label: 'Hráčů ve statistikách', value: String(totalRoster), unit: `sezóna 2026`, accent: 'plum' },
];

const recentGames = supabaseStats.matches.slice(0, 5);

const accentMap: Record<string, string> = {
  signal: 'text-signal',
  verde:  'text-verde',
  sky:    'text-[#1B5E83]',
  spark:  'text-[#A0531B]',
  plum:   'text-[#4F3878]',
};

// Best QB and WR for "coach insight" highlight (Iter 16: from Supabase)
const topQb = supabaseStats.qbStats[0];
const topWr = supabaseStats.wrStats[0];
---

<AppLayout
  title="Dashboard · GameStatiq"
  active="dashboard"
  pageTitle={currentTeam ? `${clubName} · ${currentTeam.name}` : 'Dashboard'}
  pageSub={currentTeam ? `Sezóna ${currentTeam.season ?? '2026'} · ${matches} ${matches === 1 ? 'odehraný zápas' : matches < 5 ? 'odehrané zápasy' : 'odehraných zápasů'}` : 'Načítám klubová data…'}
>
  {/* Iter 16: GAS sunset — error banner odebrán. */}

  {/* Iter 5b: pending league invitations awaiting club admin approval */}
  {pendingLeagueInvites.length > 0 && (
    <div class="mb-6 rounded-xl border border-plum/30 bg-gradient-to-br from-plum/5 to-signal/5 p-5">
      <div class="flex items-start gap-3">
        <span class="inline-flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-plum/15 text-[#4F3878]">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z"/></svg>
        </span>
        <div class="min-w-0 flex-1">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#4F3878]">Pozvánka do ligy</p>
          <p class="mt-1 text-[15px] font-bold text-ink">
            {pendingLeagueInvites.length === 1
              ? `1 nová pozvánka čeká na schválení`
              : `${pendingLeagueInvites.length} pozvánek čeká na schválení`}
          </p>
          <ul class="mt-3 space-y-2">
            {pendingLeagueInvites.map((inv) => (
              <li class="flex flex-wrap items-center gap-3 rounded-lg border border-stone bg-pearl p-3">
                <div class="min-w-0 flex-1">
                  <p class="text-[13px] font-semibold text-ink">
                    Liga <strong>{inv.leagues.name}</strong> chce přidat váš tým <strong>{inv.teams.name}</strong>.
                  </p>
                  <p class="text-[11px] text-slate">Pozváno {new Date(inv.invited_at).toLocaleDateString('cs-CZ')}</p>
                </div>
                <form method="POST" action="/api/league/team/approve" class="inline">
                  <input type="hidden" name="league_id" value={inv.league_id} />
                  <input type="hidden" name="team_id" value={inv.team_id} />
                  <button type="submit" class="rounded-md bg-verde px-3 py-1.5 text-[12px] font-semibold text-white hover:bg-[#22887C]">Schválit</button>
                </form>
                <form method="POST" action="/api/league/team/remove" class="inline">
                  <input type="hidden" name="league_id" value={inv.league_id} />
                  <input type="hidden" name="team_id" value={inv.team_id} />
                  <input type="hidden" name="source" value="club" />
                  <button type="submit" class="rounded-md border border-stone bg-pearl px-3 py-1.5 text-[12px] font-medium text-graphite hover:bg-mist">Odmítnout</button>
                </form>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  )}

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {kpis.map((k) => (
      <div class="rounded-xl border border-stone bg-pearl p-5">
        <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-slate">{k.label}</p>
        <p class={`mt-3 text-3xl font-bold tabular-nums tracking-tight-3 ${accentMap[k.accent]}`}>{k.value}</p>
        <p class="mt-1 text-[12px] text-graphite">{k.unit}</p>
      </div>
    ))}
  </div>

  <div class="mt-6 flex flex-col items-start justify-between gap-4 rounded-xl border border-stone bg-pearl p-5 lg:flex-row lg:items-center">
    <div class="flex items-center gap-4">
      <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-verde/10 text-verde">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
      </span>
      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-slate">Live data</p>
        <p class="text-[17px] font-bold tracking-tight-2 text-ink">Supabase · {clubName} {currentTeam?.name ?? ''}</p>
        <p class="text-[12px] text-graphite">Aktualizace po každém uložení ze Scorer PWA</p>
      </div>
    </div>
    <div class="flex gap-2">
      {clubSlug && (
        <a href={`/klub/${clubSlug}${currentTeam?.name ? `?team=${encodeURIComponent(currentTeam.name)}` : ''}`} target="_blank" rel="noopener" class="rounded-lg border border-stone bg-mist px-4 py-2 text-[13px] font-medium text-graphite hover:border-stone-2 hover:bg-stone/30">Veřejná stránka</a>
      )}
      <a href="/app/billing" class="rounded-lg bg-ink px-4 py-2 text-[13px] font-medium text-white hover:bg-[#1A2B45]">Upgrade na Klub</a>
    </div>
  </div>

  <!-- Iter 30: Stáhnout Scorer app -->
  <div class="mt-6">
    <ScorerInstall />
  </div>

  <div class="mt-6 grid gap-5 lg:grid-cols-[1.3fr_1fr]">
    <div class="rounded-xl border border-stone bg-pearl">
      <div class="flex items-center justify-between border-b border-stone px-5 py-4">
        <div>
          <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Poslední zápasy</p>
          <p class="text-[12px] text-slate">Top {recentGames.length} podle data</p>
        </div>
        <a href="/app/stats" class="text-[12px] font-semibold text-signal hover:underline">Všechny stats →</a>
      </div>
      {recentGames.length === 0 ? (
        <div class="p-8 text-center text-[13px] text-slate">Žádné odehrané zápasy.</div>
      ) : (
        <ul class="divide-y divide-stone">
          {recentGames.map((g) => (
            <li class="flex items-center gap-4 px-5 py-3.5">
              <span class={`inline-flex h-9 w-9 items-center justify-center rounded-lg text-[12px] font-bold ${
                g.result === 'W' ? 'bg-verde/15 text-[#1B6E62]' :
                g.result === 'L' ? 'bg-signal/15 text-signal' :
                'bg-stone text-slate'
              }`}>{g.result === 'W' ? 'V' : g.result === 'L' ? 'P' : 'R'}</span>
              <div class="min-w-0 flex-1">
                <p class="text-[14px] font-semibold text-ink">{g.opponent}</p>
                <p class="text-[11px] text-slate">{g.date}</p>
              </div>
              <p class="text-[15px] font-bold tabular-nums tracking-tight-2 text-ink">{g.ourScore} : {g.oppScore}</p>
            </li>
          ))}
        </ul>
      )}
    </div>

    <div class="rounded-xl border border-stone bg-pearl">
      <div class="flex items-center justify-between border-b border-stone px-5 py-4">
        <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Top hráči</p>
        <span class="rounded-md bg-mist px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.1em] text-slate">živě</span>
      </div>
      <ul class="divide-y divide-stone">
        {topQb && (
          <li class="px-5 py-4">
            <p class="text-[10px] font-semibold uppercase tracking-[0.08em] text-signal">Top quarterback</p>
            <p class="mt-1 text-[14px] font-semibold text-ink">{topQb.name} · #{topQb.jersey}</p>
            <p class="text-[12px] text-slate">{topQb.qb.td} TD · {topQb.qb.comp}/{topQb.qb.att} cmp ({Math.round((topQb.qb.comp / Math.max(topQb.qb.att, 1)) * 100)}%)</p>
          </li>
        )}
        {topWr && (
          <li class="px-5 py-4">
            <p class="text-[10px] font-semibold uppercase tracking-[0.08em] text-sky">Top wide receiver</p>
            <p class="mt-1 text-[14px] font-semibold text-ink">{topWr.name} · #{topWr.jersey}</p>
            <p class="text-[12px] text-slate">{topWr.wr.td} TD · {topWr.wr.rec}/{topWr.wr.targets} cmp · {topWr.wr.pts} bodů</p>
          </li>
        )}
        {!topQb && !topWr && (
          <li class="px-5 py-8 text-center text-[13px] text-slate">Zatím žádná data o hráčích.</li>
        )}
      </ul>
      <div class="border-t border-stone px-5 py-3">
        <a href="/app/players" class="text-[12px] font-semibold text-signal hover:underline">Celá soupiska →</a>
      </div>
    </div>
  </div>

  {hasStats && (
    <div class="mt-6 rounded-xl border border-stone bg-gradient-to-br from-ink to-[#1A2B45] p-6 text-white lg:p-8">
      <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-signal">Coach insight · sezóna</p>
      <h2 class="mt-2 text-[22px] font-bold tracking-tight-2">
        Skórujete <span class="text-signal">{forAvg.toFixed(1)}</span> bodů na zápas — inkasujete jen <span class="text-signal">{againstAvg.toFixed(1)}</span>
      </h2>
      <p class="mt-3 max-w-2xl text-[14px] leading-relaxed text-white/75">
        Rozdíl <strong class="text-white">{(forAvg - againstAvg).toFixed(1)}</strong> bodů na zápas vás řadí mezi top týmy ligy. Útok produkuje stabilně, obrana drží zadní vrátka.
      </p>
      <div class="mt-6 grid gap-4 border-t border-white/10 pt-5 sm:grid-cols-4">
        <div>
          <p class="text-[10px] uppercase tracking-[0.08em] text-white/50">Zápasů</p>
          <p class="text-2xl font-bold tabular-nums tracking-tight-2">{matches}</p>
        </div>
        <div>
          <p class="text-[10px] uppercase tracking-[0.08em] text-white/50">Výher</p>
          <p class="text-2xl font-bold tabular-nums tracking-tight-2">{wins}</p>
        </div>
        <div>
          <p class="text-[10px] uppercase tracking-[0.08em] text-white/50">Bodů celkem</p>
          <p class="text-2xl font-bold tabular-nums tracking-tight-2">{ptsFor}</p>
        </div>
        <div>
          <p class="text-[10px] uppercase tracking-[0.08em] text-white/50">Obdržených</p>
          <p class="text-2xl font-bold tabular-nums tracking-tight-2">{ptsAgainst}</p>
        </div>
      </div>
    </div>
  )}
</AppLayout>
