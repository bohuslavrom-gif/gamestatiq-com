---
import AppLayout from '../../../layouts/AppLayout.astro';
import { fetchLeagueLeaders } from '../../../lib/league-stats';

export const prerender = false;

const league = Astro.locals.league ?? null;
if (!league) return Astro.redirect('/app');

const { qb, wr, db } = await fetchLeagueLeaders(league.id);

const url = new URL(Astro.request.url);
const tab = url.searchParams.get('pos') ?? 'qb';
const tabs = [
  { key: 'qb', label: 'Quarterback', count: qb.length },
  { key: 'wr', label: 'Wide receiver', count: wr.length },
  { key: 'db', label: 'Obrana / DB',  count: db.length },
];
const accentByTab: Record<string, string> = {
  qb: 'bg-signal/15 text-signal',
  wr: 'bg-sky/15 text-[#1B5E83]',
  db: 'bg-verde/15 text-[#1B6E62]',
};
---

<AppLayout
  title={`Top hráči · ${league.name}`}
  active="leaders"
  pageTitle="Leaderboards"
  pageSub={`${league.name} · cross-club žebříčky`}
>
  <div class="mb-6 flex flex-wrap items-center gap-2 text-[13px]">
    <a href="/app/league" class="rounded-md border border-stone bg-pearl px-3 py-1.5 font-medium text-graphite hover:bg-mist">← Liga dashboard</a>
  </div>

  <!-- Tabs -->
  <div class="mb-6 flex flex-wrap gap-1 rounded-lg border border-stone bg-pearl p-1">
    {tabs.map((t) => {
      const isActive = tab === t.key;
      return (
        <a
          href={`/app/league/leaders?pos=${t.key}`}
          class={`rounded-md px-4 py-2 text-[13px] font-medium transition-colors ${isActive ? 'bg-ink text-white' : 'text-graphite hover:bg-mist'}`}
        >
          {t.label}
          <span class="ml-1 text-[10px] opacity-70">({t.count})</span>
        </a>
      );
    })}
  </div>

  {tab === 'qb' && (
    <div class="rounded-xl border border-stone bg-pearl">
      <div class="flex items-center justify-between border-b border-stone px-5 py-4">
        <div>
          <p class="text-[15px] font-semibold tracking-tight-2 text-ink">QB top {qb.length === 0 ? '' : `· ${qb.length} hráčů`}</p>
          <p class="text-[12px] text-slate">Řazeno podle TD pasů · sekundárně yds</p>
        </div>
        <span class={`rounded-md px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.1em] ${accentByTab.qb}`}>QB</span>
      </div>
      {qb.length === 0 ? (
        <div class="p-12 text-center text-[13px] text-slate">Zatím žádné QB staty v lize. Po prvních zápasech se objeví žebříček.</div>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full min-w-[800px] text-left text-[13px]">
            <thead class="border-b border-stone bg-mist text-[10px] font-semibold uppercase tracking-[0.08em] text-slate">
              <tr>
                <th class="px-5 py-3 w-10">#</th>
                <th class="py-3">Hráč</th>
                <th class="py-3">Tým</th>
                <th class="px-3 py-3 text-center tabular-nums">ATT</th>
                <th class="px-3 py-3 text-center tabular-nums">COMP</th>
                <th class="px-3 py-3 text-center tabular-nums">%</th>
                <th class="px-3 py-3 text-center tabular-nums">YDS</th>
                <th class="px-3 py-3 text-center tabular-nums">TD</th>
                <th class="px-3 py-3 text-center tabular-nums">INT</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-stone">
              {qb.map((p, i) => {
                const pct = p.qbAtt > 0 ? Math.round((p.qbComp / p.qbAtt) * 100) : 0;
                return (
                  <tr class="transition-colors hover:bg-mist/60">
                    <td class="px-5 py-3"><span class={`inline-flex h-6 w-6 items-center justify-center rounded-full text-[11px] font-bold tabular-nums ${i === 0 ? 'bg-signal text-white' : 'bg-mist text-graphite'}`}>{i + 1}</span></td>
                    <td class="py-3">
                      <div class="flex items-center gap-3">
                        {p.photoUrl ? (
                          <img src={p.photoUrl} alt="" loading="lazy" class="h-8 w-8 flex-shrink-0 rounded-full object-cover" />
                        ) : (
                          <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-ink/5 text-[11px] font-semibold text-ink">{p.name.split(' ').map((w) => w[0] ?? '').join('').slice(0, 2)}</span>
                        )}
                        <div>
                          <p class="text-[14px] font-semibold text-ink">{p.name}</p>
                          <p class="text-[11px] text-slate">#{p.jersey ?? '—'}</p>
                        </div>
                      </div>
                    </td>
                    <td class="py-3 text-[12px] text-graphite">{p.clubName} · {p.teamName}</td>
                    <td class="px-3 py-3 text-center tabular-nums text-graphite">{p.qbAtt}</td>
                    <td class="px-3 py-3 text-center font-semibold tabular-nums text-ink">{p.qbComp}</td>
                    <td class="px-3 py-3 text-center tabular-nums text-signal">{pct}%</td>
                    <td class="px-3 py-3 text-center tabular-nums text-graphite">{p.qbYds}</td>
                    <td class="px-3 py-3 text-center font-semibold tabular-nums text-ink">{p.qbTd}</td>
                    <td class="px-3 py-3 text-center tabular-nums text-graphite">{p.qbInt}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </div>
  )}

  {tab === 'wr' && (
    <div class="rounded-xl border border-stone bg-pearl">
      <div class="flex items-center justify-between border-b border-stone px-5 py-4">
        <div>
          <p class="text-[15px] font-semibold tracking-tight-2 text-ink">WR top {wr.length === 0 ? '' : `· ${wr.length} hráčů`}</p>
          <p class="text-[12px] text-slate">Řazeno podle TD chytů · sekundárně bodů</p>
        </div>
        <span class={`rounded-md px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.1em] ${accentByTab.wr}`}>WR</span>
      </div>
      {wr.length === 0 ? (
        <div class="p-12 text-center text-[13px] text-slate">Zatím žádné WR staty v lize.</div>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full min-w-[820px] text-left text-[13px]">
            <thead class="border-b border-stone bg-mist text-[10px] font-semibold uppercase tracking-[0.08em] text-slate">
              <tr>
                <th class="px-5 py-3 w-10">#</th>
                <th class="py-3">Hráč</th>
                <th class="py-3">Tým</th>
                <th class="px-3 py-3 text-center tabular-nums">TARG</th>
                <th class="px-3 py-3 text-center tabular-nums">REC</th>
                <th class="px-3 py-3 text-center tabular-nums">%</th>
                <th class="px-3 py-3 text-center tabular-nums">YDS</th>
                <th class="px-3 py-3 text-center tabular-nums">TD</th>
                <th class="px-3 py-3 text-center tabular-nums">PTS</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-stone">
              {wr.map((p, i) => {
                const pct = p.wrTargets > 0 ? Math.round((p.wrRec / p.wrTargets) * 100) : 0;
                return (
                  <tr class="transition-colors hover:bg-mist/60">
                    <td class="px-5 py-3"><span class={`inline-flex h-6 w-6 items-center justify-center rounded-full text-[11px] font-bold tabular-nums ${i === 0 ? 'bg-sky/30 text-[#1B5E83]' : 'bg-mist text-graphite'}`}>{i + 1}</span></td>
                    <td class="py-3">
                      <div class="flex items-center gap-3">
                        {p.photoUrl ? (
                          <img src={p.photoUrl} alt="" loading="lazy" class="h-8 w-8 flex-shrink-0 rounded-full object-cover" />
                        ) : (
                          <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-ink/5 text-[11px] font-semibold text-ink">{p.name.split(' ').map((w) => w[0] ?? '').join('').slice(0, 2)}</span>
                        )}
                        <div>
                          <p class="text-[14px] font-semibold text-ink">{p.name}</p>
                          <p class="text-[11px] text-slate">#{p.jersey ?? '—'}</p>
                        </div>
                      </div>
                    </td>
                    <td class="py-3 text-[12px] text-graphite">{p.clubName} · {p.teamName}</td>
                    <td class="px-3 py-3 text-center tabular-nums text-graphite">{p.wrTargets}</td>
                    <td class="px-3 py-3 text-center font-semibold tabular-nums text-ink">{p.wrRec}</td>
                    <td class="px-3 py-3 text-center tabular-nums text-[#1B5E83]">{pct}%</td>
                    <td class="px-3 py-3 text-center tabular-nums text-graphite">{p.wrYds}</td>
                    <td class="px-3 py-3 text-center font-semibold tabular-nums text-ink">{p.wrTd}</td>
                    <td class="px-3 py-3 text-center font-semibold tabular-nums text-signal">{p.wrPts}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </div>
  )}

  {tab === 'db' && (
    <div class="rounded-xl border border-stone bg-pearl">
      <div class="flex items-center justify-between border-b border-stone px-5 py-4">
        <div>
          <p class="text-[15px] font-semibold tracking-tight-2 text-ink">DB top {db.length === 0 ? '' : `· ${db.length} hráčů`}</p>
          <p class="text-[12px] text-slate">Score = INT × 3 + Sack × 2 + Flag pull</p>
        </div>
        <span class={`rounded-md px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.1em] ${accentByTab.db}`}>DB</span>
      </div>
      {db.length === 0 ? (
        <div class="p-12 text-center text-[13px] text-slate">Zatím žádné obranné staty v lize.</div>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full min-w-[780px] text-left text-[13px]">
            <thead class="border-b border-stone bg-mist text-[10px] font-semibold uppercase tracking-[0.08em] text-slate">
              <tr>
                <th class="px-5 py-3 w-10">#</th>
                <th class="py-3">Hráč</th>
                <th class="py-3">Tým</th>
                <th class="px-3 py-3 text-center tabular-nums">FLAG PULL</th>
                <th class="px-3 py-3 text-center tabular-nums">SACK</th>
                <th class="px-3 py-3 text-center tabular-nums">INT</th>
                <th class="px-3 py-3 text-center tabular-nums">BRKUP</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-stone">
              {db.map((p, i) => (
                <tr class="transition-colors hover:bg-mist/60">
                  <td class="px-5 py-3"><span class={`inline-flex h-6 w-6 items-center justify-center rounded-full text-[11px] font-bold tabular-nums ${i === 0 ? 'bg-verde/30 text-[#1B6E62]' : 'bg-mist text-graphite'}`}>{i + 1}</span></td>
                  <td class="py-3">
                    <div class="flex items-center gap-3">
                      {p.photoUrl ? (
                        <img src={p.photoUrl} alt="" loading="lazy" class="h-8 w-8 flex-shrink-0 rounded-full object-cover" />
                      ) : (
                        <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-ink/5 text-[11px] font-semibold text-ink">{p.name.split(' ').map((w) => w[0] ?? '').join('').slice(0, 2)}</span>
                      )}
                      <div>
                        <p class="text-[14px] font-semibold text-ink">{p.name}</p>
                        <p class="text-[11px] text-slate">#{p.jersey ?? '—'}</p>
                      </div>
                    </div>
                  </td>
                  <td class="py-3 text-[12px] text-graphite">{p.clubName} · {p.teamName}</td>
                  <td class="px-3 py-3 text-center font-semibold tabular-nums text-ink">{p.dbFlagPull}</td>
                  <td class="px-3 py-3 text-center font-semibold tabular-nums text-signal">{p.dbSack}</td>
                  <td class="px-3 py-3 text-center font-semibold tabular-nums text-[#1B6E62]">{p.dbInt}</td>
                  <td class="px-3 py-3 text-center tabular-nums text-graphite">{p.dbBrkup}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  )}
</AppLayout>
