---
import AppLayout from '../../../layouts/AppLayout.astro';
import { getSupabaseAdmin } from '../../../lib/supabase';

export const prerender = false;

const user = Astro.locals.user!;
let league: any = Astro.locals.league ?? null;
let role: string | null = Astro.locals.leagueRole ?? null;

const admin = getSupabaseAdmin();

// Iter 71b: collect diagnostic info so we can SEE what's happening instead
// of silently bouncing.
const debug: Record<string, any> = {
  userId: user?.id ?? '(null)',
  userEmail: user?.email ?? '(null)',
  initialLeagueFromMiddleware: league?.id ?? null,
  initialRole: role,
  membershipRows: null,
  membershipErr: null,
  ownedLeagueId: null,
  ownedErr: null,
};

// Path 1: membership lookup (re-do in case middleware missed it)
if (!league && user) {
  const { data: lmRows, error: lmErr } = await admin
    .from('league_members')
    .select('league_id, role, leagues(*)')
    .eq('user_id', user.id)
    .order('created_at', { ascending: true });
  debug.membershipRows = lmRows?.length ?? 0;
  debug.membershipErr = lmErr?.message ?? null;
  const lm = (lmRows ?? [])[0];
  if (lm && (lm as any).leagues) {
    league = (lm as any).leagues;
    role = (lm as any).role;
  }
}

// Path 2: owner fallback
if (!league && user) {
  const { data: ownedLeague, error: ownErr } = await admin
    .from('leagues')
    .select('*')
    .eq('owner_user_id', user.id)
    .order('created_at', { ascending: true })
    .limit(1)
    .maybeSingle();
  debug.ownedLeagueId = (ownedLeague as any)?.id ?? null;
  debug.ownedErr = ownErr?.message ?? null;
  if (ownedLeague) {
    league = ownedLeague as any;
    role = 'admin';
  }
}

debug.finalLeagueId = league?.id ?? null;
debug.finalRole = role;

// Iter 71b: if league STILL missing, render diagnostic page (no redirect).
const noLeague = !league;

// Fetch all league members with profile info (skip if noLeague)
const { data: membersRaw } = noLeague
  ? { data: [] as any[] }
  : await admin
      .from('league_members')
      .select('id, role, user_id, created_at')
      .eq('league_id', league.id)
      .order('created_at', { ascending: true });
const members = (membersRaw ?? []) as { id: string; role: string; user_id: string; created_at: string }[];

const userIds = members.map((m) => m.user_id);
const { data: profilesRaw } = userIds.length
  ? await admin.from('profiles').select('id, email, first_name, last_name').in('id', userIds)
  : { data: [] as any[] };
const profileById = new Map<string, any>((profilesRaw ?? []).map((p: any) => [p.id, p]));

// URL params
const url = new URL(Astro.request.url);
const saved = url.searchParams.get('saved');
const error = url.searchParams.get('error');

const isAdmin = role === 'admin';
const roleLabel: Record<string, string> = { admin: 'Admin', staff: 'Staff', viewer: 'Viewer' };
const initials = (firstName: string, lastName: string, email: string) => {
  const fn = firstName?.[0] ?? '';
  const ln = lastName?.[0] ?? '';
  if (fn || ln) return (fn + ln).toUpperCase();
  return (email[0] ?? '?').toUpperCase();
};

const publicUrl = noLeague ? '—' : `gamestatiq.com/liga/${league.slug}`;
---

<AppLayout
  title={noLeague ? 'Nastavení (diagnostika) · GameStatiq' : `Nastavení · ${league.name}`}
  active="settings"
  pageTitle={noLeague ? 'Nastavení ligy — diagnostika' : 'Nastavení ligy'}
  pageSub={noLeague ? 'Liga kontext chybí. Detaily níže.' : `${league.name} · ${members.length} členů`}
>
  {noLeague && (
    <div class="mb-8 rounded-xl border-2 border-signal/40 bg-signal/5 p-6">
      <p class="text-[15px] font-bold text-signal">⚠️ Liga kontext nebyl nastaven</p>
      <p class="mt-2 text-[13px] text-graphite">
        Server nedokázal najít žádnou ligu, ke které jsi přihlášený(á). Pošli tento výpis na <a href="mailto:hello@gamestatiq.com" class="font-semibold text-signal underline">hello@gamestatiq.com</a>.
      </p>
      <pre class="mt-4 overflow-x-auto rounded-lg border border-stone bg-ink/95 p-4 text-[11px] font-mono text-pearl">{JSON.stringify(debug, null, 2)}</pre>
      <p class="mt-3 text-[11px] text-slate">
        Možné příčiny: žádný řádek v <code class="rounded bg-mist px-1 text-[10px]">league_members</code> pro tvůj user_id, žádná liga s <code class="rounded bg-mist px-1 text-[10px]">owner_user_id</code> = tvůj user_id, nebo Supabase service-role klíč nemá přístup ke <code class="rounded bg-mist px-1 text-[10px]">leagues</code>/<code class="rounded bg-mist px-1 text-[10px]">league_members</code> tabulkám.
      </p>
      <div class="mt-5 flex flex-wrap gap-2">
        <a href="/app" class="rounded-md border border-stone bg-pearl px-3 py-1.5 text-[13px] font-medium text-graphite hover:bg-mist">← Hlavní dashboard</a>
        <a href="/app/league" class="rounded-md border border-stone bg-pearl px-3 py-1.5 text-[13px] font-medium text-graphite hover:bg-mist">Liga dashboard</a>
      </div>
    </div>
  )}
  {!noLeague && (<>
  {saved === 'logo' && (
    <div class="mb-6 rounded-lg border border-verde/30 bg-verde/5 px-4 py-3 text-[14px] text-[#1B6E62]">
      ✓ Logo nahráno.
    </div>
  )}
  {saved === 'logo_removed' && (
    <div class="mb-6 rounded-lg border border-verde/30 bg-verde/5 px-4 py-3 text-[14px] text-[#1B6E62]">
      ✓ Logo odebráno.
    </div>
  )}
  {saved === 'invite' && (
    <div class="mb-6 rounded-lg border border-verde/30 bg-verde/5 px-4 py-3 text-[14px] text-[#1B6E62]">
      ✓ Člen <strong>{url.searchParams.get('invited')}</strong> přidán do ligy.
    </div>
  )}
  {saved === 'role' && (
    <div class="mb-6 rounded-lg border border-verde/30 bg-verde/5 px-4 py-3 text-[14px] text-[#1B6E62]">
      ✓ Role byla změněna.
    </div>
  )}
  {saved === 'removed' && (
    <div class="mb-6 rounded-lg border border-verde/30 bg-verde/5 px-4 py-3 text-[14px] text-[#1B6E62]">
      ✓ Člen byl odebrán z ligy.
    </div>
  )}
  {saved && saved !== 'logo' && saved !== 'logo_removed' && saved !== 'invite' && saved !== 'role' && saved !== 'removed' && (
    <div class="mb-6 rounded-lg border border-verde/30 bg-verde/5 px-4 py-3 text-[14px] text-[#1B6E62]">
      ✓ Změny uloženy.
    </div>
  )}
  {error && (
    <div class="mb-6 rounded-lg border border-signal/30 bg-signal/5 px-4 py-3 text-[14px] text-signal">{error}</div>
  )}

  <div class="mb-6 flex flex-wrap items-center gap-2 text-[13px]">
    <a href="/app/league" class="rounded-md border border-stone bg-pearl px-3 py-1.5 font-medium text-graphite hover:bg-mist">← Liga dashboard</a>
  </div>

  <div class="grid gap-6 lg:grid-cols-[1fr_280px]">
    <div class="space-y-6">

      <!-- Liga info -->
      <div class="rounded-xl border border-stone bg-pearl p-6">
        <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Informace o lize</p>
        <p class="mt-1 text-[12px] text-slate">Veřejné informace zobrazené na public stránce <code class="rounded bg-mist px-1 py-0.5 text-[11px] text-graphite">{publicUrl}</code></p>

        {isAdmin ? (
          <form method="POST" action="/api/league/update" class="mt-5 space-y-4">
            <div class="grid gap-4 sm:grid-cols-2">
              <label class="block">
                <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Název ligy *</span>
                <input type="text" name="name" required maxlength="80" value={league.name} class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[14px] text-ink focus:border-signal focus:outline-none focus:ring-2 focus:ring-signal/20" />
              </label>
              <label class="block">
                <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Sport</span>
                <select name="sport" class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[14px] text-ink focus:border-signal focus:outline-none focus:ring-2 focus:ring-signal/20">
                  <option value="flag-football"     selected={league.sport === 'flag-football'}>Flag football</option>
                  <option value="american_football" selected={league.sport === 'american_football'}>American football</option>
                  <option value="football"          selected={league.sport === 'football'}>Football (soccer)</option>
                  <option value="basketball"        selected={league.sport === 'basketball'}>Basketball</option>
                  <option value="volleyball"        selected={league.sport === 'volleyball'}>Volejbal</option>
                  <option value="hockey"            selected={league.sport === 'hockey'}>Hokej</option>
                  <option value="other"             selected={league.sport === 'other'}>Jiný</option>
                </select>
              </label>
            </div>
            <label class="block">
              <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Slug · public URL</span>
              <div class="mt-1.5 flex items-center gap-2">
                <span class="rounded-md bg-mist px-3 py-2.5 text-[13px] font-mono text-slate">/liga/</span>
                <input type="text" name="slug" value={league.slug} placeholder="moje-liga" class="block flex-1 rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[14px] font-mono text-ink focus:border-signal focus:outline-none focus:ring-2 focus:ring-signal/20" />
              </div>
              <p class="mt-1 text-[11px] text-slate">Slug musí být unikátní. Pomlčky, písmena, čísla. Změna naruší existující odkazy.</p>
            </label>
            <label class="block">
              <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Popis (volitelný)</span>
              <textarea name="description" rows="3" maxlength="500" placeholder="Krátký popis pro fanoušky a partnery…" class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[14px] text-ink focus:border-signal focus:outline-none focus:ring-2 focus:ring-signal/20">{league.description ?? ''}</textarea>
            </label>
            <div class="grid gap-4 sm:grid-cols-2">
              <label class="block">
                <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Primární barva</span>
                <input type="color" name="primary" value={league.primary_color} class="mt-1.5 block h-10 w-full cursor-pointer rounded-lg border border-stone bg-pearl" />
              </label>
              <label class="block">
                <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Sekundární barva</span>
                <input type="color" name="secondary" value={league.secondary_color} class="mt-1.5 block h-10 w-full cursor-pointer rounded-lg border border-stone bg-pearl" />
              </label>
            </div>
            <div class="flex flex-wrap items-center gap-3 pt-2">
              <button type="submit" class="rounded-lg bg-signal px-4 py-2.5 text-[13px] font-semibold text-white hover:bg-[#C8313D]">Uložit změny</button>
              <a href="/app/league" class="text-[13px] font-medium text-graphite hover:text-ink">Zrušit</a>
            </div>
          </form>

          <!-- Logo upload (separate form, multipart) -->
          <div class="mt-6 border-t border-stone pt-5">
            <p class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Logo ligy</p>
            <div class="mt-3 flex flex-wrap items-center gap-5">
              {league.logo_url ? (
                <img src={league.logo_url} alt="" class="h-20 w-20 rounded-xl border border-stone bg-pearl object-contain p-2" />
              ) : (
                <span class="inline-flex h-20 w-20 items-center justify-center rounded-xl border border-dashed border-stone bg-mist text-[10px] font-semibold uppercase tracking-wider text-stone-2">No logo</span>
              )}
              <div class="flex-1 min-w-[240px] space-y-3">
                <form method="POST" action="/api/league/logo/upload" enctype="multipart/form-data" class="flex flex-wrap items-center gap-2">
                  <input type="file" name="logo" accept="image/svg+xml,image/png,image/jpeg,image/webp" required class="text-[12px]" />
                  <button type="submit" class="rounded-md bg-signal px-3 py-1.5 text-[12px] font-semibold text-white hover:bg-[#C8313D]">{league.logo_url ? 'Vyměnit' : 'Nahrát'}</button>
                </form>
                {league.logo_url && (
                  <form method="POST" action="/api/league/logo/remove" class="inline">
                    <button type="submit" onclick="return confirm('Odebrat aktuální logo?')" class="rounded-md border border-stone bg-pearl px-3 py-1.5 text-[11px] font-medium text-graphite hover:border-signal/40 hover:text-signal">Odebrat logo</button>
                  </form>
                )}
                <p class="text-[11px] text-stone-2">SVG / PNG / JPG / WebP · max 5 MB · zobrazí se na public stránce <code class="rounded bg-mist px-1 py-0.5 text-[11px]">/liga/{league.slug}</code></p>
              </div>
            </div>
          </div>
        ) : (
          <dl class="mt-5 space-y-3 text-[13px]">
            <div class="flex"><dt class="w-32 text-slate">Název</dt><dd class="text-ink">{league.name}</dd></div>
            <div class="flex"><dt class="w-32 text-slate">Sport</dt><dd class="text-ink">{league.sport}</dd></div>
            <div class="flex"><dt class="w-32 text-slate">Public URL</dt><dd class="font-mono text-ink">{publicUrl}</dd></div>
            <div class="flex"><dt class="w-32 text-slate">Popis</dt><dd class="text-graphite">{league.description ?? '—'}</dd></div>
          </dl>
        )}
      </div>

      <!-- Members -->
      <div class="rounded-xl border border-stone bg-pearl">
        <div class="flex items-center justify-between border-b border-stone px-5 py-4">
          <div>
            <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Členové ligy</p>
            <p class="text-[12px] text-slate">{members.length} {members.length === 1 ? 'člen' : members.length < 5 ? 'členové' : 'členů'} · admin / staff / viewer</p>
          </div>
        </div>

        {isAdmin && (
          <form method="POST" action="/api/league/members/invite" class="border-b border-stone bg-mist/40 px-5 py-4">
            <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">Přidat člena podle e-mailu</p>
            <div class="flex flex-wrap items-end gap-3">
              <label class="flex-1 min-w-[220px]">
                <span class="block text-[11px] font-medium text-slate">E-mail</span>
                <input type="email" name="email" required placeholder="kolega@klub.cz" class="mt-1 block w-full rounded-lg border border-stone bg-pearl px-3 py-2 text-[13px] text-ink focus:border-signal focus:outline-none focus:ring-2 focus:ring-signal/20" />
              </label>
              <label>
                <span class="block text-[11px] font-medium text-slate">Role</span>
                <select name="role" class="mt-1 rounded-lg border border-stone bg-pearl px-3 py-2 text-[13px] text-ink">
                  <option value="staff" style="color:#1A1A1A;background:white">Staff</option>
                  <option value="admin" style="color:#1A1A1A;background:white">Admin</option>
                  <option value="viewer" style="color:#1A1A1A;background:white">Viewer</option>
                </select>
              </label>
              <button type="submit" class="rounded-lg bg-signal px-4 py-2 text-[13px] font-semibold text-white hover:bg-[#C8313D]">+ Přidat</button>
            </div>
            <p class="mt-2 text-[11px] text-stone-2">Uživatel musí mít účet na GameStatiq. Pokud nemá, požádejte ho, ať se nejdřív zaregistruje na gamestatiq.com.</p>
          </form>
        )}

        <ul class="divide-y divide-stone">
          {members.map((m) => {
            const p = profileById.get(m.user_id);
            const fn = p?.first_name ?? '';
            const ln = p?.last_name ?? '';
            const fullName = [fn, ln].filter(Boolean).join(' ') || (p?.email ?? '—');
            const isSelf = m.user_id === user.id;
            const isOwner = m.user_id === (league as any).owner_user_id;
            return (
              <li class="flex flex-wrap items-center gap-4 px-5 py-4">
                <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-ink/5 text-[12px] font-semibold text-ink">{initials(fn, ln, p?.email ?? '?')}</span>
                <div class="min-w-0 flex-1">
                  <p class="truncate text-[14px] font-semibold text-ink">
                    {fullName}
                    {isSelf && <span class="ml-2 text-[10px] font-semibold uppercase tracking-wider text-slate">vy</span>}
                    {isOwner && <span class="ml-2 rounded bg-spark/20 px-1.5 py-0.5 text-[9px] font-semibold uppercase tracking-wider text-[#7A4318]">Vlastník</span>}
                  </p>
                  <p class="truncate text-[12px] text-slate">{p?.email ?? '—'}</p>
                </div>

                {isAdmin ? (
                  <div class="flex items-center gap-2">
                    <form method="POST" action="/api/league/members/role" class="inline-flex">
                      <input type="hidden" name="member_id" value={m.id} />
                      <select
                        name="role"
                        onchange="this.form.submit()"
                        class={`rounded-md border px-2 py-1 text-[11px] font-semibold uppercase tracking-[0.08em] ${
                          m.role === 'admin' ? 'border-signal/40 bg-signal/15 text-signal' :
                          m.role === 'staff' ? 'border-sky/40 bg-sky/15 text-[#1B5E83]' :
                                               'border-stone bg-mist text-slate'
                        }`}
                      >
                        <option value="admin"  selected={m.role === 'admin'}  style="color:#1A1A1A;background:white">Admin</option>
                        <option value="staff"  selected={m.role === 'staff'}  style="color:#1A1A1A;background:white">Staff</option>
                        <option value="viewer" selected={m.role === 'viewer'} style="color:#1A1A1A;background:white">Viewer</option>
                      </select>
                    </form>
                    {!isOwner && (
                      <form method="POST" action="/api/league/members/remove" class="inline-flex">
                        <input type="hidden" name="member_id" value={m.id} />
                        <button
                          type="submit"
                          onclick={`return confirm('Odebrat ${fullName} z ligy?')`}
                          title="Odebrat z ligy"
                          class="rounded-md border border-stone bg-pearl px-2 py-1 text-[11px] font-medium text-graphite hover:border-signal/40 hover:text-signal"
                        >×</button>
                      </form>
                    )}
                  </div>
                ) : (
                  <span class={`rounded-md px-2 py-1 text-[11px] font-semibold uppercase tracking-[0.08em] ${
                    m.role === 'admin' ? 'bg-signal/15 text-signal' :
                    m.role === 'staff' ? 'bg-sky/15 text-[#1B5E83]' :
                                         'bg-mist text-slate'
                  }`}>{roleLabel[m.role] ?? m.role}</span>
                )}
              </li>
            );
          })}
        </ul>
      </div>

    </div>

    <!-- Side panel -->
    <aside class="space-y-4">
      <div class="rounded-xl border border-plum/20 bg-plum/5 p-5">
        <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-[#4F3878]">Public stránka</p>
        <p class="mt-2 text-[13px] text-graphite">
          Fanoušci a partneři uvidí standings + leaderboards na public adrese.
        </p>
        <a href={`/liga/${league.slug}`} target="_blank" rel="noopener" class="mt-3 inline-flex items-center gap-1.5 text-[13px] font-semibold text-[#4F3878] hover:underline">
          Otevřít {publicUrl}
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7 M7 7h10v10"/></svg>
        </a>
      </div>

      <div class="rounded-xl border border-stone bg-pearl p-5">
        <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-slate">Plán</p>
        <p class="mt-2 text-[15px] font-bold text-ink">Liga · Trial</p>
        <p class="mt-1 text-[12px] text-graphite">
          {league.trial_ends_at
            ? `Trial běží do ${new Date(league.trial_ends_at).toLocaleDateString('cs-CZ')}.`
            : 'Trial neaktivní.'}
        </p>
        <a href="/app/league/billing" class="mt-3 inline-flex text-[12px] font-semibold text-signal hover:underline">Spravovat plán →</a>
      </div>

      <div class="rounded-xl border border-stone bg-pearl p-5">
        <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-slate">ID ligy</p>
        <p class="mt-2 truncate font-mono text-[12px] text-graphite" title={league.id}>{league.id}</p>
        <p class="mt-2 text-[11px] text-slate">Pro support tickety nebo migrace.</p>
      </div>
    </aside>
  </div>
  </>)}
</AppLayout>
