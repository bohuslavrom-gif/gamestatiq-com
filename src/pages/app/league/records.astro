---
import AppLayout from '../../../layouts/AppLayout.astro';
import { fetchLeagueCareerRecords, CAREER_CATEGORY_LABELS, CAREER_CATEGORIES } from '../../../lib/league-stats';

export const prerender = false;

const league = Astro.locals.league ?? null;
const role = Astro.locals.leagueRole ?? null;
if (!league) return Astro.redirect('/app');

const canEdit = role === 'admin' || role === 'staff';

const records = await fetchLeagueCareerRecords(league.id);

const url = new URL(Astro.request.url);
const saved = url.searchParams.get('saved');
const errorMsg = url.searchParams.get('error');
const editId = url.searchParams.get('edit');
const addMode = url.searchParams.get('add') === '1';
const editingRecord = editId ? records.find((r) => r.id === editId) : null;
const showForm = canEdit && (addMode || !!editingRecord);

const SAVED_MSG: Record<string, string> = {
  created: '✓ Rekord přidán.',
  updated: '✓ Rekord upraven.',
  deleted: '✓ Rekord smazán.',
};

// Group records by category for display
const byCategory = new Map<string, typeof records>();
for (const r of records) {
  const arr = byCategory.get(r.category) ?? [];
  arr.push(r);
  byCategory.set(r.category, arr);
}
---

<AppLayout
  title={`Rekordy · ${league.name}`}
  active="records"
  pageTitle="Kariérní rekordy ligy"
  pageSub={`${league.name} · ${records.length} ${records.length === 1 ? 'rekord' : records.length < 5 ? 'rekordy' : 'rekordů'}`}
>

  {saved && SAVED_MSG[saved] && <div class="mb-6 rounded-lg border border-verde/30 bg-verde/5 px-4 py-3 text-[14px] text-[#1B6E62]">{SAVED_MSG[saved]}</div>}
  {errorMsg && <div class="mb-6 rounded-lg border border-signal/30 bg-signal/5 px-4 py-3 text-[14px] text-signal">{errorMsg}</div>}

  <div class="mb-6 flex flex-wrap items-center gap-2 text-[13px]">
    <a href="/app/league" class="rounded-md border border-stone bg-pearl px-3 py-1.5 font-medium text-graphite hover:bg-mist">← Liga dashboard</a>
  </div>

  {!canEdit && (
    <div class="mb-6 rounded-lg border border-sky/30 bg-sky/5 px-4 py-3 text-[13px] text-[#1B5E83]">
      Vaše role <strong>{role}</strong> umožňuje pouze prohlížení. Pro úpravy je potřeba role Admin nebo Staff.
    </div>
  )}

  <!-- Add / Edit form -->
  {showForm && (
    <div class="mb-6 rounded-xl border border-plum/30 bg-gradient-to-br from-plum/5 to-signal/5 p-6">
      <p class="text-[15px] font-semibold tracking-tight-2 text-ink">{editingRecord ? 'Upravit rekord' : 'Přidat kariérní rekord'}</p>
      <p class="mt-1 text-[12px] text-graphite">
        Manuální zápis historických rekordů (před érou GameStatiq). Ukáže se public na <code class="rounded bg-mist px-1 py-0.5 text-[11px]">/liga/{league.slug}</code> v sekci Ligové rekordy.
      </p>

      <form method="POST" action={editingRecord ? '/api/league/record/update' : '/api/league/record/create'} class="mt-5 space-y-4">
        {editingRecord && <input type="hidden" name="id" value={editingRecord.id} />}

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Kategorie *</span>
            <select name="category" required class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[13px] text-ink">
              <option value="">— vyberte —</option>
              {CAREER_CATEGORIES.map((c) => (
                <option value={c} selected={c === editingRecord?.category}>{CAREER_CATEGORY_LABELS[c] ?? c}</option>
              ))}
            </select>
          </label>
          <label class="block">
            <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Hodnota *</span>
            <input type="number" min="0" name="value" required value={editingRecord?.value ?? ''} class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[14px] tabular-nums" placeholder="312" />
          </label>
        </div>

        <div class="grid gap-4 sm:grid-cols-[1fr_120px]">
          <label class="block">
            <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Jméno hráče / týmu *</span>
            <input type="text" name="player_name" required value={editingRecord?.playerName ?? ''} class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[14px]" placeholder="Tomáš Vacek" />
          </label>
          <label class="block">
            <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Číslo dresu</span>
            <input type="number" min="0" max="999" name="jersey" value={editingRecord?.jersey ?? ''} class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[14px] tabular-nums" placeholder="12" />
          </label>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Klub</span>
            <input type="text" name="club_name" value={editingRecord?.clubName ?? ''} class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[14px]" placeholder="Bobcats" />
          </label>
          <label class="block">
            <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Tým</span>
            <input type="text" name="team_name" value={editingRecord?.teamName ?? ''} class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[14px]" placeholder="Muži" />
          </label>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Roky / sezóny</span>
            <input type="text" name="season_range" value={editingRecord?.seasonRange ?? ''} class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[14px]" placeholder="2018–2024 nebo 2020–dnes" />
          </label>
          <label class="block">
            <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">URL fotky (volitelné)</span>
            <input type="url" name="photo_url" value={editingRecord?.photoUrl ?? ''} class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[13px]" placeholder="https://…" />
          </label>
        </div>

        <label class="block">
          <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Poznámka (volitelné)</span>
          <textarea name="notes" rows="2" class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[13px]" placeholder="Vítěz MVP 2022; první hráč co dosáhl 300 TD;…">{editingRecord?.notes ?? ''}</textarea>
        </label>

        <div class="flex flex-wrap items-center gap-3 pt-2">
          <button type="submit" class="rounded-lg bg-plum px-4 py-2.5 text-[13px] font-semibold text-white hover:bg-[#3F2B68]">{editingRecord ? 'Uložit změny' : 'Přidat rekord'}</button>
          <a href="/app/league/records" class="text-[13px] font-medium text-graphite hover:text-ink">Zrušit</a>
        </div>
      </form>
    </div>
  )}

  <!-- Records list grouped by category -->
  <div class="space-y-6">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <h2 class="text-[18px] font-bold tracking-tight-2 text-ink">Seznam rekordů</h2>
        <p class="text-[12px] text-slate">{records.length} celkem · {byCategory.size} kategorií</p>
      </div>
      {canEdit && !addMode && !editingRecord && (
        <a href="/app/league/records?add=1" class="rounded-lg bg-plum px-4 py-2 text-[13px] font-semibold text-white hover:bg-[#3F2B68]">+ Přidat rekord</a>
      )}
    </div>

    {records.length === 0 ? (
      <div class="rounded-xl border border-stone bg-pearl p-12 text-center">
        <p class="text-[15px] font-semibold text-ink">Zatím žádné rekordy</p>
        <p class="mt-1 text-[13px] text-slate">
          {canEdit ? 'Klikněte na "+ Přidat rekord" a začněte zapisovat historické úspěchy hráčů a týmů.' : 'Zatím nebyly přidány žádné kariérní rekordy.'}
        </p>
      </div>
    ) : (
      Array.from(byCategory.entries()).map(([cat, rows]) => (
        <div class="rounded-xl border border-stone bg-pearl">
          <div class="border-b border-stone px-5 py-4">
            <p class="text-[14px] font-semibold tracking-tight-2 text-ink">{CAREER_CATEGORY_LABELS[cat] ?? cat}</p>
            <p class="text-[11px] text-slate">{rows.length} {rows.length === 1 ? 'záznam' : rows.length < 5 ? 'záznamy' : 'záznamů'}</p>
          </div>
          <ul class="divide-y divide-stone">
            {rows.map((r) => (
              <li class="flex flex-wrap items-center gap-4 px-5 py-4">
                {r.photoUrl ? (
                  <img src={r.photoUrl} alt="" loading="lazy" class="h-10 w-10 rounded-full object-cover" />
                ) : (
                  <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-ink/5 text-[12px] font-semibold text-ink">
                    {(r.playerName ?? '?').split(' ').map((w) => w[0] ?? '').join('').slice(0, 2).toUpperCase()}
                  </span>
                )}
                <div class="min-w-0 flex-1">
                  <p class="truncate text-[14px] font-semibold text-ink">
                    {r.playerName}
                    {r.jersey != null && <span class="ml-1 text-[11px] text-stone-2">#{r.jersey}</span>}
                  </p>
                  <p class="truncate text-[11px] text-slate">
                    {[r.clubName, r.teamName].filter(Boolean).join(' · ') || '—'}
                    {r.seasonRange && ` · ${r.seasonRange}`}
                  </p>
                  {r.notes && <p class="mt-1 truncate text-[11px] text-stone-2">{r.notes}</p>}
                </div>
                <span class="text-[24px] font-bold tabular-nums text-plum">{r.value}</span>
                {canEdit && (
                  <div class="flex items-center gap-2">
                    <a href={`/app/league/records?edit=${r.id}`} class="rounded-md border border-stone bg-pearl px-3 py-1.5 text-[11px] font-medium text-graphite hover:bg-mist">Upravit</a>
                    <form method="POST" action="/api/league/record/delete" class="inline">
                      <input type="hidden" name="id" value={r.id} />
                      <button type="submit" class="rounded-md border border-stone bg-pearl px-3 py-1.5 text-[11px] font-medium text-graphite hover:border-signal/40 hover:text-signal" onclick="return confirm('Smazat rekord? Akce je nevratná.')">Smazat</button>
                    </form>
                  </div>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))
    )}
  </div>
</AppLayout>
