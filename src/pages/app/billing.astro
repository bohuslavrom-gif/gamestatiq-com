---
import AppLayout from '../../layouts/AppLayout.astro';
import { getSupabaseAdmin, type Club } from '../../lib/supabase';

export const prerender = false;

const user = Astro.locals.user!;
const admin = getSupabaseAdmin();

const { data: club } = await admin
  .from('clubs')
  .select('*')
  .eq('owner_id', user.id)
  .order('created_at', { ascending: true })
  .limit(1)
  .maybeSingle() as { data: Club | null };

const url = new URL(Astro.request.url);
const checkout = url.searchParams.get('checkout');
const error = url.searchParams.get('error');

const tierLabel: Record<string, string> = { trial: 'Trial', klub: 'Klub', liga: 'Liga', federace: 'Federace' };
const statusLabel: Record<string, string> = {
  trialing: 'Trial běží', active: 'Aktivní', past_due: 'Nezaplaceno', canceled: 'Zrušeno', incomplete: 'Neúplné',
};
const statusColor: Record<string, string> = {
  trialing: 'bg-sky/15 text-[#1B5E83]',
  active: 'bg-verde/15 text-[#1B6E62]',
  past_due: 'bg-spark/15 text-[#A0531B]',
  canceled: 'bg-stone text-slate',
  incomplete: 'bg-spark/15 text-[#A0531B]',
};

const currentTier = club?.subscription_tier ?? 'trial';
const isTrial = currentTier === 'trial';

const tiers = [
  { id: 'klub', name: 'Klub', price: '690 Kč', period: '/ měs',
    desc: 'Jeden tým, app, public widget, coach analytika.',
    features: ['Live tracking', 'Public widget', 'Coach analytika', 'E-mail support'] },
  { id: 'liga', name: 'Liga', price: 'od 2 490 Kč', period: '/ měs',
    desc: 'Pro svazy a ligy. Master view + custom branding.',
    features: ['Vše z Klubu', 'Master league standings', 'Cross-club leaderboardy', 'Custom domain', 'Vlastní branding', 'Dedikovaný AM'],
    sales: true },
  { id: 'federace', name: 'Federace', price: 'Enterprise', period: '',
    desc: 'White-label + API + integrace s existujícími systémy.',
    features: ['Vše z Liga', 'White-label', 'API + webhooky', 'SLA + 24/7 support', 'On-premise option'],
    sales: true },
];

const formatDate = (s?: string | null) => s ? new Date(s).toLocaleDateString('cs-CZ') : '—';
---

<AppLayout title="Předplatné · GameStatiq" active="billing" pageTitle="Předplatné a faktury" pageSub="Spravujte svůj plán, platební metodu a stahujte faktury">
  {checkout === 'success' && (
    <div class="mb-6 rounded-lg border border-verde/30 bg-verde/5 px-4 py-3 text-[14px] text-[#1B6E62]">
      ✓ Předplatné aktivováno. Detaily se zobrazí během několika sekund.
    </div>
  )}
  {checkout === 'cancel' && (
    <div class="mb-6 rounded-lg border border-spark/30 bg-spark/5 px-4 py-3 text-[14px] text-[#A0531B]">
      Platba zrušena. Pokud potřebujete pomoc, napište nám na hello@gamestatiq.com.
    </div>
  )}
  {error && (
    <div class="mb-6 rounded-lg border border-signal/30 bg-signal/5 px-4 py-3 text-[14px] text-signal">{error}</div>
  )}

  <div class="rounded-xl border border-signal/30 bg-gradient-to-br from-signal/5 to-signal/10 p-6 lg:p-8">
    <div class="flex flex-wrap items-start justify-between gap-6">
      <div>
        <div class="flex items-center gap-2">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-signal">Aktuální plán</p>
          <span class={`inline-flex items-center rounded-md px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.1em] ${statusColor[club?.subscription_status ?? 'trialing']}`}>
            {statusLabel[club?.subscription_status ?? 'trialing']}
          </span>
        </div>
        <div class="mt-2 flex items-baseline gap-2">
          <h2 class="text-[28px] font-bold tracking-tight-2 text-ink">{tierLabel[currentTier]}</h2>
          {currentTier === 'klub' && (
            <>
              <span class="text-[18px] font-semibold text-graphite">·</span>
              <span class="text-[18px] font-semibold tabular-nums tracking-tight-2 text-ink">690 Kč / měs</span>
            </>
          )}
        </div>
        <p class="mt-3 max-w-md text-[14px] text-graphite">
          {isTrial
            ? `Free trial běží do ${formatDate(club?.trial_ends_at)}. Aktivujte předplatné, ať vám zachová přístup po skončení trialu.`
            : `Další platba ${formatDate(club?.current_period_end)}.`}
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          {!isTrial && club?.stripe_customer_id && (
            <form method="POST" action="/api/stripe/portal">
              <button type="submit" class="rounded-lg bg-ink px-4 py-2.5 text-[13px] font-medium text-white hover:bg-[#1A2B45]">
                Spravovat v Stripe Customer Portal
              </button>
            </form>
          )}
          {isTrial && (
            <form method="POST" action="/api/stripe/checkout">
              <input type="hidden" name="tier" value="klub" />
              <button type="submit" class="rounded-lg bg-signal px-4 py-2.5 text-[13px] font-semibold text-white hover:bg-[#C8313D]">
                Aktivovat Klub — 690 Kč / měs
              </button>
            </form>
          )}
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4 rounded-lg bg-pearl p-4 lg:gap-6 lg:p-5">
        <div>
          <p class="text-[10px] font-semibold uppercase tracking-[0.1em] text-slate">{isTrial ? 'Trial končí' : 'Příští platba'}</p>
          <p class="mt-1 text-[15px] font-bold tabular-nums text-ink">{isTrial ? formatDate(club?.trial_ends_at) : formatDate(club?.current_period_end)}</p>
        </div>
        <div>
          <p class="text-[10px] font-semibold uppercase tracking-[0.1em] text-slate">Stav</p>
          <p class="mt-1 text-[15px] font-bold text-ink">{statusLabel[club?.subscription_status ?? 'trialing']}</p>
        </div>
        <div>
          <p class="text-[10px] font-semibold uppercase tracking-[0.1em] text-slate">Customer ID</p>
          <p class="mt-1 truncate font-mono text-[13px] text-ink">{club?.stripe_customer_id ?? '—'}</p>
        </div>
        <div>
          <p class="text-[10px] font-semibold uppercase tracking-[0.1em] text-slate">Účet od</p>
          <p class="mt-1 text-[15px] font-bold tabular-nums text-ink">{formatDate(club?.created_at)}</p>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-8">
    <h2 class="text-[20px] font-bold tracking-tight-2 text-ink">Změna plánu</h2>
    <p class="mt-1 text-[14px] text-slate">Upgrade i downgrade se aplikuje proporcionálně k aktuálnímu fakturačnímu období.</p>
    <div class="mt-5 grid gap-5 lg:grid-cols-3">
      {tiers.map((t) => {
        const isCurrent = currentTier === t.id;
        return (
          <div class={`relative flex flex-col rounded-xl border bg-pearl p-6 ${isCurrent ? 'border-2 border-signal' : 'border-stone'}`}>
            {isCurrent && (
              <span class="absolute -top-3 left-6 rounded-full bg-signal px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.1em] text-white">Váš plán</span>
            )}
            <h3 class="text-[18px] font-bold tracking-tight-2 text-ink">{t.name}</h3>
            <p class="mt-1 text-[13px] text-slate">{t.desc}</p>
            <div class="mt-4 flex items-baseline gap-1.5">
              <span class="text-2xl font-bold tracking-tight-3 text-ink">{t.price}</span>
              {t.period && <span class="text-[13px] text-slate">{t.period}</span>}
            </div>
            <ul class="mt-5 space-y-2 text-[13px] text-graphite">
              {t.features.map((f) => (
                <li class="flex items-start gap-2">
                  <svg class="mt-[3px] h-3.5 w-3.5 flex-shrink-0 text-verde" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <div class="mt-6">
              {isCurrent ? (
                <button disabled class="w-full cursor-not-allowed rounded-lg border border-stone bg-mist px-4 py-2.5 text-[13px] font-medium text-stone-2">Aktuální plán</button>
              ) : t.sales ? (
                <a href="/#contact" class="block w-full rounded-lg border border-stone bg-pearl px-4 py-2.5 text-center text-[13px] font-medium text-ink hover:bg-mist">Kontaktovat sales</a>
              ) : (
                <form method="POST" action="/api/stripe/checkout">
                  <input type="hidden" name="tier" value={t.id} />
                  <button type="submit" class="w-full rounded-lg bg-signal px-4 py-2.5 text-[13px] font-semibold text-white hover:bg-[#C8313D]">Upgradovat na {t.name}</button>
                </form>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <div class="mt-8 rounded-xl border border-stone bg-pearl">
    <div class="flex items-center justify-between border-b border-stone px-5 py-4">
      <div>
        <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Faktury</p>
        <p class="text-[12px] text-slate">
          {club?.stripe_customer_id
            ? 'Faktury se synchronizují ze Stripe.'
            : 'Faktury budou k dispozici po aktivaci předplatného.'}
        </p>
      </div>
      {club?.stripe_customer_id && (
        <form method="POST" action="/api/stripe/portal">
          <button type="submit" class="rounded-md border border-stone bg-pearl px-3 py-1.5 text-[12px] font-medium text-graphite hover:bg-mist">Otevřít v Stripe</button>
        </form>
      )}
    </div>
    <div class="p-8 text-center">
      <p class="text-[13px] text-slate">
        {club?.stripe_customer_id
          ? 'Pro stažení faktur otevřete Stripe Customer Portal výše.'
          : 'Žádné faktury zatím nevystaveny.'}
      </p>
    </div>
  </div>

  <p class="mt-5 text-[12px] text-slate">
    Fakturujeme jako <strong class="text-graphite">GameStatiq s.r.o.</strong> Pro změny fakturačních údajů kontaktujte <a href="mailto:hello@gamestatiq.com" class="text-signal hover:underline">hello@gamestatiq.com</a>.
  </p>
</AppLayout>
