---
import AppLayout from '../../layouts/AppLayout.astro';
import { getSupabaseAdmin } from '../../lib/supabase';

export const prerender = false;

const user = Astro.locals.user!;
const currentTeam = Astro.locals.team ?? null;
if (!currentTeam) return Astro.redirect('/app');

const admin = getSupabaseAdmin();

// Role check
const { data: cm } = await admin
  .from('club_members')
  .select('role')
  .eq('user_id', user.id)
  .eq('club_id', currentTeam.club_id)
  .maybeSingle();
const role = (cm as { role: string } | null)?.role ?? 'viewer';
const canEdit = role === 'admin' || role === 'coach';
const canDelete = role === 'admin' || role === 'coach';

// Fetch playbook actions for current team
const { data: actionsRaw } = await admin
  .from('playbook_actions')
  .select('id, name, category, active, sort_order, created_at')
  .eq('team_id', currentTeam.id)
  .order('sort_order', { ascending: true })
  .order('name', { ascending: true });
const actions = (actionsRaw ?? []) as Array<{
  id: string;
  name: string;
  category: string;
  active: boolean;
  sort_order: number;
  created_at: string;
}>;

// URL params
const url = new URL(Astro.request.url);
const saved = url.searchParams.get('saved');
const errorMsg = url.searchParams.get('error');
const editId = url.searchParams.get('edit');
const addMode = url.searchParams.get('add') === '1';
const filterCat = url.searchParams.get('cat') ?? 'all';

const editingAction = editId ? actions.find((a) => a.id === editId) : null;
const showForm = canEdit && (addMode || !!editingAction);

const SAVED_MSG: Record<string, string> = {
  created: '✓ Akce přidána do playbooku.',
  updated: '✓ Akce upravena.',
  deleted: '✓ Akce odebrána.',
};

const CATEGORY_LABEL: Record<string, string> = {
  run:     'Běh',
  pass:    'Pas',
  screen:  'Screen',
  special: 'Special',
  other:   'Ostatní',
};

const CATEGORY_COLOR: Record<string, string> = {
  run:     'bg-spark/15 text-[#A0531B]',
  pass:    'bg-signal/15 text-signal',
  screen:  'bg-sky/15 text-[#1B5E83]',
  special: 'bg-plum/15 text-[#4F3878]',
  other:   'bg-stone text-graphite',
};

const filtered = filterCat === 'all' ? actions : actions.filter((a) => a.category === filterCat);

// Group by category for stats
const byCategory = new Map<string, number>();
for (const a of actions) {
  byCategory.set(a.category, (byCategory.get(a.category) ?? 0) + 1);
}

const filterTabs = [
  { key: 'all',     label: 'Vše',     count: actions.length },
  { key: 'run',     label: 'Běh',     count: byCategory.get('run')     ?? 0 },
  { key: 'pass',    label: 'Pas',     count: byCategory.get('pass')    ?? 0 },
  { key: 'screen',  label: 'Screen',  count: byCategory.get('screen')  ?? 0 },
  { key: 'special', label: 'Special', count: byCategory.get('special') ?? 0 },
  { key: 'other',   label: 'Ostatní', count: byCategory.get('other')   ?? 0 },
];
---

<AppLayout
  title={`Playbook · ${currentTeam.name} · GameStatiq`}
  active="playbook"
  pageTitle="Playbook"
  pageSub={`${currentTeam.name} · ${actions.length} ${actions.length === 1 ? 'akce' : actions.length < 5 ? 'akce' : 'akcí'} · ${actions.filter((a) => a.active).length} aktivních`}
>

  {saved && SAVED_MSG[saved] && (
    <div class="mb-6 rounded-lg border border-verde/30 bg-verde/5 px-4 py-3 text-[14px] text-[#1B6E62]">{SAVED_MSG[saved]}</div>
  )}
  {errorMsg && (
    <div class="mb-6 rounded-lg border border-signal/30 bg-signal/5 px-4 py-3 text-[14px] text-signal">{errorMsg}</div>
  )}

  {!canEdit && (
    <div class="mb-6 rounded-lg border border-sky/30 bg-sky/5 px-4 py-3 text-[13px] text-[#1B5E83]">
      Vaše role <strong>{role}</strong> umožňuje pouze prohlížení. Pro úpravy je potřeba role Admin nebo Trenér.
    </div>
  )}

  <!-- Intro card -->
  <div class="mb-6 rounded-xl border border-plum/20 bg-gradient-to-br from-plum/5 to-signal/5 p-5">
    <p class="text-[14px] text-graphite">
      <strong class="text-ink">Playbook</strong> jsou předdefinované akce, které statistik vidí jako rychlá tlačítka ve Scorer PWA při zápisu zápasu.
      Místo psaní názvu akce stačí kliknout. Akce jsou per-tým — Muži, Ženy a U18 mají vlastní playbook.
    </p>
  </div>

  <!-- Filter tabs -->
  <div class="mb-5 flex flex-wrap gap-1 rounded-lg border border-stone bg-pearl p-1">
    {filterTabs.map((t) => {
      const isActive = filterCat === t.key;
      return (
        <a href={t.key === 'all' ? '/app/playbook' : `?cat=${t.key}`} class={`rounded-md px-3 py-1.5 text-[13px] font-medium transition-colors ${isActive ? 'bg-ink text-white' : 'text-graphite hover:bg-mist'}`}>
          {t.label}<span class="ml-1 text-[10px] opacity-70">({t.count})</span>
        </a>
      );
    })}
  </div>

  <!-- Add/Edit form -->
  {showForm && (
    <div id="playbook-form" class="mb-6 rounded-xl border border-plum/30 bg-gradient-to-br from-plum/5 to-signal/5 p-6">
      <p class="text-[15px] font-semibold tracking-tight-2 text-ink">{editingAction ? 'Upravit akci' : 'Přidat akci do playbooku'}</p>
      <p class="mt-1 text-[12px] text-graphite">Akce se zobrazí ve Scorer PWA jako klikatelné tlačítko při zápisu plays.</p>

      <form method="POST" action={editingAction ? '/api/club/playbook/update' : '/api/club/playbook/create'} class="mt-5 space-y-4">
        {editingAction && <input type="hidden" name="id" value={editingAction.id} />}

        <div class="grid gap-4 sm:grid-cols-[1fr_180px_120px]">
          <label class="block">
            <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Název akce *</span>
            <input type="text" name="name" required maxlength="80" value={editingAction?.name ?? ''} placeholder="Slant · 04 · Sweep right" class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[14px] text-ink focus:border-plum focus:outline-none focus:ring-2 focus:ring-plum/20" />
          </label>
          <label class="block">
            <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Kategorie</span>
            <select name="category" class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[13px] text-ink">
              <option value="run"     selected={editingAction?.category === 'run'}>Běh</option>
              <option value="pass"    selected={editingAction?.category === 'pass'}>Pas</option>
              <option value="screen"  selected={editingAction?.category === 'screen'}>Screen</option>
              <option value="special" selected={editingAction?.category === 'special'}>Special</option>
              <option value="other"   selected={(!editingAction || editingAction.category === 'other')}>Ostatní</option>
            </select>
          </label>
          <label class="block">
            <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-slate">Pořadí</span>
            <input type="number" name="sort_order" value={editingAction?.sort_order ?? 0} step="1" class="mt-1.5 block w-full rounded-lg border border-stone bg-pearl px-3 py-2.5 text-[14px] tabular-nums text-ink" />
          </label>
        </div>

        {editingAction && (
          <label class="flex items-center gap-2">
            <input type="checkbox" name="active" checked={editingAction.active} class="h-4 w-4 rounded border-stone text-plum focus:ring-plum/30" />
            <span class="text-[13px] text-graphite">Aktivní — zobrazí se ve Scorer PWA</span>
          </label>
        )}

        <div class="flex flex-wrap items-center gap-3 pt-2">
          <button type="submit" class="rounded-lg bg-plum px-4 py-2.5 text-[13px] font-semibold text-white hover:bg-[#3F2B68]">{editingAction ? 'Uložit změny' : 'Přidat akci'}</button>
          <a href="/app/playbook" class="text-[13px] font-medium text-graphite hover:text-ink">Zrušit</a>
        </div>
      </form>
    </div>
  )}

  <!-- Playbook list -->
  <div class="rounded-xl border border-stone bg-pearl">
    <div class="flex flex-wrap items-center justify-between gap-3 border-b border-stone px-5 py-4">
      <div>
        <p class="text-[15px] font-semibold tracking-tight-2 text-ink">
          {filterCat === 'all' ? 'Všechny akce' : CATEGORY_LABEL[filterCat]}
        </p>
        <p class="text-[12px] text-slate">{filtered.length} v této kategorii</p>
      </div>
      {canEdit && !addMode && !editingAction && (
        <a href="/app/playbook?add=1#playbook-form" class="rounded-lg bg-plum px-4 py-2 text-[13px] font-semibold text-white hover:bg-[#3F2B68]">+ Přidat akci</a>
      )}
    </div>

    {filtered.length === 0 ? (
      <div class="p-12 text-center">
        <p class="text-[14px] font-semibold text-ink">
          {actions.length === 0 ? 'Playbook je prázdný' : 'Žádná akce v této kategorii'}
        </p>
        <p class="mt-1 text-[13px] text-slate">
          {actions.length === 0
            ? (canEdit ? 'Klikni "+ Přidat akci" a začněte budovat playbook.' : 'Admin nebo trenér musí přidat akce.')
            : 'Zkuste jinou kategorii nebo přidejte akci.'}
        </p>
      </div>
    ) : (
      <ul class="divide-y divide-stone">
        {filtered.map((a) => (
          <li class="flex flex-wrap items-center gap-4 px-5 py-3.5">
            <span class="font-mono text-[12px] tabular-nums text-stone-2 w-8">#{a.sort_order}</span>
            <div class="min-w-0 flex-1">
              <p class="flex items-center gap-2">
                <span class={`text-[14px] font-semibold ${a.active ? 'text-ink' : 'text-stone-2 line-through'}`}>{a.name}</span>
                {!a.active && <span class="rounded bg-stone px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-slate">Skryto</span>}
              </p>
            </div>
            <span class={`inline-flex items-center rounded-md px-2 py-0.5 text-[11px] font-semibold ${CATEGORY_COLOR[a.category] ?? 'bg-stone text-graphite'}`}>{CATEGORY_LABEL[a.category] ?? a.category}</span>
            {canEdit && (
              <div class="flex items-center gap-2">
                <a href={`/app/playbook?edit=${a.id}#playbook-form`} class="rounded-md border border-stone bg-pearl px-3 py-1.5 text-[11px] font-medium text-graphite hover:bg-mist">Upravit</a>
                {canDelete && (
                  <form method="POST" action="/api/club/playbook/remove" class="inline">
                    <input type="hidden" name="id" value={a.id} />
                    <button type="submit" onclick={`return confirm('Smazat akci "${a.name}"?');`} class="rounded-md border border-stone bg-pearl px-3 py-1.5 text-[11px] font-medium text-graphite hover:border-signal/40 hover:text-signal">Smazat</button>
                  </form>
                )}
              </div>
            )}
          </li>
        ))}
      </ul>
    )}
  </div>

  <p class="mt-4 text-[11px] text-stone-2">
    Tip: Pořadí (#) určuje sortování ve Scoreru. Nižší číslo = výš. Stejné číslo = řadí abecedně.
  </p>
</AppLayout>

<script is:inline>
  // Scroll to form if edit or add param present
  const _qs = new URLSearchParams(location.search);
  if (_qs.get('edit') || _qs.get('add')) {
    document.getElementById('playbook-form')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
</script>
