---
import AppLayout from '../../layouts/AppLayout.astro';
import { fetchPublicStats } from '../../lib/bobcats';

export const prerender = false;

const stats = await fetchPublicStats('Muži');

type Row = {
  number: number | string;
  name: string;
  position: 'QB' | 'WR' | 'DB';
  primary: string;
  photoUrl?: string;
};

const rows: Row[] = [];
const seen = new Set<string>();
const addRow = (r: Row) => {
  if (seen.has(r.name)) return;
  seen.add(r.name);
  rows.push(r);
};

if (stats) {
  for (const p of stats.qbStats) {
    addRow({
      number: p.jersey,
      name: p.name,
      position: 'QB',
      primary: `${p.qb.td} TD · ${p.qb.comp}/${p.qb.att} cmp · ${p.qb.yds} yds`,
      photoUrl: p.photoUrl,
    });
  }
  for (const p of stats.wrStats) {
    addRow({
      number: p.jersey,
      name: p.name,
      position: 'WR',
      primary: `${p.wr.td} TD · ${p.wr.rec}/${p.wr.targets} cmp · ${p.wr.pts} bodů`,
      photoUrl: p.photoUrl,
    });
  }
  for (const p of stats.defenseLeaders) {
    addRow({
      number: p.jersey,
      name: p.name,
      position: 'DB',
      primary: `${p.db.flagPull} flag pull · ${p.db.int} INT · ${p.db.sack} sack · ${p.db.brkup} brkup`,
      photoUrl: p.photoUrl,
    });
  }
}

const posColor: Record<string, string> = {
  QB: 'bg-signal/15 text-signal',
  WR: 'bg-sky/15 text-[#1B5E83]',
  DB: 'bg-verde/15 text-[#1B6E62]',
};
---

<AppLayout
  title="Soupiska · GameStatiq"
  active="players"
  pageTitle="Soupiska"
  pageSub={stats ? `Bobcats Muži · ${rows.length} hráčů ve statistikách · sezóna 2026` : 'Načítám hráče…'}
>
  {!stats && (
    <div class="mb-6 rounded-lg border border-spark/30 bg-spark/5 px-4 py-3 text-[14px] text-[#A0531B]">
      Nepodařilo se načíst live data ze Sheets. Zkuste obnovit stránku.
    </div>
  )}

  <div class="mb-5 flex flex-wrap items-center gap-2">
    <button class="rounded-full bg-ink px-3 py-1.5 text-[12px] font-medium text-white">Všichni ({rows.length})</button>
    <button class="rounded-full border border-stone bg-pearl px-3 py-1.5 text-[12px] font-medium text-graphite hover:bg-mist">Útok ({rows.filter(r => r.position === 'QB' || r.position === 'WR').length})</button>
    <button class="rounded-full border border-stone bg-pearl px-3 py-1.5 text-[12px] font-medium text-graphite hover:bg-mist">Obrana ({rows.filter(r => r.position === 'DB').length})</button>
    <span class="ml-auto inline-flex items-center gap-2">
      <button disabled class="cursor-not-allowed rounded-lg border border-stone bg-mist px-3 py-1.5 text-[12px] font-medium text-stone-2">+ Přidat hráče</button>
      <span class="rounded-md bg-signal/10 px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.1em] text-signal">Liga tier ↗</span>
    </span>
  </div>

  <div class="overflow-x-auto rounded-xl border border-stone bg-pearl">
    <table class="w-full min-w-[720px] text-left text-[14px]">
      <thead class="border-b border-stone bg-mist text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">
        <tr>
          <th class="px-5 py-3">#</th>
          <th class="py-3">Hráč</th>
          <th class="px-3 py-3">Pozice</th>
          <th class="py-3">Hlavní stat (sezóna)</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-stone">
        {rows.length === 0 ? (
          <tr><td colspan="5" class="px-5 py-12 text-center text-[13px] text-slate">Zatím žádní hráči ve statistikách.</td></tr>
        ) : (
          rows.map((p) => (
            <tr class="transition-colors hover:bg-mist/60">
              <td class="px-5 py-3.5">
                <span class="font-mono text-[14px] font-bold tabular-nums text-graphite">#{p.number}</span>
              </td>
              <td class="py-3.5">
                <div class="flex items-center gap-3">
                  {p.photoUrl ? (
                    <img src={p.photoUrl} alt="" loading="lazy" class="h-8 w-8 flex-shrink-0 rounded-full object-cover" />
                  ) : (
                    <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-ink/5 text-[11px] font-semibold text-ink">{p.name.split(' ').map((w) => w[0]).join('').slice(0, 2)}</span>
                  )}
                  <p class="text-[14px] font-semibold tracking-tight-2 text-ink">{p.name}</p>
                </div>
              </td>
              <td class="px-3 py-3.5">
                <span class={`inline-flex items-center rounded-md px-2 py-0.5 text-[11px] font-semibold ${posColor[p.position]}`}>{p.position}</span>
              </td>
              <td class="py-3.5 text-[13px] text-graphite">{p.primary}</td>
              <td class="px-5 py-3.5 text-right">
                <button class="text-[12px] font-semibold text-slate hover:text-ink">Detail →</button>
              </td>
            </tr>
          ))
        )}
      </tbody>
    </table>
  </div>

  <p class="mt-4 text-[12px] text-slate">
    Data se synchronizují automaticky ze Scorer appky přes Google Sheets. Pro editaci profilu hráče upgradujte na tier <strong class="text-graphite">Liga</strong>.
  </p>
</AppLayout>
