---
import AppLayout from '../../../layouts/AppLayout.astro';
import PlayerStatRow from '../../../components/PlayerStatRow.astro';
import { getSupabaseAdmin } from '../../../lib/supabase';

export const prerender = false;

const user = Astro.locals.user!;
const id = Astro.params.id;
if (!id) return Astro.redirect('/app/matches');

const admin = getSupabaseAdmin();

const { data: match } = await admin
  .from('matches')
  .select('*, teams(id, name, club_id, clubs(name)), opp_team:teams!matches_opp_team_id_fkey(id, name, club_id, clubs(name))')
  .eq('id', id)
  .maybeSingle();
if (!match) return Astro.redirect('/app/matches');

const team = (match as any).teams;
const club = team?.clubs;
const oppTeam = (match as any).opp_team;
const oppClub = oppTeam?.clubs;

// Iter 33: user může být buď v klubu home teamu (full access), nebo opp teamu (read-only shared view)
const currentTeam = Astro.locals.team ?? null;
const currentTeamId = currentTeam?.id ?? null;
const isOppView = !!(oppTeam && currentTeamId && oppTeam.id === currentTeamId);

// Verify user has access — try home team's club first, then opp team's club
let role: string | null = null;
let accessClubId: string | null = null;
{
  const { data: cm } = await admin
    .from('club_members')
    .select('role')
    .eq('club_id', (match as any).club_id)
    .eq('user_id', user.id)
    .maybeSingle();
  if (cm?.role) {
    role = cm.role;
    accessClubId = (match as any).club_id;
  }
}
if (!role && oppTeam?.club_id) {
  const { data: cm2 } = await admin
    .from('club_members')
    .select('role')
    .eq('club_id', oppTeam.club_id)
    .eq('user_id', user.id)
    .maybeSingle();
  if (cm2?.role) {
    role = cm2.role;
    accessClubId = oppTeam.club_id;
  }
}

// Iter 67: liga admin / staff může editovat zápasy v jeho lize (přes league_members nebo league.owner)
let isLeagueAdminAccess = false;
if (!role) {
  // Najdi liga(s) kde je match (team nebo opp_team)
  const teamIdsToCheck = [(match as any).team_id, (match as any).opp_team_id].filter(Boolean);
  if (teamIdsToCheck.length > 0) {
    const { data: leagueTeams } = await admin
      .from('league_teams')
      .select('league_id')
      .in('team_id', teamIdsToCheck)
      .not('approved_at', 'is', null);
    const leagueIds = (leagueTeams ?? []).map((r: any) => r.league_id);
    if (leagueIds.length > 0) {
      // Liga owner check
      const { data: ownedLeagues } = await admin
        .from('leagues')
        .select('id')
        .in('id', leagueIds)
        .eq('owner_user_id', user.id);
      if (ownedLeagues && ownedLeagues.length > 0) {
        role = 'admin';
        isLeagueAdminAccess = true;
      }
      // League_members admin/staff check
      if (!role) {
        const { data: lm } = await admin
          .from('league_members')
          .select('role')
          .in('league_id', leagueIds)
          .eq('user_id', user.id)
          .in('role', ['admin', 'staff']);
        if (lm && lm.length > 0) {
          role = (lm[0] as any).role === 'admin' ? 'admin' : 'stats';
          isLeagueAdminAccess = true;
        }
      }
    }
  }
}

if (!role) return Astro.redirect('/app/matches');

// V opp view je vždy read-only (zápas patří jinému klubu)
const canEdit   = !isOppView && (role === 'admin' || role === 'coach' || role === 'stats');
const canDelete = !isOppView && (role === 'admin');
const readOnly  = !canEdit;

// Per-match player stats with player metadata
const { data: psRaw } = await admin
  .from('match_player_stats')
  .select(`
    match_id, player_id,
    qb_att, qb_comp, qb_yds, qb_td, qb_int, qb_sack,
    wr_targets, wr_rec, wr_yds, wr_td, wr_xp, wr_pts,
    db_flag_pull, db_sack, db_brkup, db_int,
    players ( first_name, last_name, jersey_number, position, team_id )
  `)
  .eq('match_id', id);
const ps = (psRaw ?? []) as any[];

// Iter 34: rozdělit stats podle team_id (shared match — keeper zapsal za oba)
const homeTeamId = (match as any).team_id;
const oppTeamId  = (match as any).opp_team_id;
const psHome = ps.filter((r) => r.players?.team_id === homeTeamId);
const psOpp  = oppTeamId ? ps.filter((r) => r.players?.team_id === oppTeamId) : [];
const psOther = ps.filter((r) => r.players?.team_id !== homeTeamId && r.players?.team_id !== oppTeamId);

// Iter 34: available players pro picker — z obou rosterů pokud shared match
const { data: teamPlayers } = await admin
  .from('players')
  .select('id, first_name, last_name, jersey_number, position, team_id')
  .in('team_id', oppTeamId ? [homeTeamId, oppTeamId] : [homeTeamId])
  .order('jersey_number', { ascending: true, nullsLast: true });
const playersInStats = new Set(ps.map((r) => r.player_id));
const availablePlayers = ((teamPlayers ?? []) as any[]).filter((p) => !playersInStats.has(p.id));

const url = new URL(Astro.request.url);
const saved = url.searchParams.get('saved');
const errorMsg = url.searchParams.get('error');
const SAVED_MSG: Record<string, string> = {
  '1':       '✓ Změny uloženy.',
  stats:     '✓ Statistiky hráče uloženy.',
  added:     '✓ Hráč přidán do statistik.',
  removed:   '✓ Hráč odebrán ze statistik.',
};

const roleLabel: Record<string, string> = { admin: 'Admin', coach: 'Trenér', stats: 'Statistik', viewer: 'Pozorovatel' };

// Iter 33: v opp view zobrazujeme zápas z pohledu soupeře — zrcadlové skóre + odpovídající soupeř
const homeLabel = team?.clubs?.name ? `${team.clubs.name}${team?.name ? ' ' + team.name : ''}` : (team?.name || '—');
const displayOpponent = isOppView ? homeLabel : match.opponent;
const displayOur = isOppView ? match.opp_score : match.our_score;
const displayOpp = isOppView ? match.our_score : match.opp_score;
---

<AppLayout
  title={`vs ${displayOpponent} · ${currentTeam?.name ?? team?.name ?? ''}`}
  active="matches"
  pageTitle={`vs ${displayOpponent}`}
  pageSub={`${new Date(match.date).toLocaleDateString('cs-CZ')} · ${currentTeam?.name ?? team?.name ?? '—'} · skóre ${displayOur}–${displayOpp} · vy: ${roleLabel[role] ?? role}${isOppView ? ' · sdílený zápas' : ''}`}
>

  {saved && SAVED_MSG[saved] && <div class="mb-6 rounded-lg border border-verde/30 bg-verde/5 px-4 py-3 text-[14px] text-[#1B6E62]">{SAVED_MSG[saved]}</div>}
  {errorMsg && <div class="mb-6 rounded-lg border border-signal/30 bg-signal/5 px-4 py-3 text-[14px] text-signal">{errorMsg}</div>}

  <div class="mb-6 flex flex-wrap items-center gap-2 text-[13px]">
    <a href="/app/matches" class="rounded-md border border-stone bg-pearl px-3 py-1.5 font-medium text-graphite hover:bg-mist">← Všechny zápasy</a>
  </div>

  {isOppView && (
    <div class="mb-6 rounded-lg border border-sky/30 bg-sky/5 px-4 py-3 text-[13px] text-[#1B5E83]">
      <strong>Sdílený zápas v lize</strong> — zapsal {team?.clubs?.name ?? '—'} {team?.name ?? ''}. Pro vás je tento záznam pouze ke čtení; statistiky a hráče zobrazené níže patří hostujícímu týmu.
    </div>
  )}
  {readOnly && !isOppView && (
    <div class="mb-6 rounded-lg border border-sky/30 bg-sky/5 px-4 py-3 text-[13px] text-[#1B5E83]">
      Vaše role <strong>{roleLabel[role] ?? role}</strong> umožňuje pouze prohlížení. Pro úpravy je potřeba role Admin, Trenér, nebo Statistik.
    </div>
  )}

  <!-- Match-level edit form -->
  <div class="rounded-xl border border-stone bg-pearl">
    <div class="border-b border-stone px-5 py-4">
      <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Zápasové statistiky</p>
      <p class="text-[12px] text-slate">Korekce hodnot zápisu — pro opravu chybně zapsaných hodnot z PWA Scoreru</p>
    </div>
    <form method="POST" action="/api/club/match/update" class="p-5">
      <input type="hidden" name="match_id" value={match.id} />

      <div class="grid gap-4 sm:grid-cols-3">
        <label class="block">
          <span class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">Datum</span>
          <input type="date" name="date" value={match.date} readonly={readOnly} class="mt-1.5 block w-full rounded-md border border-stone bg-pearl px-3 py-2 text-[13px]" />
        </label>
        <label class="block sm:col-span-2">
          <span class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">Soupeř</span>
          <input type="text" name="opponent" value={match.opponent} readonly={readOnly} class="mt-1.5 block w-full rounded-md border border-stone bg-pearl px-3 py-2 text-[13px]" />
        </label>
      </div>

      <p class="mt-6 text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">Skóre + drives</p>
      <div class="mt-2 grid gap-3 sm:grid-cols-4">
        {[
          ['our_score', 'Naše skóre'], ['opp_score', 'Soupeřovo skóre'],
          ['off_drives', 'Útočné drives'], ['off_td', 'Útočné TD'],
          ['def_drives', 'Defenzivní drives'], ['def_stops', 'Defenzivní stops'],
          ['rush_yds', 'Rush yds'], ['pass_yds', 'Pass yds'],
          ['total_yds', 'Total yds'],
          ['opp_rush_yds', 'Opp rush'], ['opp_pass_yds', 'Opp pass'], ['opp_total_yds', 'Opp total'],
        ].map(([k, label]) => (
          <label class="block">
            <span class="text-[10px] uppercase tracking-wider text-stone-2">{label}</span>
            <input type="number" min="0" name={k} value={(match as any)[k] ?? 0} readonly={readOnly} class="mt-1 block w-full rounded-md border border-stone bg-pearl px-2 py-1.5 text-[13px] tabular-nums" />
          </label>
        ))}
      </div>

      <p class="mt-6 text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">QB team agg + naše XP + fauly</p>
      <div class="mt-2 grid gap-3 sm:grid-cols-4">
        {[
          ['qb_att', 'QB ATT'], ['qb_comp', 'QB COMP'], ['qb_yds', 'QB YDS'],
          ['qb_td', 'QB TD'], ['qb_int', 'QB INT'],
          ['xp1_att', '1XP ATT'], ['xp1_ok', '1XP OK'],
          ['xp2_att', '2XP ATT'], ['xp2_ok', '2XP OK'],
          ['pen_count', 'Fauly count'], ['pen_yds', 'Fauly yds'],
        ].map(([k, label]) => (
          <label class="block">
            <span class="text-[10px] uppercase tracking-wider text-stone-2">{label}</span>
            <input type="number" min="0" name={k} value={(match as any)[k] ?? 0} readonly={readOnly} class="mt-1 block w-full rounded-md border border-stone bg-pearl px-2 py-1.5 text-[13px] tabular-nums" />
          </label>
        ))}
      </div>

      {/* Iter 24: Soupeřovy XP konverze (kolik soupeř proměnil / pokusil) */}
      <p class="mt-6 text-[11px] font-semibold uppercase tracking-[0.08em] text-slate">Soupeřovy XP konverze (defense)</p>
      <div class="mt-2 grid gap-3 sm:grid-cols-4">
        {[
          ['opp_xp1_att', 'Opp 1XP ATT'], ['opp_xp1_ok', 'Opp 1XP OK'],
          ['opp_xp2_att', 'Opp 2XP ATT'], ['opp_xp2_ok', 'Opp 2XP OK'],
        ].map(([k, label]) => (
          <label class="block">
            <span class="text-[10px] uppercase tracking-wider text-stone-2">{label}</span>
            <input type="number" min="0" name={k} value={(match as any)[k] ?? 0} readonly={readOnly} class="mt-1 block w-full rounded-md border border-stone bg-pearl px-2 py-1.5 text-[13px] tabular-nums" />
          </label>
        ))}
      </div>

      {canEdit && (
        <div class="mt-6">
          <button type="submit" class="rounded-md bg-signal px-4 py-2 text-[13px] font-semibold text-white hover:bg-[#C8313D]">Uložit změny zápasu</button>
        </div>
      )}
    </form>

    {canDelete && (
      <div class="border-t border-stone bg-mist/40 px-5 py-3">
        <form method="POST" action="/api/club/match/delete" onsubmit="return confirm('Smazat zápas včetně všech player stats, plays, faulů a drives? Nevratné.')">
          <input type="hidden" name="match_id" value={match.id} />
          <button type="submit" class="rounded-md border border-signal/40 bg-signal/5 px-3 py-2 text-[12px] font-semibold text-signal hover:bg-signal hover:text-white">Smazat celý zápas (jen Admin)</button>
        </form>
      </div>
    )}
  </div>

  <!-- Per-player stats: editable -->
  <div class="mt-8 rounded-xl border border-stone bg-pearl">
    <div class="flex items-center justify-between border-b border-stone px-5 py-4">
      <div>
        <p class="text-[15px] font-semibold tracking-tight-2 text-ink">Per-hráč statistiky</p>
        <p class="text-[12px] text-slate">{ps.length} hráčů · upravte čísla a klikněte Uložit u řádku{oppTeam ? ' · zápas má hráče obou týmů' : ''}</p>
      </div>
    </div>

    {canEdit && availablePlayers.length > 0 && (
      <div class="border-b border-stone bg-mist/40 px-5 py-3">
        <form method="POST" action="/api/club/match/add-player-stat" class="flex flex-wrap items-end gap-2">
          <input type="hidden" name="match_id" value={match.id} />
          <label class="block flex-1 min-w-[260px]">
            <span class="text-[10px] uppercase tracking-wider text-slate">Přidat hráče{oppTeam ? ' (z home nebo opp rosteru)' : ` (z ${team?.name} rosteru)`}</span>
            <select name="player_id" required class="mt-1 block w-full rounded-md border border-stone bg-pearl px-3 py-1.5 text-[13px]">
              <option value="">— vyberte hráče —</option>
              {availablePlayers.map((p: any) => {
                const teamLabel = oppTeam && p.team_id === oppTeamId ? ` [${oppTeam.name}]` : (oppTeam ? ` [${team?.name}]` : '');
                return <option value={p.id}>#{p.jersey_number ?? '—'} {p.first_name} {p.last_name ?? ''} ({p.position}){teamLabel}</option>;
              })}
            </select>
          </label>
          <button type="submit" class="rounded-md bg-signal px-3 py-1.5 text-[12px] font-semibold text-white hover:bg-[#C8313D]">+ Přidat do statistik</button>
        </form>
      </div>
    )}

    {ps.length === 0 ? (
      <div class="p-8 text-center text-[13px] text-slate">Žádné per-hráč staty.</div>
    ) : (
      <div class="divide-y-2 divide-stone">
        {/* Iter 34: dual-team stats — home tým sekce */}
        {psHome.length > 0 && (
          <div>
            {oppTeam && (
              <div class="bg-mist/60 px-5 py-2 text-[11px] font-semibold uppercase tracking-wide text-graphite">
                {team?.clubs?.name ?? ''} {team?.name ?? '—'} · {psHome.length} hráčů
              </div>
            )}
            <div class="divide-y divide-stone">
              {psHome.map((row: any) => <PlayerStatRow row={row} canEdit={canEdit} readOnly={readOnly} />)}
            </div>
          </div>
        )}
        {/* Iter 34: opp tým sekce — jen u shared matchů */}
        {psOpp.length > 0 && (
          <div>
            <div class="bg-sky/10 px-5 py-2 text-[11px] font-semibold uppercase tracking-wide text-[#1B5E83]">
              {oppTeam?.clubs?.name ?? ''} {oppTeam?.name ?? '—'} · {psOpp.length} hráčů (soupeř)
            </div>
            <div class="divide-y divide-stone">
              {psOpp.map((row: any) => <PlayerStatRow row={row} canEdit={canEdit} readOnly={readOnly} />)}
            </div>
          </div>
        )}
        {/* Fallback: hráči s neidentifikovatelným týmem (legacy data) */}
        {psOther.length > 0 && (
          <div>
            <div class="bg-stone/30 px-5 py-2 text-[11px] font-semibold uppercase tracking-wide text-slate">Ostatní · {psOther.length} hráčů</div>
            <div class="divide-y divide-stone">
              {psOther.map((row: any) => <PlayerStatRow row={row} canEdit={canEdit} readOnly={readOnly} />)}
            </div>
          </div>
        )}
      </div>
    )}
  </div>
</AppLayout>
