---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const features = [
  { id: 'f1', iconPath: 'M3 3v18h18 M7 13h3v6 M13 9h3v10 M19 5h3v14', accent: 'sky' },
  { id: 'f2', iconPath: 'M9 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z M3 21v-1a5 5 0 0 1 5-5h2a5 5 0 0 1 5 5v1 M16 3.13a4 4 0 0 1 0 7.75 M21 21v-1a5 5 0 0 0-3-4.58', accent: 'signal' },
  { id: 'f3', iconPath: 'M8 4v16 M8 4h12l-3 5 3 5H8', accent: 'verde' },
  { id: 'f4', iconPath: 'M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0Z M12 3v9l5 3', accent: 'spark' },
  { id: 'f5', iconPath: 'M3 7h18 M5 11h14 M7 15h10 M9 19h6', accent: 'plum' },
  { id: 'f6', iconPath: 'M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2Z M17 21v-8H7v8 M7 3v5h8', accent: 'sky' },
] as const;

const accentBgClass: Record<string, string> = {
  signal: 'bg-signal/10 text-signal',
  sky:    'bg-sky/15  text-[#1B5E83]',
  verde:  'bg-verde/15 text-[#1B6E62]',
  spark:  'bg-spark/15 text-[#A0531B]',
  plum:   'bg-plum/15 text-[#4F3878]',
};
---

<section id="features" class="bg-mist py-20 lg:py-28">
  <div class="container-pm">
    <div class="max-w-2xl">
      <p class="eyebrow">{t('features.eyebrow')}</p>
      <h2 class="h-section mt-3">{t('features.title')}</h2>
      <p class="lead mt-4">
        {t('features.lead')}
      </p>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f) => (
          <div class="rounded-xl border border-stone bg-pearl p-6 transition-colors hover:border-stone-2">
            <div class={`inline-flex h-10 w-10 items-center justify-center rounded-lg ${accentBgClass[f.accent]}`}>
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d={f.iconPath} />
              </svg>
            </div>
            <h3 class="mt-4 text-[17px] font-semibold tracking-tight-2 text-ink">{t(`features.${f.id}.title` as any)}</h3>
            <p class="mt-2 text-[14px] leading-relaxed text-graphite">{t(`features.${f.id}.body` as any)}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
