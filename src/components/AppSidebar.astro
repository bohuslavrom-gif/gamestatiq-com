---
import { getSupabaseAdmin, type Club } from '../lib/supabase';

interface Props {
  active?: 'dashboard' | 'stats' | 'players' | 'billing' | 'settings';
}
const { active = 'dashboard' } = Astro.props;

const user = Astro.locals.user;
let userName = '—';
let userInitials = '—';
let userRole = 'Admin';
let club: { name: string; sport: string | null; abbr: string; logoUrl: string | null } | null = null;

if (user) {
  const admin = getSupabaseAdmin();
  const { data: profile } = await admin
    .from('profiles')
    .select('first_name,last_name,email')
    .eq('id', user.id)
    .maybeSingle();
  const fn = profile?.first_name ?? '';
  const ln = profile?.last_name ?? '';
  userName = (fn + ' ' + ln).trim() || (profile?.email ?? user.email ?? '—');
  userInitials = ((fn[0] ?? '') + (ln[0] ?? '')).toUpperCase() || (user.email?.[0] ?? '?').toUpperCase();

  const { data: membership } = await admin
    .from('club_members')
    .select('role, clubs(name, sport, logo_url)')
    .eq('user_id', user.id)
    .order('created_at', { ascending: true })
    .limit(1)
    .maybeSingle();
  if (membership) {
    userRole = ({ admin: 'Admin', coach: 'Trenér', stats: 'Statistik', viewer: 'Pozorovatel' } as Record<string, string>)[membership.role] ?? 'Admin';
    const c = (membership as any).clubs as Pick<Club, 'name' | 'sport' | 'logo_url'> | null;
    if (c) {
      const abbr = c.name.replace(/[^A-Za-zÀ-ž]/g, '').slice(0, 3).toUpperCase() || 'KLB';
      club = { name: c.name, sport: c.sport, abbr, logoUrl: c.logo_url };
    }
  }
}

const navItems = [
  { key: 'dashboard', label: 'Dashboard',  href: '/app',          icon: 'M3 12l9-9 9 9 M5 10v10h14V10' },
  { key: 'stats',     label: 'Statistiky', href: '/app/stats',    icon: 'M3 3v18h18 M7 13h3v6 M13 9h3v10 M19 5h3v14' },
  { key: 'players',   label: 'Soupiska',   href: '/app/players',  icon: 'M9 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z M3 21v-1a5 5 0 0 1 5-5h2a5 5 0 0 1 5 5v1' },
  { key: 'billing',   label: 'Předplatné', href: '/app/billing',  icon: 'M3 7h18 M3 12h18 M3 17h18' },
  { key: 'settings',  label: 'Nastavení',  href: '/app/settings', icon: 'M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1Z' },
];

// ── Multi-team Iter 2: derived UI props for team switcher ──
const teams = Astro.locals.teams ?? [];
const currentTeam = Astro.locals.team ?? null;
const isMultiTeam = teams.length > 1;
const currentTeamId = currentTeam?.id ?? null;
const teamAbbr =
  currentTeam?.name?.replace(/[^A-Za-zÀ-ž]/g, '').slice(0, 3).toUpperCase()
  || club?.abbr || '?';
const teamSeason = currentTeam?.season ?? '2026';
const teamDisplayName = currentTeam?.name ?? club?.name ?? 'Vyberte klub';
const teamSportLabel  = currentTeam?.sport ?? club?.sport ?? '—';
const teamLogo        = currentTeam?.logo_url ?? club?.logoUrl ?? null;
---

<aside class="app-sidebar fixed inset-y-0 left-0 z-30 w-64 flex-shrink-0 -translate-x-full transform border-r border-stone bg-pearl transition-transform duration-200 lg:translate-x-0">
  <div class="flex h-full flex-col">
    <div class="flex h-16 items-center gap-2.5 border-b border-stone px-5">
      <img src="/brand/gamestatiq-icon.svg" alt="" class="h-7 w-7" width="28" height="28" />
      <span class="text-[17px] font-semibold tracking-tight-2">
        Game<span class="font-bold text-signal">Statiq</span>
      </span>
    </div>

    <div class="border-b border-stone px-3 py-4">
      {!isMultiTeam && (
        <div class="flex w-full items-center gap-3 rounded-lg px-2 py-2 text-left">
          {teamLogo ? (
            <img src={teamLogo} alt="" class="h-9 w-9 rounded-lg bg-mist object-contain" />
          ) : (
            <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-ink text-[11px] font-bold tracking-[0.04em] text-white">{teamAbbr}</span>
          )}
          <div class="min-w-0 flex-1">
            <p class="truncate text-[14px] font-semibold tracking-tight-2 text-ink">{teamDisplayName}</p>
            <p class="truncate text-[11px] text-slate">{teamSportLabel} · sezóna {teamSeason}</p>
          </div>
        </div>
      )}

      {isMultiTeam && (
        <details class="group">
          <summary class="flex w-full cursor-pointer items-center gap-3 list-none rounded-lg px-2 py-2 text-left transition-colors hover:bg-mist [&::-webkit-details-marker]:hidden">
            {teamLogo ? (
              <img src={teamLogo} alt="" class="h-9 w-9 rounded-lg bg-mist object-contain" />
            ) : (
              <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-ink text-[11px] font-bold tracking-[0.04em] text-white">{teamAbbr}</span>
            )}
            <div class="min-w-0 flex-1">
              <p class="truncate text-[14px] font-semibold tracking-tight-2 text-ink">{teamDisplayName}</p>
              <p class="truncate text-[11px] text-slate">{teamSportLabel} · {teams.length} týmů</p>
            </div>
            <svg class="h-4 w-4 flex-shrink-0 text-slate transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="mt-2 space-y-0.5 rounded-lg border border-stone bg-pearl p-1">
            {teams.map((t) => {
              const isActive = t.id === currentTeamId;
              const abbr = t.name.replace(/[^A-Za-zÀ-ž]/g, '').slice(0, 3).toUpperCase() || '?';
              return (
                <a
                  href={`/app?team=${t.id}`}
                  class={`flex items-center gap-3 rounded-md px-2 py-2 transition-colors ${isActive ? 'bg-signal/10' : 'hover:bg-mist'}`}
                >
                  {t.logo_url ? (
                    <img src={t.logo_url} alt="" class="h-7 w-7 rounded-md bg-mist object-contain" />
                  ) : (
                    <span class="inline-flex h-7 w-7 items-center justify-center rounded-md bg-ink/80 text-[10px] font-bold tracking-[0.04em] text-white">{abbr}</span>
                  )}
                  <div class="min-w-0 flex-1">
                    <p class={`truncate text-[13px] font-semibold ${isActive ? 'text-signal' : 'text-ink'}`}>
                      {t.name}{t.is_archived && <span class="ml-1 text-[10px] uppercase tracking-wider text-stone-2">archiv</span>}
                    </p>
                    <p class="truncate text-[11px] text-slate">{t.sport} · {t.season ?? '2026'}</p>
                  </div>
                  {isActive && (
                    <svg class="h-3.5 w-3.5 flex-shrink-0 text-signal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>
                  )}
                </a>
              );
            })}
          </div>
        </details>
      )}
    </div>

    <nav class="flex-1 overflow-y-auto px-3 py-4">
      <ul class="space-y-0.5">
        {navItems.map((item) => {
          // Preserve ?team=<id> in nav links so team selection persists across routes
          const currentTeamId = Astro.locals.team?.id ?? null;
          const href = currentTeamId ? `${item.href}?team=${currentTeamId}` : item.href;
          return (
            <li>
              <a
                href={href}
                aria-current={active === item.key ? 'page' : undefined}
                class={`flex items-center gap-3 rounded-lg px-3 py-2.5 text-[14px] font-medium transition-colors ${
                  active === item.key
                    ? 'bg-signal/10 text-signal'
                    : 'text-graphite hover:bg-mist hover:text-ink'
                }`}
              >
                <svg class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d={item.icon} />
                </svg>
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>

      <a
        href="https://scorer.gamestatiq.com"
        target="_blank"
        rel="noopener"
        class="mt-6 flex items-center gap-3 rounded-lg border border-ink/10 bg-ink p-4 text-white transition-colors hover:bg-[#1A2B45]"
      >
        <span class="inline-flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-lg bg-signal text-white">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="6" width="20" height="12" rx="2"/>
            <path d="M8 10v4 M16 10v4 M12 9v6 M2 12h4 M18 12h4"/>
          </svg>
        </span>
        <div class="min-w-0 flex-1">
          <p class="text-[13px] font-semibold tracking-tight-2">Otevřít Scorer</p>
          <p class="text-[11px] text-white/60">Zapisování zápasu →</p>
        </div>
      </a>

      <div class="mt-3 rounded-lg border border-signal/20 bg-signal/5 p-4">
        <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-signal">Upgrade na Klub</p>
        <p class="mt-2 text-[12px] leading-relaxed text-graphite">
          Více týmů (Muži, Ženy, U18…), přepínání mezi nimi, sdílená správa hráčů.
        </p>
        <a href="/app/billing" class="mt-3 inline-flex items-center gap-1.5 text-[12px] font-semibold text-signal hover:underline">
          Zobrazit balíčky
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </nav>

    <div class="border-t border-stone p-3">
      <div class="flex items-center gap-3 rounded-lg px-2 py-2">
        <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-mist text-[12px] font-semibold text-ink">{userInitials}</span>
        <div class="min-w-0 flex-1">
          <p class="truncate text-[13px] font-semibold text-ink">{userName}</p>
          <p class="truncate text-[11px] text-slate">{userRole}</p>
        </div>
        <form method="POST" action="/api/auth/logout">
          <button type="submit" aria-label="Odhlásit se" class="text-slate hover:text-ink">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4 M16 17l5-5-5-5 M21 12H9" />
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</aside>
