<section id="contact" class="bg-ink py-20 lg:py-28 text-white">
  <div class="container-pm">
    <div class="grid items-center gap-12 lg:grid-cols-[1.1fr_1fr]">
      <div>
        <p class="eyebrow text-white/60">Kontakt</p>
        <h2 class="h-section mt-3 text-white">
          Připravte sezónu na <span class="text-signal">GameStatiq</span>.
        </h2>
        <p class="mt-5 max-w-xl text-[17px] leading-relaxed text-white/75">
          Napište nám jaký máte tým, kolik hráčů, a jakou ligu hrajete.
          Domluvíme 30minutové demo na míru a získáte 30denní free trial bez závazku.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="mailto:hello@gamestatiq.com?subject=Demo%20zdarma%20%E2%80%94%20[Vas%20klub]"
            class="inline-flex items-center justify-center gap-2 rounded-lg bg-signal px-6 py-3.5 text-[15px] font-semibold text-white transition-all hover:bg-[#C8313D] active:scale-[0.98]"
          >
            hello@gamestatiq.com
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="/liga"
            class="inline-flex items-center justify-center gap-2 rounded-lg border border-white/20 bg-white/[0.04] px-6 py-3.5 text-[15px] font-medium text-white transition-all hover:bg-white/10"
          >
            Zkusit live demo
          </a>
        </div>

        <p class="mt-6 text-sm text-white/50">
          Nebo napište přímo: <a class="text-white underline-offset-2 hover:underline" href="mailto:hello@gamestatiq.com">hello@gamestatiq.com</a>
        </p>
      </div>

      <!-- Quick "what's included" callout card -->
      <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-7">
        <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-signal">
          Co dostanete v prvních 30 dnech
        </p>
        <ul class="mt-5 space-y-3.5 text-[14px] text-white/85">
          <li class="flex items-start gap-3">
            <svg class="mt-[3px] h-4 w-4 flex-shrink-0 text-sky" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>
            <span><strong class="text-white">30min onboarding workshop</strong> — pomůžeme vám nastavit roster, playbook a Sheets</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="mt-[3px] h-4 w-4 flex-shrink-0 text-sky" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>
            <span><strong class="text-white">Trénink statistika</strong> — 1:1 session jak používat app během zápasu</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="mt-[3px] h-4 w-4 flex-shrink-0 text-sky" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>
            <span><strong class="text-white">Custom branding</strong> — váš klubový logo a barvy v public widgetu</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="mt-[3px] h-4 w-4 flex-shrink-0 text-sky" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>
            <span><strong class="text-white">Žádný závazek</strong> — kdykoli odejdete, vaše data v Sheets zůstávají</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
