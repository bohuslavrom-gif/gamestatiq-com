---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const steps = [
  { n: '01', id: 's1' },
  { n: '02', id: 's2' },
  { n: '03', id: 's3' },
  { n: '04', id: 's4' },
] as const;
---

<section id="how" class="bg-pearl py-20 lg:py-28">
  <div class="container-pm">
    <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="eyebrow">{t('how.eyebrow')}</p>
        <h2 class="h-section mt-3">{t('how.title')}</h2>
        <p class="lead mt-4 max-w-md">
          {t('how.lead')}
        </p>
      </div>

      <ol class="space-y-5">
        {
          steps.map((s) => (
            <li class="flex gap-5 rounded-xl border border-stone bg-mist p-5">
              <span class="font-mono text-[13px] font-semibold tracking-[0.05em] text-signal">
                {s.n}
              </span>
              <div>
                <h3 class="text-[16px] font-semibold tracking-tight-2 text-ink">{t(`how.${s.id}.title` as any)}</h3>
                <p class="mt-1.5 text-[14px] leading-relaxed text-graphite">{t(`how.${s.id}.body` as any)}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>
