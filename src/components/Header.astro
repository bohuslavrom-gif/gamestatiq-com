---
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navLinks = [
  { href: localizedPath('/', lang) + '#features', label: t('nav.features') },
  { href: localizedPath('/', lang) + '#how',      label: t('nav.how') },
  { href: localizedPath('/', lang) + '#pricing',  label: t('nav.pricing') },
  { href: localizedPath('/liga', lang),           label: t('nav.liga') },
];
const homeHref = localizedPath('/', lang);
const contactHref = localizedPath('/', lang) + '#contact';

const isLoggedIn = !!Astro.locals.user;
---

<header class="sticky top-0 z-40 border-b border-stone bg-pearl/85 backdrop-blur">
  <div class="container-pm flex h-16 items-center justify-between">
    <a href={homeHref} class="flex items-center gap-2.5" aria-label="GameStatiq">
      <img src="/brand/gamestatiq-icon.svg" alt="" width="28" height="28" class="h-7 w-7" />
      <span class="text-[17px] font-semibold tracking-tight-2">
        Game<span class="font-bold text-signal">Statiq</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-7 md:flex">
      {navLinks.map((link) => (
        <a href={link.href} class="text-[14px] font-medium text-graphite transition-colors hover:text-ink">
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <LanguageSwitcher />

      {isLoggedIn ? (
        <a
          href="/app"
          class="hidden items-center gap-1.5 rounded-md bg-ink px-4 py-2 text-[14px] font-medium text-white transition-all hover:bg-[#1A2B45] lg:inline-flex"
        >
          {t('nav.portal')}
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      ) : (
        <>
          <a
            href="/login"
            class="hidden text-[14px] font-medium text-graphite transition-colors hover:text-ink lg:inline-flex"
          >
            {t('nav.login')}
          </a>
          <a
            href={contactHref}
            class="hidden items-center gap-1.5 rounded-md bg-ink px-4 py-2 text-[14px] font-medium text-white transition-all hover:bg-[#1A2B45] lg:inline-flex"
          >
            {t('nav.cta')}
          </a>
        </>
      )}

      <button
        type="button"
        id="mobile-menu-toggle"
        aria-label={t('nav.menu.open')}
        aria-controls="mobile-menu"
        aria-expanded="false"
        class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-stone bg-pearl text-ink transition-colors hover:bg-mist md:hidden"
      >
        <svg id="mobile-menu-icon-open" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="4" y1="7" x2="20" y2="7"/>
          <line x1="4" y1="12" x2="20" y2="12"/>
          <line x1="4" y1="17" x2="20" y2="17"/>
        </svg>
        <svg id="mobile-menu-icon-close" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="6" y1="6" x2="18" y2="18"/>
          <line x1="6" y1="18" x2="18" y2="6"/>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-stone bg-pearl md:hidden">
    <nav class="container-pm py-4">
      <ul class="flex flex-col">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="mobile-nav-link block rounded-md px-3 py-3 text-[15px] font-medium text-graphite transition-colors hover:bg-mist hover:text-ink">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      {isLoggedIn ? (
        <a
          href="/app"
          class="mobile-nav-link mt-3 inline-flex w-full items-center justify-center gap-1.5 rounded-md bg-ink px-4 py-3 text-[15px] font-medium text-white transition-all hover:bg-[#1A2B45]"
        >
          {t('nav.portal')}
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      ) : (
        <div class="mt-3 flex flex-col gap-2">
          <a
            href="/login"
            class="mobile-nav-link inline-flex w-full items-center justify-center rounded-md border border-stone bg-pearl px-4 py-3 text-[15px] font-medium text-ink transition-all hover:bg-mist"
          >
            {t('nav.login')}
          </a>
          <a
            href={contactHref}
            class="mobile-nav-link inline-flex w-full items-center justify-center gap-1.5 rounded-md bg-ink px-4 py-3 text-[15px] font-medium text-white transition-all hover:bg-[#1A2B45]"
          >
            {t('nav.cta')}
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      )}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('mobile-menu-icon-open');
  const iconClose = document.getElementById('mobile-menu-icon-close');

  function setOpen(open: boolean) {
    if (!menu || !toggle || !iconOpen || !iconClose) return;
    if (open) {
      menu.classList.remove('hidden');
      iconOpen.classList.add('hidden');
      iconClose.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
    } else {
      menu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    }
  }

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden') === false;
    setOpen(!isOpen);
  });

  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });
</script>
