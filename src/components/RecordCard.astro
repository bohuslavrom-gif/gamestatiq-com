---
// Iter 52: redesigned card — dominantní fotka hráče nahoře s mini team logo overlay,
// kategorie + hodnota dole. Pro team-only records: team logo nahoře, jméno dole.
import type { RecordEntry } from '../lib/league-stats';

interface Props {
  record: RecordEntry;
  accentColor: string;
  isPlayer: boolean;
}

const { record, accentColor, isPlayer } = Astro.props;
const display = record.formattedValue ?? String(record.value);
const initials = record.playerName
  ? record.playerName.split(' ').map((w) => w[0] ?? '').join('').slice(0, 2).toUpperCase()
  : '?';
const teamInitials = (record.teamName ?? '').replace(/[^A-Za-zÀ-ɏ]/g, '').slice(0, 2).toUpperCase() || '?';
const brandColor = record.primaryColor ?? '#0F1B2D';
---

<div class="overflow-hidden rounded-xl border border-stone bg-pearl flex flex-col">
  {isPlayer && record.playerName ? (
    <>
      {/* Hero — dominantní fotka s overlay */}
      <div class="relative flex justify-center bg-gradient-to-b from-mist/40 to-pearl pt-6 pb-4">
        <div class="relative">
          {record.photoUrl ? (
            <img src={record.photoUrl} alt="" loading="lazy" class="h-32 w-32 rounded-full border-4 border-pearl object-cover shadow-md ring-2" style={`--tw-ring-color:${accentColor}`} />
          ) : (
            <span class="inline-flex h-32 w-32 items-center justify-center rounded-full border-4 border-pearl text-[28px] font-bold text-ink shadow-md ring-2" style={`background-color:${brandColor}15;color:${brandColor};--tw-ring-color:${accentColor}`}>{initials}</span>
          )}
          {/* Iter 52: mini team logo overlay vpravo dole */}
          {record.teamLogoUrl ? (
            <img src={record.teamLogoUrl} alt="" loading="lazy" class="absolute -right-1 bottom-0 h-9 w-9 rounded-full border-2 border-pearl bg-pearl object-contain" />
          ) : (
            <span class="absolute -right-1 bottom-0 inline-flex h-9 w-9 items-center justify-center rounded-full border-2 border-pearl text-[10px] font-bold text-white" style={`background-color:${brandColor}`}>{teamInitials}</span>
          )}
        </div>
      </div>

      {/* Jméno + tým */}
      <div class="px-5 pb-3 text-center">
        <p class="text-[15px] font-bold text-ink">
          {record.playerName}
          {record.jersey != null && <span class="ml-1.5 text-[12px] font-medium text-stone-2">#{record.jersey}</span>}
        </p>
        <p class="mt-0.5 text-[11px] uppercase tracking-wider text-slate">{record.teamName}</p>
      </div>

      {/* Hodnota + kategorie */}
      <div class="border-t border-stone bg-mist/30 px-5 py-4 text-center">
        <p class="text-[10px] font-semibold uppercase tracking-[0.1em] text-slate">{record.category}</p>
        <p class="mt-1 text-[40px] font-bold leading-none tabular-nums tracking-tight-3" style={`color:${accentColor}`}>{display}</p>
        {record.matchContext && (
          <p class="mt-2 text-[10px] uppercase tracking-wider text-stone-2">{record.matchContext}</p>
        )}
        <p class="mt-1 text-[10px] text-stone-2">Sezóna {record.season}</p>
      </div>
    </>
  ) : (
    <>
      {/* Team-only — logo nahoře */}
      <div class="relative flex justify-center bg-gradient-to-b from-mist/40 to-pearl pt-6 pb-4">
        {record.teamLogoUrl ? (
          <img src={record.teamLogoUrl} alt="" loading="lazy" class="h-32 w-32 rounded-2xl border-4 border-pearl bg-white object-contain p-2 shadow-md" />
        ) : (
          <span class="inline-flex h-32 w-32 items-center justify-center rounded-2xl border-4 border-pearl text-[36px] font-bold text-white shadow-md" style={`background-color:${brandColor}`}>{teamInitials}</span>
        )}
      </div>

      <div class="px-5 pb-3 text-center">
        <p class="text-[15px] font-bold text-ink">{record.teamName}</p>
      </div>

      <div class="border-t border-stone bg-mist/30 px-5 py-4 text-center">
        <p class="text-[10px] font-semibold uppercase tracking-[0.1em] text-slate">{record.category}</p>
        <p class="mt-1 text-[40px] font-bold leading-none tabular-nums tracking-tight-3" style={`color:${accentColor}`}>{display}</p>
        {record.matchContext && (
          <p class="mt-2 text-[10px] uppercase tracking-wider text-stone-2">{record.matchContext}</p>
        )}
        <p class="mt-1 text-[10px] text-stone-2">Sezóna {record.season}</p>
      </div>
    </>
  )}
</div>
