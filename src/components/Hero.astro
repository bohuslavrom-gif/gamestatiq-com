---
---

<section class="relative overflow-hidden bg-pearl">
  <div class="container-pm pt-16 pb-20 lg:pt-24 lg:pb-28">
    <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_1fr]">
      <div>
        <p class="eyebrow inline-flex items-center gap-2">
          <span class="h-1.5 w-1.5 rounded-full bg-signal"></span>
          Sport stats platforma
        </p>
        <h1 class="h-display mt-5">
          Měřte každou hru.
          <span class="text-signal">Od amatérského</span>
          <br class="hidden sm:block" />
          zápasu po ligové finále.
        </h1>
        <p class="lead mt-6 max-w-xl">
          GameStatiq je live stats platforma pro vážné týmy, ligy a svazy.
          Sbírejte data v reálném čase, sdílejte je s fanoušky a dejte
          trenérům analytiku, která pomůže vyhrát další zápas.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#contact" class="btn-primary">
            Vyžádat demo
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="/liga" class="btn-secondary">
            Live demo: liga
          </a>
        </div>

        <div class="mt-10 grid grid-cols-3 gap-6 border-t border-stone pt-6 sm:max-w-md">
          <div>
            <p class="text-2xl font-bold tracking-tight-2 tabular-nums">5<span class="text-signal">+</span></p>
            <p class="mt-1 text-xs font-medium uppercase tracking-[0.08em] text-slate">Klubů v pilotu</p>
          </div>
          <div>
            <p class="text-2xl font-bold tracking-tight-2 tabular-nums">120<span class="text-signal">+</span></p>
            <p class="mt-1 text-xs font-medium uppercase tracking-[0.08em] text-slate">Zápasů zachyceno</p>
          </div>
          <div>
            <p class="text-2xl font-bold tracking-tight-2 tabular-nums">{`<2 s`}</p>
            <p class="mt-1 text-xs font-medium uppercase tracking-[0.08em] text-slate">Latence k fanouškům</p>
          </div>
        </div>
      </div>

      <!-- Visual: real screenshots — PC widget (background) + Mobile app (foreground) -->
      <div class="relative min-h-[540px] lg:min-h-[620px]">
        <!-- Soft brand backdrop -->
        <div class="absolute -inset-6 -z-10 rounded-[2rem] bg-gradient-to-br from-mist via-pearl to-mist"></div>
        <div class="absolute -top-4 -right-2 -z-10 h-40 w-40 rounded-full bg-signal/10 blur-3xl"></div>
        <div class="absolute bottom-0 -left-4 -z-10 h-48 w-48 rounded-full bg-sky/20 blur-3xl"></div>

        <!-- PC monitor (background, real screenshot of public stats page) -->
        <div class="absolute left-0 top-2 w-[92%] max-w-[480px] lg:left-[-4%] lg:top-0">
          <!-- Monitor bezel -->
          <div class="rounded-[14px] bg-ink p-2 shadow-[0_30px_60px_-20px_rgba(15,27,45,0.4)] ring-1 ring-black/10">
            <div class="overflow-hidden rounded-[8px] bg-pearl">
              <img
                src="/screenshots/pc.png"
                alt="GameStatiq — veřejná stránka klubu Bobcats se sezónními statistikami a tabulkou hráčů"
                width="2548"
                height="1521"
                loading="eager"
                class="block h-auto w-full"
              />
            </div>
          </div>
          <!-- Monitor stand -->
          <div class="mx-auto mt-1 h-1.5 w-1/3 rounded-b-md bg-ink/80"></div>
          <div class="mx-auto h-2 w-2/3 rounded-full bg-ink/15"></div>
        </div>

        <!-- Mobile phone (foreground, real screenshot of scorer app) -->
        <div class="absolute bottom-0 right-0 w-[38%] max-w-[180px] lg:right-4">
          <div class="rounded-[2rem] bg-ink p-1.5 shadow-[0_40px_80px_-20px_rgba(15,27,45,0.55)] ring-1 ring-black/20">
            <div class="overflow-hidden rounded-[1.55rem] bg-pearl">
              <img
                src="/screenshots/mobil.png"
                alt="GameStatiq mobilní app — scorer rozhraní s live skóre, downs, typy hraje"
                width="1440"
                height="3120"
                loading="eager"
                class="block h-auto w-full"
              />
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
