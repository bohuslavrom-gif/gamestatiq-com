---
---

<section class="relative overflow-hidden bg-pearl">
  <div class="container-pm pt-16 pb-20 lg:pt-24 lg:pb-28">
    <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_1fr]">
      <div>
        <p class="eyebrow inline-flex items-center gap-2">
          <span class="h-1.5 w-1.5 rounded-full bg-signal"></span>
          Sport stats platforma
        </p>
        <h1 class="h-display mt-5">
          Měřte každou hru.
          <span class="text-signal">Od amatérského</span>
          <br class="hidden sm:block" />
          zápasu po ligové finále.
        </h1>
        <p class="lead mt-6 max-w-xl">
          GameStatiq je live stats platforma pro vážné týmy, ligy a svazy.
          Sbírejte data v reálném čase, sdílejte je s fanoušky a dejte
          trenérům analytiku, která pomůže vyhrát další zápas.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#contact" class="btn-primary">
            Vyžádat demo
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="/liga" class="btn-secondary">
            Live demo: liga
          </a>
        </div>

        <div class="mt-10 grid grid-cols-3 gap-6 border-t border-stone pt-6 sm:max-w-md">
          <div>
            <p class="text-2xl font-bold tracking-tight-2 tabular-nums">5<span class="text-signal">+</span></p>
            <p class="mt-1 text-xs font-medium uppercase tracking-[0.08em] text-slate">Klubů v pilotu</p>
          </div>
          <div>
            <p class="text-2xl font-bold tracking-tight-2 tabular-nums">120<span class="text-signal">+</span></p>
            <p class="mt-1 text-xs font-medium uppercase tracking-[0.08em] text-slate">Zápasů zachyceno</p>
          </div>
          <div>
            <p class="text-2xl font-bold tracking-tight-2 tabular-nums">{`<2 s`}</p>
            <p class="mt-1 text-xs font-medium uppercase tracking-[0.08em] text-slate">Latence k fanouškům</p>
          </div>
        </div>
      </div>

      <!-- Visual: stylized scoreboard mock -->
      <div class="relative">
        <div class="absolute -inset-4 -z-10 rounded-3xl bg-gradient-to-br from-mist to-pearl"></div>
        <div class="rounded-2xl border border-stone bg-ink p-5 text-white shadow-[0_30px_60px_-15px_rgba(15,27,45,0.35)]">
          <!-- Brand strip -->
          <div class="flex items-center justify-between border-b border-white/10 pb-3 text-[10px] uppercase tracking-[0.14em] text-white/50">
            <span class="inline-flex items-center gap-2 normal-case tracking-tight-2 text-white">
              <svg viewBox="0 0 64 64" class="h-3.5 w-3.5"><rect x="8" y="44" width="6" height="12" rx="1" fill="#FFFFFF" fill-opacity="0.55"/><rect x="18" y="34" width="6" height="22" rx="1" fill="#FFFFFF" fill-opacity="0.55"/><rect x="28" y="20" width="6" height="36" rx="1" fill="#E63946"/><polygon points="38,18 56,37 38,56" fill="#E63946"/></svg>
              <span class="text-[12px] font-semibold">Game<span class="text-signal">Statiq</span></span>
            </span>
            <span>Live</span>
          </div>
          <!-- Scoreboard -->
          <div class="mt-4 flex items-center justify-between">
            <div class="text-center">
              <p class="text-[10px] font-medium uppercase tracking-[0.1em] text-signal">● Bobcats</p>
              <p class="mt-1 text-4xl font-bold tabular-nums">21</p>
            </div>
            <p class="text-sm text-white/30">·</p>
            <div class="text-center">
              <p class="text-[10px] font-medium uppercase tracking-[0.1em] text-white/50">Vyzyvatel</p>
              <p class="mt-1 text-4xl font-bold tabular-nums">14</p>
            </div>
          </div>
          <!-- Status -->
          <div class="mt-5 grid grid-cols-3 gap-2 rounded-lg bg-white/5 p-2.5 text-center">
            <div>
              <p class="text-[9px] uppercase tracking-[0.1em] text-white/50">Down</p>
              <p class="text-sm font-semibold">2 &amp; 7</p>
            </div>
            <div>
              <p class="text-[9px] uppercase tracking-[0.1em] text-white/50">Ball</p>
              <p class="text-sm font-semibold">+38</p>
            </div>
            <div>
              <p class="text-[9px] uppercase tracking-[0.1em] text-white/50">Drive</p>
              <p class="text-sm font-semibold">5 plays</p>
            </div>
          </div>
          <!-- Mini playlog -->
          <div class="mt-4 space-y-2">
            <div class="rounded-md border border-white/10 bg-white/[0.03] p-2.5 text-[12px]">
              <div class="flex items-center justify-between">
                <span class="rounded-full bg-signal/20 px-2 py-0.5 text-[9px] font-semibold uppercase tracking-wider text-signal">Pass TD</span>
                <span class="text-[10px] text-white/40">2:14 Q3</span>
              </div>
              <p class="mt-1.5 text-white/85">Krása → Beck +18 yd · Cervenka [Slant]</p>
            </div>
            <div class="rounded-md border border-white/10 bg-white/[0.03] p-2.5 text-[12px]">
              <div class="flex items-center justify-between">
                <span class="rounded-full bg-white/10 px-2 py-0.5 text-[9px] font-semibold uppercase tracking-wider text-white/70">Rush</span>
                <span class="text-[10px] text-white/40">3:02 Q3</span>
              </div>
              <p class="mt-1.5 text-white/85">Drmla run +6 yd · Macho · Vacek</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
