---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, switchLangPath, languages, type Lang } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'GameStatiq — Sport stats platforma',
  description = 'Měřte každou hru. Sportovní statistiky pro týmy, ligy a svazy.',
  ogImage = '/brand/gamestatiq-app-icon.svg',
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const htmlLang = ({ cs: 'cs', en: 'en', de: 'de' } as Record<Lang, string>)[lang];

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const altLinks = (Object.keys(languages) as Lang[]).map((l) => ({
  hreflang: ({ cs: 'cs-CZ', en: 'en', de: 'de' } as Record<Lang, string>)[l],
  href: new URL(switchLangPath(Astro.url, l), Astro.site).toString(),
}));
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/brand/gamestatiq-favicon.svg" />
    <link rel="apple-touch-icon" href="/brand/gamestatiq-app-icon.svg" />
    <meta name="theme-color" content="#0F1B2D" />

    <link rel="canonical" href={canonicalURL} />
    {altLinks.map((l) => (
      <link rel="alternate" hreflang={l.hreflang} href={l.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(switchLangPath(Astro.url, 'cs'), Astro.site).toString()} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
